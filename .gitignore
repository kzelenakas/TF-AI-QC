# ==========================================
# TF AI-QC — .gitignore
# ==========================================

# Environment & Secrets — NEVER commit these
.env
.env.local
.env.production
.env.staging
*.env
backend/.env
frontend/.env

# API keys and credentials
data-sources/bubble-oms/config.md
context/guidelines/**/*.pdf
context/sample-reports/**/*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.venv/
venv/
env/
ENV/
.python-version
htmlcov/
.coverage
.coverage.*
.pytest_cache/
*.log

# Alembic — keep migrations, not compiled versions
backend/app/db/migrations/__pycache__/

# Node / Frontend
node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
.pnpm-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Railway
.railway/

# Uploads / temp files
uploads/
tmp/
*.tmp

# Test artifacts
.coverage
htmlcov/
test-results/
playwright-report/

	<xsd:complexType name="CAR_STORAGE">
		<xsd:annotation>
			<xsd:documentation>Information regarding the type, quality, condition, materials, size and other facts about the car storage.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>

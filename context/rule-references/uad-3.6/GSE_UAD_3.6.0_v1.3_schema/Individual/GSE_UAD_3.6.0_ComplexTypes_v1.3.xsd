	<xsd:complexType name="ADDITIONAL_RENTAL_INCOME">
		<xsd:annotation>
			<xsd:documentation>Contains information about income sources and amounts received in addition to the agreed upon rent.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AdditionalRentalIncomeType" type="AdditionalRentalIncomeEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents supplemental rental income for a rental property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AdditionalRentalIncomeTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Additional Rental Income Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MonthlyActualAdditionalIncomeAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The current amount of additional income received for services and amenities provided (e.g. parking lot, laundry facilities).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MonthlyEstimatedAdditionalIncomeAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The amount of additional income expected to be received for services and amenities provided (e.g. parking lot, laundry facilities).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="ADDITIONAL_RENTAL_INCOME_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>

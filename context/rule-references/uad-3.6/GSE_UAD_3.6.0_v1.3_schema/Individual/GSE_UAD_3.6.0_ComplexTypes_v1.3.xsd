			<xsd:documentation>Information about the highest and best use of the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="FinanciallyFeasibleIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the highest and best use of the property is financially feasible.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LegallyPermissibleIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the highest and best use is legally permissible.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MaximallyProductiveIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the current use of the property is maximally productive.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PhysicallyPossibleIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the highest and best use of the property is physically possible.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SiteHighestBestUseIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the present use or the proposed use is the highest and best of the site.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="HIGHEST_AND_BEST_USE_EXTENSION" minOccurs="0"/>

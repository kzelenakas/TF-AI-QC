			<xsd:element name="DaysOnMarketCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total number of days on the property has been on the market from the last material status date to the time listing selected for the valuation.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FinalListPriceAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The final list price of the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="InitialListPriceAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>

	<xsd:complexType name="SIGNATORIES">
		<xsd:annotation>
			<xsd:documentation>Information about one or more types of signatories. Holds all occurrences of SIGNATORY.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="SIGNATORY" type="SIGNATORY" maxOccurs="2">
				<xsd:annotation>
					<xsd:documentation>Information regarding the type of electronic signature used to represent a legally binding signature of a specific party named in the document and may also contain information regarding the geographic location, date and time.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="SIGNATORIES_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="SIGNATORY">
		<xsd:annotation>
			<xsd:documentation>Information regarding the type of electronic signature used to represent a legally binding signature of a specific party named in the document and may also contain information regarding the geographic location, date and time.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="EXECUTION" type="EXECUTION">
				<xsd:annotation>
					<xsd:documentation>Information regarding the signing event.</xsd:documentation>

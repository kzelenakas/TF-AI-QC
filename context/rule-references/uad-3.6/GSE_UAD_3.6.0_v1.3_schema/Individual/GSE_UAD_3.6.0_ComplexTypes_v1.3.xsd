					<xsd:documentation>A value from a MISMO prescribed list that represents the method used to derive depreciated building value.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepreciationMethodTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Depreciation Method Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SiteEstimatedValueAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The dollar value estimated for the property site (e.g., land that is improved so that it is ready to be used for a specific purpose).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SiteEstimatedValueCommentDescription" type="MISMOString" nillable="true" minOccurs="0">

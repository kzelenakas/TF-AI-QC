					<xsd:documentation>A value from a MISMO prescribed list that represents the party that has included the additional certification in the report.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ValuationAdditionalCertificationText" type="MISMOString" nillable="true" minOccurs="0">

				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="SERVICE_PROVIDER">
		<xsd:annotation>
			<xsd:documentation>Information about a service provider available for use in the loan transaction.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PROVIDED_SERVICES" type="PROVIDED_SERVICES">
				<xsd:annotation>
					<xsd:documentation>Information about one or more services provided. Holds all occurrences of PROVIDED_SERVICE.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="SERVICE_PROVIDER_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="SERVICES">
		<xsd:annotation>
			<xsd:documentation>A collection of objects that describe requests and responses for services.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="SERVICE" type="SERVICE" minOccurs="1" maxOccurs="2">
				<xsd:annotation>
					<xsd:documentation>A collection of details related to a fulfillment service or product in terms of request, process and result.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="SERVICES_EXTENSION" minOccurs="0"/>

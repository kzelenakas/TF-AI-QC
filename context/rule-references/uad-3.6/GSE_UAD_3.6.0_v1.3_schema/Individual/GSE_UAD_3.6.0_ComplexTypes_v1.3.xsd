	</xsd:complexType>
	<xsd:complexType name="VALUATION_REPORT_ADDITIONAL_INTENDED_USERS">
		<xsd:annotation>
			<xsd:documentation>Contains information about one or more VALUATION_REPORT_ADDITIONAL_INTENDED_USER. Contains all instances of VALUATION_REPORT_ADDITIONAL_INTENDED_USER.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="VALUATION_REPORT_ADDITIONAL_INTENDED_USER" type="VALUATION_REPORT_ADDITIONAL_INTENDED_USER" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more additional users of the valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="VALUATION_REPORT_ADDITIONAL_INTENDED_USERS_EXTENSION" minOccurs="0"/>
		</xsd:sequence>

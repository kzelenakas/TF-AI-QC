				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="VALUATION_RECONCILIATION_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">

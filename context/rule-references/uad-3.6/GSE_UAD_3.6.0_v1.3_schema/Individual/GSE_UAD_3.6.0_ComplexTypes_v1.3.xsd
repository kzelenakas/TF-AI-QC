	<xsd:complexType name="SALES_CONTRACT">
		<xsd:annotation>
			<xsd:documentation>Information about the agreement for sale between a buyer and seller by which they agree on terms of the sale.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="SALES_CONTRACT_DETAIL" type="SALES_CONTRACT_DETAIL">
				<xsd:annotation>
					<xsd:documentation>Information about the type, terms, value and other details of the sales agreement.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="SALES_CONTRACT_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>

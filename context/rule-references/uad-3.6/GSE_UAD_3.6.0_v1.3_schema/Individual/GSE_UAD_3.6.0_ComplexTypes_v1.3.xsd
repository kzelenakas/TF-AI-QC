				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ListingEndDate" type="MISMODate" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The date when the listing was no longer offered for sale or rent.</xsd:documentation>

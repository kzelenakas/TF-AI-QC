			<xsd:documentation>Contains details related to a fulfillment service or product in terms of request, process, result and response.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ServiceType" type="ServiceEnum">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that specifies the type of service being defined under the SERVICE element.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="SERVICE_DETAIL_EXTENSION" minOccurs="0"/>

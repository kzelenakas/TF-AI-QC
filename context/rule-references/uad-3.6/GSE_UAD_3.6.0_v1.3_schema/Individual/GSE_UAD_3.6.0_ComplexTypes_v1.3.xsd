			<xsd:documentation>Information about one or more parcel of land. Holds all occurrences of PARCEL.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PARCEL" type="PARCEL" maxOccurs="unbounded">

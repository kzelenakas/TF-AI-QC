		<xsd:annotation>
			<xsd:documentation>Information regarding the quality, condition, materials and other facts about the attic.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AccessibleForObservationIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the component is accessible for visual observation.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="VisualObservationCompletedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that a visual observation was completed, as defined by the applicable organization's policy or guideline.</xsd:documentation>

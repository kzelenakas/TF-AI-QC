					<xsd:documentation>Information about a body of water that may impact a property's value and marketability.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="WATER_FRONT_FEATURES" type="WATER_FRONT_FEATURES" minOccurs="0">

			<xsd:documentation>Contains information about all bodies of water that are located on or near the property. Contains all instances of BODY_OF_WATER.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="BODY_OF_WATER" type="BODY_OF_WATER" maxOccurs="unbounded">

			<xsd:element name="OwnershipTransferDate" type="MISMODate" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The date of the transfer of ownership of real property as recognized in the jurisdiction in which it is located.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OwnershipTransferTransactionAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The amount of transaction (typically the sale price) related to the transfer of ownership of real property as recognized in the jurisdiction in which it is located.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OwnershipTransferTransactionType" type="OwnershipTransferTransactionEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The type of ownership transfer of real property as recognized in the jurisdiction in which it is located.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SaleType" type="SaleEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the type of sales transaction for the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SaleTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Sale Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="SALES_HISTORY_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="SCOPE_OF_WORK">
		<xsd:annotation>
			<xsd:documentation>Contains the details pertinent to the appraisal assignment that the appraiser must accept and abide by in the fulfillment of an appraisal assignment.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="SCOPE_OF_WORK_DETAIL" type="SCOPE_OF_WORK_DETAIL">
				<xsd:annotation>
					<xsd:documentation>Contains the details pertinent to the valuation and inspection that must performed in the fulfillment of an appraisal assignment.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="VALUATION_INTENDED_USES" type="VALUATION_INTENDED_USES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information regarding one or more types of usage of the valuation report. Holds all occurrences of VALUATION_INTENDED_USE.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="VALUATION_REPORT_ADDITIONAL_CERTIFICATIONS" type="VALUATION_REPORT_ADDITIONAL_CERTIFICATIONS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more VALUATION_REPORT_ADDITIONAL_CERTIFICATION. Contains all instances of VALUATION_REPORT_ADDITIONAL_CERTIFICATION.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="VALUATION_REPORT_ADDITIONAL_INTENDED_USERS" type="VALUATION_REPORT_ADDITIONAL_INTENDED_USERS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more VALUATION_REPORT_ADDITIONAL_INTENDED_USER. Contains all instances of VALUATION_REPORT_ADDITIONAL_INTENDED_USER.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="SCOPE_OF_WORK_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="SCOPE_OF_WORK_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Contains the details pertinent to the valuation and inspection that must performed in the fulfillment of an appraisal assignment.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="CostApproachIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates the cost approach will be included in the appraisal report to support the assignment.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="GovernmentAgencyAppraisalIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the appraisal has been prepared for a federal agency.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="GovernmentAgencyAppraisalType" type="GovernmentAgencyAppraisalEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the federal agency for which the appraisal has been prepared.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="IncomeApproachIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates the income approach will be included in the appraisal report to support the assignment.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyRightsNotAppraisedDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field describing the different types of property rights not included as part of the valuation.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RentScheduleIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates a rent schedule will be included in the appraisal report.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SalesComparisonApproachIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates the sales comparison approach will be included in the appraisal report to support the assignment.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SiteValueIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates a separate land value will be included in the appraisal report to support the assignment.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ValuationAdditionalIntendedUserIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that additional intended users have been identified for the valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ValuationAdditionalScopeOfWorkIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that additional scope of work (beyond the minimum scope) has been identified for this valuation assignment.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ValuationAssignmentType" type="ValuationAssignmentEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Specifies the business reason that motivated the order for a valuation.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ValuationAssignmentTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field used to collect additional information when other is selected for Valuation Assignment Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ValuationScopeOfWorkDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Describes the scope of work identified as necessary by the appraiser to determine a valuation with respect to its intended use and users.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="SCOPE_OF_WORK_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="SERVICE">
		<xsd:annotation>
			<xsd:documentation>A collection of details related to a fulfillment service or product in terms of request, process and result.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:choice minOccurs="0">
				<xsd:element name="INSPECTION_SERVICE" type="INSPECTION_SERVICE" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>The information necessary to request and receive an inspection of a property.</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="VALUATION" type="VALUATION" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>The information necessary to request and receive a valuation service for a property.</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
			</xsd:choice>
			<xsd:element name="PARTIES" type="PARTIES">
				<xsd:annotation>
					<xsd:documentation>A collection of objects that define specific parties to a deal. This includes the direct participating parties, such as borrower and seller and the indirect parties such as the credit report provider.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RELATIONSHIPS" type="RELATIONSHIPS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Collection of xlink attributes that define relationships between two elements and optionally provide the type of relationship. Many:Many relationships are formed with multiple RELATIONSHIP children with the same xlink:title value.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SERVICE_DETAIL" type="SERVICE_DETAIL">
				<xsd:annotation>
					<xsd:documentation>Contains details related to a fulfillment service or product in terms of request, process, result and response.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="SERVICE_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="SERVICE_DETAIL">

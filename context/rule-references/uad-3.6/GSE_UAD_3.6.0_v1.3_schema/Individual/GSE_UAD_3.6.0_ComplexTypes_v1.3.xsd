	<xsd:complexType name="PROPERTY_TAX_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Information related to the assessments by taxing authorities, including the timing, status, amounts due and other details for the various property taxes.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PropertyTaxAbatementsOrExemptionsIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that a tax reduction or exemption has been granted.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SpecialTaxAssessmentsIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates the existence of special tax assessments on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_TAX_DETAIL_EXTENSION" minOccurs="0"/>

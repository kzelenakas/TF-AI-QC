					<xsd:documentation>A measurement that specifies the area of the identified item being replaced or reproduced. The applicable unit of measurement is specified by the Area Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ReplacementOrReproductionCostAreaType" type="ReplacementOrReproductionCostAreaEnum" nillable="true" minOccurs="0">

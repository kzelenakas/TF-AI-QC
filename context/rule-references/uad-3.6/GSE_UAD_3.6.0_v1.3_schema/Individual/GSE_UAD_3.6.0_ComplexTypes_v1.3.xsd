			<xsd:documentation>Information about one or more PROPERTY_TAX. Holds all occurrences of PROPERTY_TAX.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PROPERTY_TAX" type="PROPERTY_TAX">

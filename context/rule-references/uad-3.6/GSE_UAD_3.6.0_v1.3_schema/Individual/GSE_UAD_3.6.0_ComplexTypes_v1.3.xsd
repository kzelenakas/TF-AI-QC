	<xsd:complexType name="PROPERTY_UNIT">
		<xsd:annotation>
			<xsd:documentation>Information about a given unit of housing.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ACCESSIBILITY_FEATURES" type="ACCESSIBILITY_FEATURES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Detailed information about one or more types of accessibility features. Contains all instances of ACCESSIBILITY_FEATURE.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="INTERIOR_COMPONENTS" type="INTERIOR_COMPONENTS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more INTERIOR_COMPONENT. Contains all instances of INTERIOR_COMPONENT.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LEVELS" type="LEVELS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more LEVEL. Contains all instances of LEVEL.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROPERTY_UNIT_AREA" type="PROPERTY_UNIT_AREA">
				<xsd:annotation>
					<xsd:documentation>Contains information about various area measurements within the unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROPERTY_UNIT_DETAIL" type="PROPERTY_UNIT_DETAIL">
				<xsd:annotation>
					<xsd:documentation>Information about various aspects of the property unit, including number of floors, bedrooms, bathrooms, square footage and cooperative information.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RENTAL_INFORMATIONS" type="RENTAL_INFORMATIONS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more RENTAL_INFORMATION. Contains all instances of RENTAL_INFORMATION.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ROOMS" type="ROOMS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more ROOM. Holds all occurrences of ROOM.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UNIT_RENT_SCHEDULE" type="UNIT_RENT_SCHEDULE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about the lease details and dollar amount of market rent for a living unit in a multi-unit property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UNIT_VIEWS" type="UNIT_VIEWS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more UNIT_VIEW. Holds all occurrences of UNIT_VIEW.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_UNIT_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_UNIT_AREA">
		<xsd:annotation>
			<xsd:documentation>Contains information about various area measurements within the unit.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AllowableWorkSpaceAreaMeasure" type="MISMOAreaMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the allowable space within the residential unit to be used for non-residential purposes. The applicable unit of measurement is specified by the Area Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UnitAboveGradeUnfinishedAreaMeasure" type="MISMOAreaMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the total above grade unfinished area of the living unit. The applicable unit of measurement is specified by the Area Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UnitBelowGradeUnfinishedAreaMeasure" type="MISMOAreaMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the total below grade unfinished area of the living unit. The applicable unit of measurement is specified by the Area Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UnitNonStandardAboveGradeFinishedAreaMeasure" type="MISMOAreaMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the total finished area, above grade, that cannot be considered as living area per the applicable standard and/or policy. The applicable unit of measurement is specified by the Area Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UnitNonStandardBelowGradeFinishedAreaMeasure" type="MISMOAreaMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the total finished area below grade that cannot be considered as living area per the applicable standard and/or policy. The applicable unit of measurement is specified by the Area Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UnitStandardAboveGradeFinishedAreaMeasure" type="MISMOAreaMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the total finished area, above grade, and considered to be living area per the applicable standard and/or policy (this is commonly referred to as GLA or finished square footage). The applicable unit of measurement is specified by the Area Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UnitStandardBelowGradeFinishedAreaMeasure" type="MISMOAreaMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the total finished area below grade considered to be living area per the applicable standard and/or policy. The applicable unit of measurement is specified by the Area Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UnitTotalFinishedAreaMeasure" type="MISMOAreaMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the total finished area of the individual living unit. The applicable unit of measurement is specified by the Area Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_UNIT_AREA_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_UNIT_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Information about various aspects of the property unit, including number of floors, bedrooms, bathrooms, square footage and cooperative information.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AccessoryDwellingUnitIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the unit is an accessory dwelling unit (e.g. mother-in-law suite, secondary dwelling unit, carriage house, etc.).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AccessoryDwellingUnitLegallyRentableIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the unit is legally rentable (e.g. meets local applicable regulations).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AccessoryDwellingUnitTypicalToMarketIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that accessory dwelling units are common in the market location.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AccessType" type="AccessEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the entrances and exits to an area.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AllowableLiveWorkSpaceIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that there is Live/Work space available within the residential unit. A Live/Work unit refers to a unit in a Condominium or Cooperative project that allows space within the individual unit to be used jointly for non-residential and residential purposes and is primarily residential.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BedroomCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The number of bedrooms per unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CornerUnitIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the property unit is situated at the corner of the building.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FloorIdentifier" type="MISMOIdentifier" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A unique alphanumeric string identifying the floor of the unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FullBathroomCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The number of full bathrooms in the living unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="GradeLevelType" type="GradeLevelEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the unit's or level's grade as it relates to ground level.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="HalfBathroomCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The number of half bathrooms in the living unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="InteriorConditionRatingCode" type="InteriorConditionRatingEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An enumerated or coded value used to identify the interior condition of the unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="InteriorQualityRatingCode" type="InteriorQualityRatingEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An enumerated or coded value used to identify the interior quality of the unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LevelCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The number of levels in a living unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OverallBathroomsQualityDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field summarizing the quality of all the bathrooms.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OverallBathroomsUpdateStatusType" type="OverallBathroomsUpdateStatusEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the degree to which all of the bathrooms have been updated.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SeparatePostalAddressIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the unit has a separate address from other unit(s) on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UnitBelowGradeFinishComparisonType" type="UnitBelowGradeFinishComparisonEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the quality of the finish for the below grade area(s) when compared to the above grade living area.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UnitIdentifier" type="MISMOIdentifier" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An unique alphanumeric string used to identify and/or differentiate between multiple units located on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UnitIncludedInRentScheduleIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the living unit is included in the rent schedule.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UnitInteriorDefectsExistIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the interior of the living unit or the accessory dwelling unit has defect(s), damage(s) or deficienc(ies).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UnitMixedUsageIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates the unit contains some space designed for commercial use.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UnitOccupancyType" type="UnitOccupancyEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Specifies the current occupancy status of the specified unit within a property or an individual unit or a group of units within project.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UnitUtilitiesOperatingIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that all utilities are operating or functional.</xsd:documentation>

	<xsd:complexType name="ADDITIONAL_ADDRESSES">
		<xsd:annotation>
			<xsd:documentation>Information about one or more additional addresses associated with the property. Holds all occurrences of ADDITIONAL_ADDRESS.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ADDITIONAL_ADDRESS" type="ADDRESS" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>Information about one or more additional addresses associated with the property. Possible use cases are 1) properties in rural areas may have different addresses, 2) allows flexibility for capturing more than one address for 2-4 unit properties that have multiple structures with different address, 3) when property address is truly changed for various reasons (citycounty changes street names etc.), 4) property truly spans two countiestownship.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="ADDITIONAL_ADDRESSES_EXTENSION" minOccurs="0"/>

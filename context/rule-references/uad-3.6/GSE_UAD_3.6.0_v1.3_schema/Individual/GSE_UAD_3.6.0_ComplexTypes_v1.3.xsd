				</xsd:annotation>
			</xsd:element>
			<xsd:element name="WaterAccessRightType" type="WaterAccessRightEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the property access right to the body of water.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="WaterAccessRightTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Water Access Right Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="BODY_OF_WATER_EXTENSION" minOccurs="0"/>

	<xsd:complexType name="IMAGE">
		<xsd:annotation>
			<xsd:documentation>Specific information pertaining to an image.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AltitudeElevationLinearMeasure" type="MISMOLinearMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the elevation above sea level where the image was captured. The applicable unit of measurement is specified by the Linear Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ImageCaptionCommentDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field used to further describe or comment on the image.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ImageCategoryType" type="ImageCategoryEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that categorizes the image.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ImageDatetime" type="MISMODatetime" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The date and time when the image was taken.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ImageFileLocationIdentifier" type="MISMOIdentifier" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A unique alphanumeric string identifying the location of the image within a file structure.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LatitudeIdentifier" type="MISMOIdentifier" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Gives the location of a place on Earth north or south of the equator. Lines of Latitude are the horizontal lines shown running east-to-west on maps (particularly so in the Mercator projection). Technically, latitude is an angular measurement in degrees ranging from 0 degrees at the equator (low latitude) to 90 degree at the poles (90 degree N or +90 degree for the North Pole and 90 degree S or -90 degree for the South Pole).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LongitudeIdentifier" type="MISMOIdentifier" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The geographic coordinate most commonly used in cartography and global navigation for east-west measurement. It is the angular distance measured east or west and usually expressed in degrees (or hours), minutes, and seconds, from the prime meridian, defined to be at the Royal Observatory, Greenwich, in England, to the meridian passing through another position on the surface of the earth.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MIMETypeIdentifier" type="MISMOIdentifier" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Indicates the Multipurpose Internet Mail Extensions type of the data in the resource. A registered list of these types is available at http://www.iana.org/assignments/media-types/ AND http://tools.ietf.org/html/rfc2045. In addition, there is a defined syntax for custom MIME types that should be followed when the type is not registered with IANA.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="IMAGE_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="IMAGES">
		<xsd:annotation>
			<xsd:documentation>Information regarding one or more types of photos. Holds all occurrences of IMAGES.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="IMAGE" type="IMAGE" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>Specific information pertaining to an image.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="IMAGES_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="IMPROVEMENT">
		<xsd:annotation>
			<xsd:documentation>Information regarding the structure including details about the interior, exterior, systems, and features of the property. An improvement is any addition to raw land such as buildings and site improvements.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="CONVERTED_AREAS" type="CONVERTED_AREAS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more CONVERTED_AREA. Contains all occurrences of CONVERTED_AREA.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="IMPROVEMENT_DETAIL" type="IMPROVEMENT_DETAIL">
				<xsd:annotation>
					<xsd:documentation>Contains specific information pertaining to IMPROVEMENT.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="INTERIOR" type="INTERIOR" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information regarding the details of the rooms, a summary of rooms and other facts about the interior of the structure for a property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MANUFACTURED_HOME" type="MANUFACTURED_HOME" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information regarding the type, identification, section breakout and other facts about the manufactured home. A manufactured home is a type of factory-built or prefabricated housing.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OUTBUILDING" type="OUTBUILDING" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more buildings on the same property but separate from the main dwelling.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROPERTY_UNITS" type="PROPERTY_UNITS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more PROPERTY_UNIT. Holds all occurrences of PROPERTY_UNIT.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="STRUCTURE" type="STRUCTURE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information that describes the interior, exterior, roof, foundation and other aspects of the property structure.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SYSTEM" type="SYSTEM" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about types of systems for the structure. For example heating and security systems.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="IMPROVEMENT_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="IMPROVEMENT_COST">
		<xsd:annotation>
			<xsd:documentation>Contains information about the costs to replace or reproduce each improvement on the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="IMPROVEMENT_COST_DETAIL" type="IMPROVEMENT_COST_DETAIL" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains detailed information about the costs to replace or reproduce each improvement on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="REPLACEMENT_REPRODUCTION_COSTS" type="REPLACEMENT_REPRODUCTION_COSTS">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more REPLACEMENT_REPRODUCTION_COST. Contains all instances of REPLACEMENT_REPRODUCTION_COST.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="IMPROVEMENT_COST_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="IMPROVEMENT_COST_AND_DEPRECIATED_VALUE">
		<xsd:annotation>
			<xsd:documentation>Contains information about the costs and associated depreciation for each improvement (dwelling or outbuilding) on the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="IMPROVEMENT_COST" type="IMPROVEMENT_COST">
				<xsd:annotation>
					<xsd:documentation>Contains information about the costs to replace or reproduce each improvement on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="IMPROVEMENT_DEPRECIATED_VALUE_SUMMARY" type="IMPROVEMENT_DEPRECIATED_VALUE_SUMMARY">
				<xsd:annotation>
					<xsd:documentation>Contains aggregate information about the improvement's depreciated value.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="IMPROVEMENT_DEPRECIATION" type="IMPROVEMENT_DEPRECIATION">
				<xsd:annotation>
					<xsd:documentation>Contains information about different type of depreciation applied to an improvement.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="IMPROVEMENT_COST_AND_DEPRECIATED_VALUE_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="IMPROVEMENT_COST_AND_DEPRECIATED_VALUES">
		<xsd:annotation>
			<xsd:documentation>Contains information about one or more IMPROVEMENT_COST_AND_DEPRECIATED_VALUE. Contains all instances of IMPROVEMENT_COST_AND_DEPRECIATED_VALUE.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="IMPROVEMENT_COST_AND_DEPRECIATED_VALUE" type="IMPROVEMENT_COST_AND_DEPRECIATED_VALUE" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>Contains information about the costs and associated depreciation for each improvement (dwelling or outbuilding) on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="IMPROVEMENT_COST_AND_DEPRECIATED_VALUES_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="IMPROVEMENT_COST_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Contains detailed information about the costs to replace or reproduce each improvement on the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ManufacturedHomeInstallationCostAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total amount associated with the delivery, installation and setup costs for a Manufactured Home.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="IMPROVEMENT_COST_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="IMPROVEMENT_DEPRECIATED_VALUE_SUMMARY">
		<xsd:annotation>
			<xsd:documentation>Contains aggregate information about the improvement's depreciated value.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ImprovementEstimatedTotalCostAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The estimated cost of the improvement calculated by adding all costs to replace or reproduce the improvement, deducting the applicable depreciation, and adding any applicable delivery, installation, and setup fee.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="IMPROVEMENT_DEPRECIATED_VALUE_SUMMARY_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="IMPROVEMENT_DEPRECIATION">
		<xsd:annotation>
			<xsd:documentation>Contains information about different type of depreciation applied to an improvement.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="DepreciationExternalAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>This dollar amount of the depreciation due to external factors impacting this improvement (e.g. economic trends, external obsolescence).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepreciationExternalPercent" type="MISMOPercent" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A portion of 100 that represents the percent of depreciation applied due to external factors impacting this improvement.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepreciationFunctionalAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The dollar amount of the depreciation due this improvement's style, design and/or functional utility becoming outdated.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepreciationFunctionalPercent" type="MISMOPercent" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A portion of 100 that represents the percent of depreciation applied to this improvement due to style, design and/or functional utility becoming outdated.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepreciationPhysicalAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The dollar amount of the depreciation due to wear and tear of this improvement.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepreciationPhysicalPercent" type="MISMOPercent" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A portion of 100 that represents the percent of physical depreciation applied to this improvement for wear and tear.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepreciationTotalAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total amount of accumulated monetary loss in value for the reproduction or replacement cost of this improvement from all causes of depreciation.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="IMPROVEMENT_DEPRECIATION_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="IMPROVEMENT_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Contains specific information pertaining to IMPROVEMENT.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ConvertedAreaExistsIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that an area within the structure or the entire structure has been improved from its original use to livable standards.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CoolingSystemExistsIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the structure has a permanent cooling system.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DwellingExteriorDefectsExistIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the exterior of the dwelling has defect(s), damage(s) or deficienc(ies).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="HeatingSystemExistsIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the structure has a permanent heating system.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ImprovementType" type="ImprovementEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that classifies the structure on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LackOfHeatingSystemTypicalToMarketIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the lack of a heating system is prevalent in the market.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NonContinuousFinishedAreaIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates there is finished area attached to the dwelling that is separate and not accessible from any unit(s) (e.g., a finished office above, below or behind an attached garage that cannot be accessed from within any living unit).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OutbuildingDefectsExistIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the outbuilding has defect(s), damage(s) or deficienc(ies).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OutbuildingRealPropertyIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the outbuilding is considered real property, e.g. permanently affixed to the land.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OutbuildingType" type="OutbuildingEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the intended functional design of an outbuilding present on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OutbuildingTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Outbuilding Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyStructureBuiltYear" type="MISMOYear" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The calendar year in which the construction of the structure was completed.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyStructureBuiltYearEstimatedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>

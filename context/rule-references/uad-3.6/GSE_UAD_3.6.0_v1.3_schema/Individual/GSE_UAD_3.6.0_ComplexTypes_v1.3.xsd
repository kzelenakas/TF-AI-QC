			<xsd:documentation>Information about one or more PROPERTY_TAX_EXEMPTION. Holds all occurrences of PROPERTY_TAX_EXEMPTION.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PROPERTY_TAX_EXEMPTION" type="PROPERTY_TAX_EXEMPTION">

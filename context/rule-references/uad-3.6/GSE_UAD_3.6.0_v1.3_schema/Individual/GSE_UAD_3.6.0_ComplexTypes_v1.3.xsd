	<xsd:complexType name="ACCESSIBILITY_FEATURE">
		<xsd:annotation>
			<xsd:documentation>Detailed information about any updates or additions designed to provide accessibility and usability for a person with disabilities.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AccessibilityFeatureType" type="AccessibilityFeatureEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents a feature that has been designed to provide accessibility and usability for a person with disabilities.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AccessibilityFeatureTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Accessibility Feature Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AccessibilityModificationDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field describing the customization made to provide accessibility and usability for a person with disabilities.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="ACCESSIBILITY_FEATURE_EXTENSION" minOccurs="0"/>
		</xsd:sequence>

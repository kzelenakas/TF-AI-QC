			<xsd:documentation>Contains information about one or more VALUATION_REPORT_ADDITIONAL_CERTIFICATION. Contains all instances of VALUATION_REPORT_ADDITIONAL_CERTIFICATION.</xsd:documentation>
		</xsd:annotation>

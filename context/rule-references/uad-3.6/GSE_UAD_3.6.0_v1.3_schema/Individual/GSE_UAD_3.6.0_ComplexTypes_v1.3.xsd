			<xsd:element name="CostAnalysisCommentDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field used to further describe the application of the Cost Approach valuation method to the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CostAnalysisType" type="CostAnalysisEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the manner in which the building would be reconstructed.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CostMethodType" type="CostMethodEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the methodology used to arrive at a replacement or reproduction building cost.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CostMethodTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Cost Method Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepreciatedCostDwellingsTotalAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total amount of depreciated cost for all dwellings on the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepreciatedCostOutbuildingsTotalAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total amount of depreciated cost for all outbuildings on the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepreciationMethodType" type="DepreciationMethodEnum" nillable="true" minOccurs="0">

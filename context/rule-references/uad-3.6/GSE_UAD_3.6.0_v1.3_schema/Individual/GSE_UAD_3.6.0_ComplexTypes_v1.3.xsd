					<xsd:documentation>Contains information about one or more ADDITIONAL_REQUESTED_CONDITIONAL_VALUATION. Contains all instances of ADDITIONAL_REQUESTED_CONDITIONAL_VALUATION.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="VALUATION_RECONCILIATION_DETAIL" type="VALUATION_RECONCILIATION_DETAIL">

	<xsd:complexType name="PARTIES">
		<xsd:annotation>
			<xsd:documentation>A collection of objects that define specific parties to a deal. This includes the direct participating parties, such as borrower and seller and the indirect parties such as the credit report provider.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PARTY" type="PARTY" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>A collection of information about a single party to a transaction. Included direct participants like the borrower and seller as well as indirect participants such as the flood certificate provider.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PARTIES_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PARTY">
		<xsd:annotation>
			<xsd:documentation>A collection of information about a single party to a transaction. Included direct participants like the borrower and seller as well as indirect participants such as the flood certificate provider.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:choice minOccurs="0">
				<xsd:element name="INDIVIDUAL" type="INDIVIDUAL" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>Information regarding a natural person.</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="LEGAL_ENTITY" type="LEGAL_ENTITY" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>This is additional information that describes or identifies a legal entity.</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
			</xsd:choice>
			<xsd:element name="ADDRESSES" type="ADDRESSES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more ADDRESS. Holds all occurrences of ADDRESS.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ROLES" type="ROLES">
				<xsd:annotation>
					<xsd:documentation>Information about one or more ROLE. Holds all occurrences of ROLE.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PARTY_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROJECT">
		<xsd:annotation>
			<xsd:documentation>A residential development area that could be comprised of any combination of multifamily and single family structures and may include mixed land use such as commercial. A project refers to an organized development in which shared common areas, road ways and management structures exist. Project management and individual homeowner associations may also co-exist within the project.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PROJECT_AMENITIES" type="PROJECT_AMENITIES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more PROJECT_AMENITY. Contains all instances of PROJECT_AMENITY.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROJECT_ANALYSIS" type="PROJECT_ANALYSIS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about the marketability and analysis of a housing project.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROJECT_BLANKET_FINANCINGS" type="PROJECT_BLANKET_FINANCINGS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more PROJECT_BLANKET_FINANCING. Holds all occurrences of PROJECT_BLANKET_FINANCING.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROJECT_COMPONENTS" type="PROJECT_COMPONENTS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more PROJECT_COMPONENT. Contains all instances of PROJECT_COMPONENT.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROJECT_CONVERSION" type="CONVERSION" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about the conversion status, dates and other facts about the conversion in ownership rights for a real estate development project and contains CONVERSION elements.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROJECT_DETAIL" type="PROJECT_DETAIL" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information regarding the name, design, status, classification and other facts about the project.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROJECT_DEVELOPER" type="PROJECT_DEVELOPER" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about the management and transfer of the housing project by a developer.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROJECT_FINANCIAL_INFORMATION" type="PROJECT_FINANCIAL_INFORMATION" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about the financial management details of a housing and project and its units.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROJECT_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROJECT_AMENITIES">
		<xsd:annotation>
			<xsd:documentation>Contains information about one or more PROJECT_AMENITY. Contains all instances of PROJECT_AMENITY.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PROJECT_AMENITY" type="PROJECT_AMENITY" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more amenities located in the project.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROJECT_AMENITIES_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROJECT_AMENITY">
		<xsd:annotation>
			<xsd:documentation>Contains information about one or more amenities located in the project.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AmenityOwnershipType" type="AmenityOwnershipEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the unit's ownership of the amenity (e.g. is the amenity assigned to the unit or is it unassigned and is first-come first-served).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AmenityOwnershipTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Amenity Ownership Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AmenityType" type="AmenityEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents a particular service, feature or facility available to residents and/or guests of a project or property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AmenityTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field used to describe the amenity if Other is selected as the Amenity Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROJECT_AMENITY_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROJECT_ANALYSIS">
		<xsd:annotation>
			<xsd:documentation>Information about the marketability and analysis of a housing project.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ProjectAnalysisGroundRentAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Identifies the annual ground rent amount for the project.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProjectAnalysisGroundRentDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field describing the ground rent.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProjectAnalysisGroundRentExpirationDate" type="MISMODate" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The date when the project ground rent expires as per the lease.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProjectAnalysisGroundRentIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Indicates that the project is subject to ground rents.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProjectConditionAndQualityDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field used to describe the condition of the project.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProjectDeficiencyObservedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that one or more deficiencies have been observed in the project.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROJECT_ANALYSIS_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROJECT_BLANKET_FINANCING">
		<xsd:annotation>
			<xsd:documentation>Information about how the housing project was financed as a whole.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AmortizationType" type="AmortizationEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A classification or description of a loan or a group of loans generally based on the changeability of the rate or payment over time.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AmortizationTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field used to collect additional information or a description of the amortization type when Other is selected.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BalloonIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that a final balloon payment is required to fully pay off the loan.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CurrentInterestRatePercent" type="MISMOPercent" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The current interest rate, expressed as a percent, for this loan.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="InterestRateAvailableIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the interest rate is available from the blanket financing documents.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LienPriorityType" type="LienPriorityEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that specifies the priority of the lien against the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LineOfCreditDrawnAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The current amount that has been drawn from a line of credit.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LineOfCreditDrawnProRataShareAttributableToUnitAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The proportionate amount of the project's drawn line of credit obligated to the subject unit(s).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LineOfCreditIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the lien is a line of credit.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LineOfCreditMaximumAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The maximum amount that can be extended as a line of credit.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LineOfCreditMaximumProRataShareAttributableToUnitAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The proportionate amount of the project's maximum line of credit obligated to the subject unit(s).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LoanRemainingMaturityTermMonthsCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The number of months remaining until the loan matures.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PaymentAmountAvailableIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the payment amount is available from the blanket financing documents.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PaymentFrequencyType" type="PaymentFrequencyEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that specifies how often the obligor must make the financing payments.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TotalPaymentAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total payment amount that is reported.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UPBAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The current unpaid principal balance on the loan.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UPBProRataShareAttributableToUnitAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The proportionate amount of the project's unpaid blanket mortgage financing obligated to the subject unit(s).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROJECT_BLANKET_FINANCING_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROJECT_BLANKET_FINANCINGS">
		<xsd:annotation>
			<xsd:documentation>Information about one or more PROJECT_BLANKET_FINANCING. Holds all occurrences of PROJECT_BLANKET_FINANCING.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PROJECT_BLANKET_FINANCING" type="PROJECT_BLANKET_FINANCING" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>Information about how the housing project was financed as a whole.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROJECT_BLANKET_FINANCINGS_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROJECT_COMPONENT">
		<xsd:annotation>
			<xsd:documentation>Contains information about the completeness of one or more component present in a project (e.g. amenities, units, common areas).</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ProjectComponentCategoryType" type="ProjectComponentCategoryEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents classification of a project component associated with the project.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProjectComponentCategoryTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Project Component Category Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProjectComponentCompletedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that construction of the identified project component category is complete. When false, indicates that construction of the identified project component category is incomplete.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROJECT_COMPONENT_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROJECT_COMPONENTS">
		<xsd:annotation>
			<xsd:documentation>Contains information about one or more PROJECT_COMPONENT. Contains all instances of PROJECT_COMPONENT.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PROJECT_COMPONENT" type="PROJECT_COMPONENT" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>Contains information about the completeness of one or more component present in a project (e.g. amenities, units, common areas).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROJECT_COMPONENTS_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROJECT_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Information regarding the name, design, status, classification and other facts about the project.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="LegalActionIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that research on the project revealed pending or current legal actions.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProjectCommercialSpaceIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Indicates that the project contains commercial space.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProjectCommercialSpacePercent" type="MISMOPercent" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The overall percentage of commercial space in the project in which the subject property is located.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProjectCompletedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that construction of the units, common elements and amenities in the project are complete and not subject to additional phasing.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProjectDwellingUnitCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Total number of individual dwelling units in the project.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProjectDwellingUnitsForSaleCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total number of units in a project that are currently for sale.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProjectDwellingUnitsRentedCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Total number of individual dwelling units in the project that are currently rented.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProjectDwellingUnitsRentedEstimateDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field describing why the number of units rented in the project is an estimate.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProjectDwellingUnitsRentedEstimateIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the number of units rented in the project is an estimate.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProjectDwellingUnitsSoldCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total number of units in a project that have been sold.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProjectLegalStructureType" type="ProjectLegalStructureEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that specifies the form of ownership of a project. The Project Legal Structure Type defines the quality and quantity of project ownership and rights accruing to the individual unit owner.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProjectName" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An unstructured name that identifies the project in which property is located (e.g., the name of the condominium or cooperative).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SubjectBuildingCompletedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the project building containing the subject property is complete.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROJECT_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROJECT_DEVELOPER">
		<xsd:annotation>
			<xsd:documentation>Information about the management and transfer of the housing project by a developer.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ProjectDeveloperOrSponsorControlsProjectManagementIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the developer or the sponsor is in control of the management of the project (e.g. Home Owner's Association).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROJECT_DEVELOPER_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROJECT_FINANCIAL_INFORMATION">
		<xsd:annotation>
			<xsd:documentation>Information about the financial management details of a housing and project and its units.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ProjectBlanketFinancingIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the cooperative has mortgage financing that encompasses the entire project.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProjectTotalSharesIssuedAndOutstandingCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The number of shares owned by the cooperative corporation and its investors.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SingleEntityGreatestNumberOfSharesCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The greatest number of shares owned by a single entity in the cooperative project.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SingleEntityGreatestNumberOfUnitsCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The greatest number of units owned by a single entity in the condominium project.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROJECT_FINANCIAL_INFORMATION_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTIES">
		<xsd:annotation>
			<xsd:documentation>Information about one or more types of property. Holds all occurrences of PROPERTY.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PROPERTY" type="PROPERTY" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>Information specific to a real estate in terms of land structure, location and market.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTIES_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY">
		<xsd:annotation>
			<xsd:documentation>Information specific to a real estate in terms of land structure, location and market.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ADDITIONAL_ADDRESSES" type="ADDITIONAL_ADDRESSES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more additional addresses associated with the property. Holds all occurrences of ADDITIONAL_ADDRESS.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ADDRESS" type="ADDRESS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Address is based upon USPS publication 28. Publication 28 has two sections, format of an address on a piece of mail and data points that MAY compose an address. The data point children of ADDRESS are the union components of an address on a piece of mail or a package.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CAR_STORAGES" type="CAR_STORAGES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more types of car storage. Holds all occurrences of CAR_STORAGE.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="COMPARABLE" type="COMPARABLE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information regarding the research, adjustments, summary conclusions and other facts about selections used in the sales comparison approach to value and in the context of grid style reporting.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DISASTER_MITIGATION_FEATURES" type="DISASTER_MITIGATION_FEATURES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more DISASTER_MITIGATION_FEATURE. Contains all instances of DISASTER_MITIGATION_FEATURE.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ENCUMBRANCES" type="ENCUMBRANCES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more types of encumbrance. Holds all occurrences of ENCUMBRANCE.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ENERGY_EFFICIENCY_AND_GREEN" type="ENERGY_EFFICIENCY_AND_GREEN" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains information about the property's energy efficiency and green features, certifications, ratings and/or equipment.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ENVIRONMENTAL_CONDITIONS" type="ENVIRONMENTAL_CONDITIONS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information regarding one or more types of property environmental considerations. Holds all occurrences of ENVIRONMENTAL CONSIDERATION.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FUNCTIONAL_ISSUES" type="FUNCTIONAL_ISSUES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more FUNCTIONAL_ISSUE. Holds all occurrences of FUNCTIONAL_ISSUE.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="HOMEOWNERS_ASSOCIATIONS" type="HOMEOWNERS_ASSOCIATIONS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more homeowners associations. Holds all occurrences of HOMEOWNERS ASSOCIATION.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="IMPROVEMENTS" type="IMPROVEMENTS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more improvements on the property. Contains all occurrences of IMPROVEMENT.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="INSPECTIONS" type="INSPECTIONS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more types of inspection of the property. Holds all occurrences of INSPECTION.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LISTING_INFORMATION_SUMMARY" type="LISTING_INFORMATION_SUMMARY" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains aggregate listing information for a specific real property instance.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LISTING_INFORMATIONS" type="LISTING_INFORMATIONS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more types of listing information. Holds all occurrences of LISTING_INFORMATION.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LOCATION_IDENTIFIER" type="LOCATION_IDENTIFIER" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information regarding location identifiers, which provide unique identification of specific locations.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MARKET" type="MARKET" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about the inventories, trends and other facts about the market area of the property. A market is described in terms of its supply and demand characteristics for property in a given geographic location and economic condition.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NEIGHBORHOOD" type="NEIGHBORHOOD" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information regarding the housing, schools, influences, land use and other facts about a neighborhood. A neighborhood is a geographically localized community within a larger city, town or suburb.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PARCEL_SUMMARY" type="PARCEL_SUMMARY" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains summary level information about all parcels of land.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PARCELS" type="PARCELS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more parcel of land. Holds all occurrences of PARCEL.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROJECT" type="PROJECT" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A residential development area that could be comprised of any combination of multifamily and single family structures and may include mixed land use such as commercial. A project refers to an organized development in which shared common areas, road ways and management structures exist. Project management and individual homeowner associations may also co-exist within the project.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROPERTY_AMENITY" type="PROPERTY_AMENITY" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more amenities located on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROPERTY_DEFECT" type="PROPERTY_DEFECT" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more defect, damage and/or deficiency that has been observed on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROPERTY_DETAIL" type="PROPERTY_DETAIL" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about the subject property or other owned property that includes construction information, restrictions, property usage and other details about the real property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROPERTY_GROUND_RENT" type="PROPERTY_GROUND_RENT" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about ground rent associated with the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROPERTY_NOT_USED" type="PROPERTY_NOT_USED" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains information about data pertaining to properties analyzed but ultimately not used as part of the Sales Comparison Approach.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROPERTY_TAXES" type="PROPERTY_TAXES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more PROPERTY_TAX. Holds all occurrences of PROPERTY_TAX.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROPERTY_USE_SUMMARY" type="PROPERTY_USE_SUMMARY" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Aggregate information about how a property is being used.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROPERTY_USES" type="PROPERTY_USES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more PROPERTY_USE. Holds all occurrences of PROPERTY_USE.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROPERTY_VALUATIONS" type="PROPERTY_VALUATIONS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more types of property valuation. Holds all occurrences of PROPERTY_VALUATION.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="REAL_PROPERTY_INTERESTS" type="REAL_PROPERTY_INTERESTS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains the details of the collateral valuation assignment sufficient for the provider to judge the amount of research and data necessary for the assignment.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RENTAL_INFORMATION_SUMMARY" type="RENTAL_INFORMATION_SUMMARY" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains aggregate information about the rental information for one or more property unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SALES_CONTRACTS" type="SALES_CONTRACTS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more SALES_CONTRACT. Holds all occurrences of SALES_CONTRACT.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SALES_HISTORIES" type="SALES_HISTORIES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more SALES_HISTORY. Holds all occurrences of SALES_HISTORY.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SITE" type="SITE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information that describes features or aspects of the site.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attribute name="ValuationUseType" type="ValuationUseBase">
			<xsd:annotation>
				<xsd:documentation>Used as an attribute on PROPERTY to specify whether the referenced property is the Subject property or a property valuation comparable.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_ACCESS">
		<xsd:annotation>
			<xsd:documentation>Contains information about the methods used to access the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ACCESS_STREETS" type="ACCESS_STREETS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains information about any streets leading to the property. Contains all instances of ACCESS_STREET.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROPERTY_ACCESS_DETAIL" type="PROPERTY_ACCESS_DETAIL" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains detailed information about the methods used to access the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_ACCESS_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_ACCESS_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Contains detailed information about the methods used to access the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PrivateStreetMaintenanceAgreementExistIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that there is a maintenance agreement for a private street used to access the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyAccessDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field describing access to the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyAccessTypicalToMarketIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the property access is common for the identified market.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyPrimaryEntryExitMethodType" type="PropertyPrimaryEntryExitMethodEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the primary ingress and/or egress method for the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyPrimaryEntryExitMethodTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Property Primary Entry Exit Method Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_ACCESS_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_AMENITY">
		<xsd:annotation>
			<xsd:documentation>Contains information about one or more amenities located on the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AMENITY_CATEGORIES" type="AMENITY_CATEGORIES">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more AMENITY_CATEGORY. Contains all instances of AMENITY_CATEGORY.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_AMENITY_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_DATA_COLLECTOR">
		<xsd:annotation>
			<xsd:documentation>Information about the party acting as property data collector.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PrimaryOccupationType" type="PrimaryOccupationEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the primary occupation of the identified party role.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PrimaryOccupationTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Primary Occupation Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_DATA_COLLECTOR_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_DEFECT">
		<xsd:annotation>
			<xsd:documentation>Contains information about one or more defect, damage and/or deficiency that has been observed on the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="DEFECTS" type="DEFECTS">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more DEFECT. Contains all instances of DEFECT.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROPERTY_DEFECT_SUMMARY" type="PROPERTY_DEFECT_SUMMARY" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains aggregate information about defects, damages, deficiencies and associated costs that have been observed on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_DEFECT_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_DEFECT_SUMMARY">
		<xsd:annotation>
			<xsd:documentation>Contains aggregate information about defects, damages, deficiencies and associated costs that have been observed on the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="CostToRepairType" type="CostToRepairEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents how the cost to repair amount will be provided for the defects, damages or deficiencies that have been identified for the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DefectCostToRepairTotalAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The estimated total cost of the repairs to be performed on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_DEFECT_SUMMARY_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Information about the subject property or other owned property that includes construction information, restrictions, property usage and other details about the real property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AccessoryDwellingUnitTotalCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total number of accessory dwelling units in the subject property. Possible examples may include in-law quarters, apartment over a garage, etc.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AttachmentType" type="AttachmentEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that specifies the type of physical attachment, if any, between the dwelling and adjacent dwellings.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CommunityLandTrustIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Indicates that the property is located in a community land trust.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ConstructionStatusType" type="ConstructionStatusEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents stage of construction at the time of the inspection.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CooperativeProprietaryLeaseExpirationDate" type="MISMODate" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The expiration date of the lease agreement that gives a shareholder the right to occupy a particular dwelling unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DwellingCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total number of structures on the property, excluding outbuildings, that contains a living unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FunctionalIssueDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field describing all apparent functional issues associated with the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="HomeownerResponsibleForExteriorMaintenanceIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the homeowner is responsible for maintaining the exterior of the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LivingUnitExcludingADUCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The number of separate living units in the subject property, excluding any accessory dwelling units.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MineralRightsLeasedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that mineral rights for the subject property is subject to a lease agreement.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NativeAmericanLandsIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the property is located on Native American lands.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NativeAmericanLandsType" type="NativeAmericanLandsEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that categorizes the legal means by which Native American land may be owned.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NativeAmericanLandsTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field used to collect additional information when Other is selected for Native American Lands Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NewConstructionIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that all dwellings on the property have been completed in the last 12 months, have a 100% new foundation, and have never been occupied.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OverallConditionRatingCode" type="OverallConditionRatingEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An enumerated or coded value that represents the condition rating of all dwellings on the property utilized in the development of the opinion of value.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OverallQualityRatingCode" type="OverallQualityRatingEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An enumerated or coded value that represents the quality rating of all dwellings on the property utilized in the development of the opinion of value.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PriorSalesOrTransfersIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the property has a prior sale or transfer history included within the reporting period.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyAmenityExistsIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the property has one or more amenities available.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyCooperativeSharesCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The number of cooperative shares attributed to the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyEstateType" type="PropertyEstateEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that specifies the ownership interest in the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyEstateTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field used to collect additional information when Other is selected for Property Estate Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyInProjectIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the property is located in a project per trading partner guidelines.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProRataSharePercent" type="MISMOPercent" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A portion of 100 that represents the blanket mortgage payments that are attributable to the subject property, as determined by dividing the number of shares attributable to the subject property by the total number of project shares.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PUDIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the property is located within a Planned Unit Development (PUD). A PUD is a project or subdivision that consists of common property and / or improvements that are owned and maintained by an owners’ association for the benefit and use of the individual unit owners.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SubjectPropertyAmenitiesDefectsExistIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that at least one of the amenities associated with the property has defect(s), damage(s) or deficienc(ies).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TotalFinishedAreaOfAllLivingUnitsIncludingADUAreaMeasure" type="MISMOAreaMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the total finished area from all accessory dwelling units, finished area of all living units, and finished area from any common area located within the dwelling(s). The applicable unit of measurement is specified by the Area Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TotalOfAllDwellingsVolumeMeasure" type="MISMOVolumeMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the total volume, including finished and unfinished areas, of all dwellings on the property, including ADUs. The applicable unit of measurement is specified by the Volume Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TotalWindowSurfaceAreaOfAllDwellingsAreaMeasure" type="MISMOAreaMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the total window surface area for all windows of all dwellings on the property. The applicable unit of measurement is specified by the Area Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="VehicleStorageDefectsExistIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that at least one of the vehicle storages associated with the property has defect(s), damage(s) or deficienc(ies).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_GROUND_RENT">
		<xsd:annotation>
			<xsd:documentation>Information about ground rent associated with the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PropertyGroundLeaseAnnualAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The annual amount of dollars agreed to be paid for the ground rent.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyGroundLeaseExpirationDate" type="MISMODate" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The final expiration date of the ground lease.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyGroundLeaseRenewableIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the ground lease is renewable.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyGroundLeaseTermYearsCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total number of years the terms of the ground lease is in effect.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyGroundRentDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field describing the ground rent and/or its impact on the value and marketability of the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_GROUND_RENT_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_NOT_USED">
		<xsd:annotation>
			<xsd:documentation>Contains information about data pertaining to properties analyzed but ultimately not used as part of the Sales Comparison Approach.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PROPERTY_NOT_USED_DETAIL" type="PROPERTY_NOT_USED_DETAIL">
				<xsd:annotation>
					<xsd:documentation>Detailed information about properties analyzed but ultimately not used in the Sales Comparison Approach.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROPERTY_NOT_USED_REASONS" type="PROPERTY_NOT_USED_REASONS">
				<xsd:annotation>
					<xsd:documentation>Contains one or more reasons that the property was considered but ultimately not used in the Sales Comparison Approach. Contains all instances of PROPERTY_NOT_USED_REASON.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_NOT_USED_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_NOT_USED_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Detailed information about properties analyzed but ultimately not used in the Sales Comparison Approach.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AdditionalPropertyAnalyzedNotUsedText" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field commenting on the reason the appraiser did not include the property in the Sales Comparison Approach.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ConsiderationRequestedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the client requested the appraiser to consider the additional property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_NOT_USED_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_NOT_USED_REASON">
		<xsd:annotation>
			<xsd:documentation>Contains the unique reason that the property was considered but ultimately not used in the Sales Comparison Approach.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ReasonPropertyNotUsedType" type="ReasonPropertyNotUsedEnum" nillable="true" minOccurs="0">

			<xsd:documentation>Information about the known tax exemptions for the property. A common example is Homestead property tax exemption.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="TaxAbatementsOrExemptionsAnnualAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The annual amount granted in tax reductions or exemptions.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TaxAbatementsOrExemptionsExpirationDate" type="MISMODate" nillable="true" minOccurs="0">

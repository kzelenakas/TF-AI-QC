	<xsd:complexType name="HOMEOWNERS_ASSOCIATIONS">
		<xsd:annotation>
			<xsd:documentation>Information about one or more homeowners associations. Holds all occurrences of HOMEOWNERS ASSOCIATION.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="HOMEOWNERS_ASSOCIATION" type="HOMEOWNERS_ASSOCIATION">
				<xsd:annotation>
					<xsd:documentation>Information regarding the non-governmental body that develops policy and oversees compliance with covenants, restrictions and declarations for a subdivision or condominium development.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="HOMEOWNERS_ASSOCIATIONS_EXTENSION" minOccurs="0"/>
		</xsd:sequence>

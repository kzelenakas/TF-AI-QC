				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SanitarySewer">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Water">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ValuationAdditionalCertificationIncludedByBase">
		<xsd:annotation>
			<xsd:documentation>Term: Valuation Additional Certification Included By Type Definition: A value from a MISMO prescribed list that represents the party that has included the additional certification in the report.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Appraiser">
				<xsd:annotation>
					<xsd:documentation>A party who performs valuation services in compliance with USPAP and in a manner that is independent, impartial and objective.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="AppraiserSupervisor">
				<xsd:annotation>
					<xsd:documentation>A party who, in compliance with USPAP, performs supervision of the appraisal process and signs as an additional responsible party.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ValuationAnalysisCategoryBase">
		<xsd:annotation>
			<xsd:documentation>Term: Valuation Analysis Category Type Definition: A value from a MISMO prescribed list that represents the categorization of the valuation analysis.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Assignment">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about the appraisal assignment.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ComparableRental">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about the comparable rental property used in the analysis for determining the monthly market rent for the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ComparablesPriorSalesAndTransferHistory">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about all prior sales and transfers of the comparable properties within the identified lookback period.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DisasterMitigation">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about any disaster mitigation feature that is associated to the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="EnergyEfficientAndGreenFeatures">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about the property's energy efficient and green features, certifications and/or ratings.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="HazardZones">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about any hazard zones in which the property is located.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="HighestAndBestUse">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about the highest and best use analysis of the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="IncompleteProject">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about any elements of the project that are not yet completed.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Market">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about the inventories, trends and other facts about the market area of the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OverallQualityAndCondition">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the analysis of the overall quality and condition for the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Project">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about the project in which the subject property is located.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ProjectCommercialSpace">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about any commercial space within the project.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ProjectConversion">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about the project, which was converted from its original use to its current form of ownership.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ProjectDeveloperOrSponsorControlsProjectManagement">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or supporting details about the project management being controlled by the developer or the sponsor.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ProjectFactors">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about any miscellaneous project factors associated to the subject property (e.g. legal actions, commercial spaces, incomplete project elements).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ProjectLegalAction">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about any legal action associated with the project.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ProjectSpecialAssessmentsAttributedToSubjectProperty">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about any project imposed special assessments.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PropertyNonResidentialUses">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about any non-residential uses observed on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PropertySpecialTaxAssessments">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about any special tax assessments associated with the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PropertyTaxAbatementsOrExemptions">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about any tax abatements or exemptions associated with the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SalesContract">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the analysis about the sales contract associated with the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SingleEntityGreatestNumberOfSharesOwned">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about the single entity that holds the largest number of the cooperative shares within a project.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SingleEntityGreatestNumberOfUnitsOwned">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about the single entity that holds the largest number of the units within a project.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Site">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about one or more characteristics associated with the site.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SiteFeatures">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about any site features associated to the subject property (e.g. hazard zones, encumbrances, zoning).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SiteInfluences">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about any site influences associated to the subject property (e.g. airports, environmental conditions).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SiteViews">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about any views from the subject property (e.g. view of the ocean, view of the woods).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Sketch">
				<xsd:annotation>
					<xsd:documentation>Commentary about the sketch and/or floor plan of the subject property improvement.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SubjectListing">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about all listings of the subject property within the identified lookback period.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SubjectPriorSalesAndTransferHistory">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about all prior sales and transfers of the subject property within the identified lookback period.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SubjectProperty">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about the location and other characteristics of the property being appraised, including address, legal description, and ownership rights.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SubjectPropertyAmenities">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about services, features and/or facilities available to the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="TransferFeeAttributedToSubjectProperty">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about the transfer fee incurred by owners when they sell their unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="VehicleStorage">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about any parking facilities that are associated to the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="WaterFrontages">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about any water frontage rights attributable to the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ZoningCompliance">
				<xsd:annotation>
					<xsd:documentation>Commentary on the impact to value and marketability and/or the details about the property zoning compliance.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>

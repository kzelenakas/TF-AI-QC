			<xsd:enumeration value="Vacant">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="UtilityBase">
		<xsd:annotation>
			<xsd:documentation>Term: Utility Type Definition: A value from a MISMO prescribed list that represents the type of utility connected.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Electricity">
				<xsd:annotation>

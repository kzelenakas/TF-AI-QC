	<xsd:simpleType name="MarketingTimeBase">
		<xsd:annotation>
			<xsd:documentation>Term: Marketing Time Type Definition: A value from a MISMO prescribed list that represents the range of time needed to sell the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="OverSixMonths">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ThreeToSixMonths">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="UnderThreeMonths">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="MarketInventoryBase">
		<xsd:annotation>
			<xsd:documentation>Term: Market Inventory Type Definition: A value from a MISMO prescribed list that represents the category of real estate market inventory as of the appraisal report effective date.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="ActiveListings">
				<xsd:annotation>
					<xsd:documentation>All properties in the market offered for sale or rent.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PendingSales">
				<xsd:annotation>
					<xsd:documentation>All properties in the market where an offer has been accepted by the seller but the transaction has yet to close.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="TotalSales">
				<xsd:annotation>
					<xsd:documentation>All properties in the market where a successful closing has taken place and title has transferred from seller to buyer.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="MarketSupplyTrendBase">
		<xsd:annotation>
			<xsd:documentation>Term: Market Supply Trend Type Definition: A value from a MISMO prescribed list that represents the housing supply in the defined market.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="InBalance">
				<xsd:annotation>
					<xsd:documentation>Indicates that housing supply and housing demand are in a state of equilibrium.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OverSupply">
				<xsd:annotation>
					<xsd:documentation>Indicates that housing supply outweighs housing demand within the identified market.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Shortage">
				<xsd:annotation>
					<xsd:documentation>Indicates that housing demand outweighs housing supply within the identified market.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="MeasurementStandardPublisherBase">
		<xsd:annotation>
			<xsd:documentation>Term: Measurement Standard Publisher Type Definition: A value from a MISMO prescribed list that represents the publisher of the property area measurement standard used for the appraisal.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="AmericanMeasurementStandard">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="AmericanNationalStandardsInstitute">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="MechanicalSystemBase">
		<xsd:annotation>
			<xsd:documentation>Term: Mechanical System Type Definition: A value from a MISMO prescribed list that represents the type of mechanical system.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="RadonMitigation">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SumpPump">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="WaterHeater">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="WholeHouseWaterTreatment">
				<xsd:annotation>
					<xsd:documentation>A system designed to treat, filter and/or purify the water which runs throughout the dwelling.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="MortgageBase">
		<xsd:annotation>
			<xsd:documentation>Term: Mortgage Type Definition: A value from a MISMO prescribed list that specifies the private or public sector entity under whose guidelines the mortgage is originated.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Conventional">
				<xsd:annotation>
					<xsd:documentation>Mortgage financing which is not insured or guaranteed by a government agency.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FHA">
				<xsd:annotation>
					<xsd:documentation>A loan originated in accordance with the guidelines of HUD's Federal Housing Administration, a federal agency that provides mortgage insurance on single-family, multifamily, manufactured homes and hospital loans made by FHA-approved lenders throughout the United States and its territories.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Private">
				<xsd:annotation>
					<xsd:documentation>A loan financed through a private source of funds rather than through a traditional mortgage lender (e.g., seller financing).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="USDARuralDevelopment">
				<xsd:annotation>
					<xsd:documentation>A loan originated in accordance with the guidelines of the USDA Rural Development Agency's Housing and Community Facilities Program, which provides funding for single family homes in rural communities.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="VA">
				<xsd:annotation>
					<xsd:documentation>A loan originated in accordance with the guidelines of the Department of Veterans Affairs’ Loan Guaranty Home Loan Program, which guarantees loans made by private lenders, such as banks, savings and loans, or mortgage companies to eligible veterans for the purchase of a home which must be for their own personal occupancy.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="NativeAmericanLandsBase">
		<xsd:annotation>
			<xsd:documentation>Term: Native American Lands Type Definition: A value from a MISMO prescribed list that categorizes the legal means by which Native American land may be owned.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="AlaskaNativeCorporationLand">
				<xsd:annotation>
					<xsd:documentation>This is land that is owned by an Indian tribe and was conveyed by the United States to a Native Corporation pursuant to the Alaska Native Claims Settlement Act (43 U.S.C. 1601 et seq.) or that was conveyed by the United States to a Native Corporation in exchange for such land.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="HawaiianHomeLands">
				<xsd:annotation>
					<xsd:documentation>Public land held in trust by the State of Hawaii, Department of Hawaiian Home Lands for native Hawaiians.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="TribalTrustLand">
				<xsd:annotation>
					<xsd:documentation>Land held in trust by the United States government for the benefit of the particular tribe. This type of land may not be mortgaged. The tribe executes a lease (approved by HUD/BIA) with the tribal member. The collateral for loans on these types of lands is improvements on the land and the lease. The title to the structure and leasehold estate is conveyed but not title to the land itself (it would remain in trust for the tribe).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="NonResidentialUseBase">
		<xsd:annotation>
			<xsd:documentation>Term: Non Residential Use Type Definition: A value from a MISMO prescribed list that represents the type of non-residential use observed on the property (e.g. Agricultural, Professional Office).</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Agricultural">
				<xsd:annotation>
					<xsd:documentation>A portion of the property used for farming (e.g. crops, livestock).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Commercial">
				<xsd:annotation>
					<xsd:documentation>A portion of the property intended to produce income (e.g. office buildings, retail buildings, hospitality).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Industrial">
				<xsd:annotation>
					<xsd:documentation>A portion of the property used for the production of manufactured goods.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="OutbuildingBase">
		<xsd:annotation>
			<xsd:documentation>Term: Outbuilding Type Definition: A value from a MISMO prescribed list that represents the intended functional design of an outbuilding present on the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Barn">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Boathouse">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Bunkhouse">
				<xsd:annotation>
					<xsd:documentation>A structure designed to provide temporary sleeping quarters with no other amenities.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="EnclosedKennel">
				<xsd:annotation>
					<xsd:documentation>A permanent structure designed to house domesticated animals.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Greenhouse">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GuestHouse">
				<xsd:annotation>
					<xsd:documentation>A structure designed to provide temporary living quarters which does not contain all of the elements to be considered a dwelling.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="IndoorRidingArena">
				<xsd:annotation>
					<xsd:documentation>A structure designed for indoor horse riding.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ManufacturedHome">
				<xsd:annotation>
					<xsd:documentation>A factory built dwelling built in compliance with the Federal Manufactured Home Construction and Safety Standards in effect at the time the home was manufactured as evidenced by the HUD label.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Office">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PoolHouse">
				<xsd:annotation>
					<xsd:documentation>A structure designed to enhance the poolside experience.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Shed">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Silo">
				<xsd:annotation>
					<xsd:documentation>A structure designed to store agricultural materials in bulk.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Stable">
				<xsd:annotation>
					<xsd:documentation>A structure designed to house livestock.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="StandaloneADU">
				<xsd:annotation>
					<xsd:documentation>A detached accessory dwelling unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Studio">
				<xsd:annotation>
					<xsd:documentation>A structure designed for instruction or practice of the arts (e.g. music, painting, photography).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Workshop">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="OverallBathroomsUpdateStatusBase">
		<xsd:annotation>
			<xsd:documentation>Term: Overall Bathrooms Update Status Type Definition: A value from a MISMO prescribed list that represents the degree to which all of the bathrooms have been updated.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="FullyUpdated">
				<xsd:annotation>
					<xsd:documentation>The bathroom(s) and all elements are completely modernized, renovated, refinished or remodeled and in like new condition (e.g. gut remodel, new construction).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ModeratelyUpdated">
				<xsd:annotation>
					<xsd:documentation>The bathroom(s) contain minor updates and minimum modernization with only some of the main elements appearing to have been updated.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NotUpdated">
				<xsd:annotation>
					<xsd:documentation>No modernization and no renovation, refinishing, nor remodeling to the bathroom(s); or, any updates that have been made were completed in a timeframe that renders their impact negligible.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SignificantlyUpdated">
				<xsd:annotation>
					<xsd:documentation>The majority of the bathroom(s) or the main elements, (e.g. flooring, cabinetry, fixtures) appear to have been updated. However, not all rooms nor main elements are fully updated.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="OverallConditionRatingBase">
		<xsd:annotation>
			<xsd:documentation>Term: Overall Condition Rating Code Definition: An enumerated or coded value that represents the condition rating of all dwellings on the property utilized in the development of the opinion of value.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="C1">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="C2">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="C3">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="C4">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="C5">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="C6">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="OverallFlooringUpdateStatusBase">
		<xsd:annotation>
			<xsd:documentation>Term: Overall Flooring Update Status Type Definition: A value from a MISMO prescribed list that represents the degree to which the flooring has been updated in the entire living unit.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="FullyUpdated">
				<xsd:annotation>
					<xsd:documentation>All flooring throughout the living unit has been completely modernized, renovated, refinished or remodeled and is new or in like new condition.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ModeratelyUpdated">
				<xsd:annotation>
					<xsd:documentation>Some flooring in the living unit has minor updates and/or minimal modernization with less than a majority of the flooring appearing to have been updated.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NotUpdated">
				<xsd:annotation>
					<xsd:documentation>No modernization and no renovation, refinishing, nor remodeling to the flooring throughout the living unit; or, any updates that have been made were completed in a timeframe that renders their impact negligible.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SignificantlyUpdated">
				<xsd:annotation>
					<xsd:documentation>A majority, but not all, of the flooring throughout the living unit appears to have been updated.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="OverallQualityRatingBase">
		<xsd:annotation>
			<xsd:documentation>Term: Overall Quality Rating Code Definition: An enumerated or coded value that represents the quality rating of all dwellings on the property utilized in the development of the opinion of value.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Q1">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Q2">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Q3">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Q4">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Q5">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Q6">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="OwnershipTransferAmountNotAvailableReasonBase">
		<xsd:annotation>
			<xsd:documentation>Term: Ownership Transfer Amount Not Available Reason Type Definition: A value from a MISMO prescribed list that represents the reason why the transfer price is not available for the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="NotDisclosed">
				<xsd:annotation>
					<xsd:documentation>Information not available to the general public.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NotRecorded">
				<xsd:annotation>
					<xsd:documentation>Information not on file in the local jurisdictional authority.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="OwnershipTransferTransactionBase">
		<xsd:annotation>
			<xsd:documentation>Term: Ownership Transfer Transaction Type Definition: The type of ownership transfer of real property as recognized in the jurisdiction in which it is located.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="DeedTransferOnly">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Sale">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ParcelDescriptionClassificationBase">
		<xsd:annotation>
			<xsd:documentation>Term: Parcel Description Classification Type Definition: A value from a MISMO prescribed list that represents the categorization of the parcel description.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="BoatSlip">
				<xsd:annotation>
					<xsd:documentation>A privately owned docking point for boats or other watercraft.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CondominiumUnit">
				<xsd:annotation>
					<xsd:documentation>Represents a living unit in a condominium project.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LandWithDwelling">
				<xsd:annotation>
					<xsd:documentation>Represents a parcel containing one or more living unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LandWithImprovement">
				<xsd:annotation>
					<xsd:documentation>Represents land with one or more structure which do not contain living units (e.g. shed, barn).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Parking">
				<xsd:annotation>
					<xsd:documentation>An area which is specifically designed for vehicle storage.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Storage">
				<xsd:annotation>
					<xsd:documentation>A room or area designed to secure personal belongings.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="VacantLand">
				<xsd:annotation>
					<xsd:documentation>Represents land containing no structures or dwellings.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ParcelIdentificationBase">
		<xsd:annotation>
			<xsd:documentation>Term: Parcel Identification Type Definition: A value from a MISMO prescribed list that specifies the method used by taxing authorities or others to identify a parcel of property.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="AlternativePropertyIdentifier">
				<xsd:annotation>
					<xsd:documentation>A proprietary, alphanumeric value used to identify parcels of real property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="AssessorUnformattedIdentifier">
				<xsd:annotation>
					<xsd:documentation>Refers to a unformatted Assessor's Parcel Number (APN), which are the numbers assigned to parcels of real property by the tax assessor of a particular jurisdiction for purposes of identification and record keeping.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ParcelSeparatorBase">
		<xsd:annotation>
			<xsd:documentation>Term: Parcel Separator Type Definition: A value from a MISMO prescribed list that represents the predominant element that separates non-contiguous parcels.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="BodyOfWater">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OtherParcel">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Road">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="PartyRoleBase">
		<xsd:annotation>
			<xsd:documentation>Term: Party Role Type Definition: A value from a MISMO defined list that identifies the role that the party plays in the transaction. Parties may be either a person or legal entity. A party may play multiple roles in a transaction.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Appraiser">
				<xsd:annotation>
					<xsd:documentation>A party who performs valuation services in compliance with USPAP and in a manner that is independent, impartial and objective.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="AppraiserSupervisor">
				<xsd:annotation>
					<xsd:documentation>A party who, in compliance with USPAP, performs supervision of the appraisal process and signs as an additional responsible party.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Attorney">
				<xsd:annotation>
					<xsd:documentation>A person admitted to practice law in at least one jurisdiction and authorized to perform criminal and civil legal functions on behalf of clients.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Borrower">
				<xsd:annotation>
					<xsd:documentation>An individual or entity that has applied for, met specific requirements of, or received a monetary loan from a lender.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Client">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Investor">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Lender">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ManagementCompany">
				<xsd:annotation>
					<xsd:documentation>An organization that acts as an independent liaison between two or more parties engaged in a service.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PropertyDataCollector">
				<xsd:annotation>
					<xsd:documentation>An individual identifying and collecting relevant property characteristics.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PropertyOwner">
				<xsd:annotation>
					<xsd:documentation>Individual or entity with legal title to a property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PropertySeller">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SignificantRealPropertyAppraisalAssistance">
				<xsd:annotation>
					<xsd:documentation>An appraiser, of any level (e.g. appraiser trainee, licensed, certified residential, certified general), providing significant assistance (as defined by USPAP) with the completion of the appraisal report.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="PaymentFrequencyBase">
		<xsd:annotation>
			<xsd:documentation>Term: Payment Frequency Type Definition: A value from a MISMO prescribed list that specifies how often the obligor must make the financing payments.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Monthly">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="PrimaryOccupationBase">
		<xsd:annotation>
			<xsd:documentation>Term: Primary Occupation Type Definition: A value from a MISMO prescribed list that represents the primary occupation of the identified party role.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Appraiser">
				<xsd:annotation>
					<xsd:documentation>A party who performs valuation services in compliance with USPAP and in a manner that is independent, impartial and objective.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="AppraiserTrainee">
				<xsd:annotation>
					<xsd:documentation>An individual who performs appraiser related tasks within the valuation process while operating under the supervision of an appropriately licensed and qualified appraiser.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="HomeInspector">
				<xsd:annotation>
					<xsd:documentation>An individual that conducts an examination of the condition of residential improvements, features and systems (e.g. electrical, plumbing, sewage disposal, HVAC systems, roof).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="InsuranceInspector">
				<xsd:annotation>
					<xsd:documentation>An individual qualified to conduct an inspection or evaluation of residential improvements for insurance related matters (e.g. storm damage).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="RealEstateAgent">
				<xsd:annotation>
					<xsd:documentation>An individual that represents a buyer or seller in the sale or a client in the lease of real estate.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ProjectComponentCategoryBase">
		<xsd:annotation>
			<xsd:documentation>Term: Project Component Category Type Definition: A value from a MISMO prescribed list that represents classification of a project component associated with the project.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Amenities">
				<xsd:annotation>
					<xsd:documentation>Represents amenities of the project which are available for use by occupants and/or owners (e.g. swimming pool, business center, fitness area).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CommonAreas">
				<xsd:annotation>
					<xsd:documentation>Represents common areas of the project which are available for use by occupants and/or owners (e.g. lobby, green space, parking).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Units">
				<xsd:annotation>
					<xsd:documentation>Represents all of the individual living units within the project.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ProjectConversionOriginalUseBase">
		<xsd:annotation>
			<xsd:documentation>Term: Project Conversion Original Use Type Definition: A value from a MISMO prescribed list that specifies the original use before the project was converted to its current form of project ownership legal structure.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Apartment">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CommercialBuilding">
				<xsd:annotation>
					<xsd:documentation>An area intended to produce income (e.g. office buildings, retail buildings, hospitality).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="HotelOrMotel">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="House">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="IndustrialBuilding">
				<xsd:annotation>
					<xsd:documentation>A building intended for the production of manufactured goods (e.g. factories).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ProjectLegalStructureBase">
		<xsd:annotation>
			<xsd:documentation>Term: Project Legal Structure Type Definition: A value from a MISMO prescribed list that specifies the form of ownership of a project. The Project Legal Structure Type defines the quality and quantity of project ownership and rights accruing to the individual unit owner.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Condominium">
				<xsd:annotation>
					<xsd:documentation>A project that is legally formed as a condominium under the Condominium-Enabling Legislation of the state in which the project is located.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Condop">
				<xsd:annotation>
					<xsd:documentation>A project that contains a mix of units that are either under cooperative ownership or condominium ownership.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Cooperative">
				<xsd:annotation>
					<xsd:documentation>A project in which a corporation or business trust holds title to the property and issues shares of stock as evidence of ownership in the corporation or business trust. The corporation or business trust grants occupancy rights to the shareholder tenants through proprietary leases.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ProjectParkingSpaceAssignmentBase">
		<xsd:annotation>
			<xsd:documentation>Term: Project Parking Space Assignment Type Definition: Specifies the type of arrangement between the project and the assigned car storage for the subject unit.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Assigned">
				<xsd:annotation>
					<xsd:documentation>Indicates parking space(s) are designated to a specific unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Owned">
				<xsd:annotation>
					<xsd:documentation>Indicates parking space(s) are deeded to a specific unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Unassigned">
				<xsd:annotation>
					<xsd:documentation>Indicates parking space(s) are designated to project occupants on a first come, first served basis.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="PropertyAsIsConditionRatingBase">
		<xsd:annotation>
			<xsd:documentation>Term: Property As Is Condition Rating Code Definition: An enumerated or coded value that represents the actual condition of all dwellings on the property as of the effective date of this appraisal, excluding all required repairs, alterations or inspections.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="C1">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="C2">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="C3">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="C4">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="C5">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="C6">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="PropertyEstateBase">
		<xsd:annotation>
			<xsd:documentation>Term: Property Estate Type Definition: A value from a MISMO prescribed list that specifies the ownership interest in the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="FeeSimple">
				<xsd:annotation>
					<xsd:documentation>The greatest possible interest a person can have in real estate, including the right to dispose of the property or pass it on to their heirs.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Leasehold">
				<xsd:annotation>
					<xsd:documentation>An estate or interest in real property held by virtue of a lease.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="PropertyExteriorInspectionMethodBase">
		<xsd:annotation>
			<xsd:documentation>Term: Property Exterior Inspection Method Type Definition: A value from a MISMO prescribed list that represents the method by which the exterior inspection was conducted.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="NoInspection">
				<xsd:annotation>
					<xsd:documentation>No exterior inspection of the property was completed.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Physical">
				<xsd:annotation>
					<xsd:documentation>An in-person, exterior inspection of the property was completed.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Virtual">
				<xsd:annotation>
					<xsd:documentation>An exterior inspection of the property was completed using an electronic device conducted via interactive or recorded (non-interactive) video.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="PropertyInteriorInspectionMethodBase">
		<xsd:annotation>
			<xsd:documentation>Term: Property Interior Inspection Method Type Definition: A value from a MISMO prescribed list that represents the method by which the interior inspection was conducted.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="NoInspection">
				<xsd:annotation>
					<xsd:documentation>No interior inspection of the property was completed.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Physical">
				<xsd:annotation>
					<xsd:documentation>An in-person, interior inspection of the property was completed.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Virtual">
				<xsd:annotation>
					<xsd:documentation>An interior inspection of the property was completed using an electronic device conducted via interactive or recorded (non-interactive) video.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="PropertyPartialInterestBase">
		<xsd:annotation>
			<xsd:documentation>Term: Property Partial Interest Type Definition: Indicates the specific type of Partial Ownership Interest on the property as evaluated in the appraisal process. May also be referred to as a fractional ownership interest.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="AirRights">
				<xsd:annotation>
					<xsd:documentation>The ownership rights to control, occupy, or use the vertical air space directly above a parcel of land. The owner of air rights can sell, lease, gift or bequeath them to others individually or entirely.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="MineralRights">
				<xsd:annotation>
					<xsd:documentation>The ownership rights to the minerals found at or below the surface of a parcel of land which gives full legal rights to mine for and profit from those minerals. The owner of mineral rights can sell, lease, gift or bequeath them to others individually or entirely.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="TimberRights">
				<xsd:annotation>
					<xsd:documentation>The ownership rights to all free-standing timber located on a parcel of land which allows the owner to sell interest in the timber separately from the land. The owner of timber rights can sell, lease, gift or bequeath them to others individually or entirely.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="WaterRights">
				<xsd:annotation>
					<xsd:documentation>The ownership rights that allow legal use of the physical supply of water sitting on, beneath or adjoining the property. The owner of water rights can sell, lease, gift or bequeath them to others individually or entirely.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="PropertyPrimaryEntryExitMethodBase">
		<xsd:annotation>
			<xsd:documentation>Term: Property Primary Entry Exit Method Type Definition: A value from a MISMO prescribed list that represents the primary ingress and/or egress method for the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PedestrianOnlyAccess">
				<xsd:annotation>
					<xsd:documentation>Indicates the property is landlocked and can only be accessed by foot (e.g. walking, hiking) and cannot be accessed by any other method. An easement is typically required to access the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PrivateAirstrip">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PrivateStreet">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PublicStreet">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Waterway">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="PropertyRentControlStatusBase">
		<xsd:annotation>
			<xsd:documentation>Term: Property Rent Control Status Type Definition: A value from a MISMO prescribed list that represents the existence or likelihood of rent control on the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="No">
				<xsd:annotation>
					<xsd:documentation>Indicates that the property is not subject to rent control.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Yes">
				<xsd:annotation>
					<xsd:documentation>Indicates that the property is subject to rent control.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="PropertyValuationConditionalConclusionBase">
		<xsd:annotation>
			<xsd:documentation>Term: Property Valuation Conditional Conclusion Type Definition: A value from a MISMO prescribed list that represents the conclusions of the appraisal that there may be a dependency on future repairs or activities.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="AsIs">
				<xsd:annotation>
					<xsd:documentation>The opinion of value is based on the property in its current state as of the appraisal report effective date.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SubjectToCompletionPerPlans">
				<xsd:annotation>
					<xsd:documentation>The opinion of value is conditional on the basis of a hypothetical condition that the improvements have been completed per plans and specifications as of the appraisal report effective date.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SubjectToInspection">
				<xsd:annotation>
					<xsd:documentation>The opinion of value is conditional based on the itemized list of required inspections being completed and the extraordinary assumption that the deficiency does not require alteration or repair.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SubjectToRepair">
				<xsd:annotation>
					<xsd:documentation>Indicates that the opinion of value is conditional based on the hypothetical condition that the repairs or alterations have been completed as of the appraisal report effective date.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="PropertyValuationMethodBase">
		<xsd:annotation>
			<xsd:documentation>Term: Property Valuation Method Type Definition: A value from a MISMO prescribed list that specifies the method by which the property value was assessed.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="DesktopAppraisal">
				<xsd:annotation>
					<xsd:documentation>An appraisal assignment for which the scope of work does not require field work by the appraiser.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ExteriorAppraisal">
				<xsd:annotation>
					<xsd:documentation>An appraisal assignment for which the scope of work includes a personal inspection of the exterior areas of the subject property from at least the street by an appraiser.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="HybridAppraisal">
				<xsd:annotation>
					<xsd:documentation>An appraisal assignment for which the scope of work includes reviewing a recent report containing prescriptive interior and exterior property data in lieu of the appraiser performing a personal inspection.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="TraditionalAppraisal">
				<xsd:annotation>
					<xsd:documentation>An appraisal assignment for which the scope of work includes an interior and exterior personal onsite inspection of the subject property completed by the appraiser who signs the appraisal report, and the effective date of the appraisal is the date of inspection.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ReasonPropertyNotUsedBase">
		<xsd:annotation>
			<xsd:documentation>Term: Reason Property Not Used Type Definition: A value from a MISMO prescribed list that represents the reason the appraiser did not include the property in the Sales Comparison Approach.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="AccessoryDwellingUnit">
				<xsd:annotation>
					<xsd:documentation>The property is less appropriate than other properties due to the presence or lack of an accessory dwelling unit (e.g. Secondary Suites, In-Law Apartments).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Age">
				<xsd:annotation>
					<xsd:documentation>The property is less appropriate than other properties due to differences in the length of time that the dwelling has existed.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Amenities">
				<xsd:annotation>
					<xsd:documentation>The property is less appropriate than other properties due to the presence or lack of certain items which are considered to benefit a property and impacts its value.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="AreaBelowGrade">
				<xsd:annotation>
					<xsd:documentation>The property is less appropriate than other properties due to differences in the area of the structure which are below ground level.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="BathroomCount">
				<xsd:annotation>
					<xsd:documentation>The property is less appropriate than other properties due to differences in the number of bathrooms.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="BedroomCount">
				<xsd:annotation>
					<xsd:documentation>The property is less appropriate than other properties due to differences in the number of bedrooms.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Condition">
				<xsd:annotation>
					<xsd:documentation>The property is less appropriate than other properties due to differences in the condition.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DatedSale">
				<xsd:annotation>
					<xsd:documentation>The property is less appropriate than other properties because the sale date is older than other more recently sold properties.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DesignOrStyleVariance">
				<xsd:annotation>
					<xsd:documentation>The property is less appropriate than other properties due to differences in design or style.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GrossBuildingArea">
				<xsd:annotation>
					<xsd:documentation>The property is less appropriate than other properties due to differences in gross building area.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GrossLivingArea">
				<xsd:annotation>
					<xsd:documentation>The property is less appropriate than other properties due to differences in gross living area.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LotSize">
				<xsd:annotation>
					<xsd:documentation>The property is less appropriate than other properties due to differences in lot size.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Outbuildings">
				<xsd:annotation>
					<xsd:documentation>The property is less appropriate than other properties due to the presence or lack of one or more outbuildings.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Proximity">
				<xsd:annotation>
					<xsd:documentation>The property is less appropriate than other properties due to equally or more relevant comparable(s) being available which are closer to the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Quality">
				<xsd:annotation>
					<xsd:documentation>The property is less appropriate than other properties due to differences in the quality.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SaleOrTransferType">
				<xsd:annotation>
					<xsd:documentation>The sale is less appropriate than other sales due to the differences in the sale or transfer type.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SiteInfluence">
				<xsd:annotation>

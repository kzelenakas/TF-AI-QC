				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CeramicTile">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="EngineeredWood">
				<xsd:annotation>
					<xsd:documentation>A wood product made by binding or fixing strands or fibers of natural wood together with adhesives (e.g. particle board, plywood, T-1 11).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FinishedConcrete">

			<xsd:enumeration value="Shower">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Sink">
				<xsd:annotation>
					<xsd:documentation/>

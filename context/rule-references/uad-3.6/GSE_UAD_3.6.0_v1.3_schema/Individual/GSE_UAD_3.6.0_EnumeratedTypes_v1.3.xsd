	<xsd:simpleType name="ReplacementOrReproductionCostAreaBase">
		<xsd:annotation>
			<xsd:documentation>Term: Replacement Or Reproduction Cost Area Type Definition: A value from a MISMO prescribed list that represents the area, associated with this improvement, whose costs to reproduce or replace are being estimated.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="AttachedGarage">
				<xsd:annotation>
					<xsd:documentation>An enclosed vehicle storage structure adjoining a dwelling.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="BuiltInGarage">
				<xsd:annotation>
					<xsd:documentation>An enclosed vehicle storage structure built into the footprint of a dwelling, under the same roofline and offering interior access to the dwelling.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Carport">
				<xsd:annotation>
					<xsd:documentation>A covered structure which offers limited protection from the elements generally with two or fewer walls, which is not closed off from the weather. It may be free standing or attached to a structure.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FinishedArea">
				<xsd:annotation>
					<xsd:documentation>Refers to any area of the structure improved to livable standards.</xsd:documentation>
				</xsd:annotation>

	<xsd:simpleType name="FrontDoorApproximateElevationRangeBase">
		<xsd:annotation>
			<xsd:documentation>Term: Front Door Approximate Elevation Range Type Definition: A value from a MISMO prescribed list that represents the approximate elevation range from grade to the bottom of the front entrance door.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="EightToNineFeet">
				<xsd:annotation>
					<xsd:documentation>Greater than or equal to eight feet but less than nine feet above grade.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FiveToSixFeet">
				<xsd:annotation>
					<xsd:documentation>Greater than or equal to five feet but less than six feet above grade.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FourToFiveFeet">
				<xsd:annotation>
					<xsd:documentation>Greater than or equal to four feet but less than five feet above grade.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GroundLevel">
				<xsd:annotation>
					<xsd:documentation>At grade level.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NineToTenFeet">
				<xsd:annotation>
					<xsd:documentation>Greater than or equal to nine feet but less than ten feet above grade.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OneToTwoFeet">
				<xsd:annotation>
					<xsd:documentation>Greater than or equal to one foot but less than two feet above grade.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SevenToEightFeet">
				<xsd:annotation>
					<xsd:documentation>Greater than or equal to seven feet but less than eight feet above grade.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SixToSevenFeet">
				<xsd:annotation>
					<xsd:documentation>Greater than or equal to six feet but less than seven feet above grade.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="TenOrMoreFeet">
				<xsd:annotation>
					<xsd:documentation>Ten or more feet above grade.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ThreeToFourFeet">
				<xsd:annotation>
					<xsd:documentation>Greater than or equal to three feet but less than four feet above grade.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="TwoToThreeFeet">
				<xsd:annotation>
					<xsd:documentation>Greater than or equal to two feet but less than three feet above grade.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="UpToOneFoot">
				<xsd:annotation>
					<xsd:documentation>Less than twelve inches above grade.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="FunctionalIssueBase">
		<xsd:annotation>
			<xsd:documentation>Term: Functional Issue Type Definition: A value from a MISMO prescribed list that represents an apparent functional issue observed.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="CeilingHeight">
				<xsd:annotation>
					<xsd:documentation>Represents that the ceiling heights do not meet the typical market standards and/or impacts the livability of the dwelling.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FloorPlan">
				<xsd:annotation>
					<xsd:documentation>Represents that the floor plan does not meet the typical market standards for and/or impacts to the livability of the dwelling.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NonConformity">
				<xsd:annotation>
					<xsd:documentation>Represents that the dwelling significantly differs from other properties in the surrounding area (e.g. age, style, size, use).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="None">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Overimprovement">
				<xsd:annotation>
					<xsd:documentation>Represents that one or more of the improvements is not fully valued by the market due to exceeding typical expectations in comparison to other properties in the market area (e.g. 5000 sq. ft. home in a 2000 sq. ft. home neighborhood).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Underimprovement">
				<xsd:annotation>
					<xsd:documentation>Represents that one or more of the improvements do not meet minimum expectations in comparison to other properties in the market area (e.g. one bedroom home in a three bedroom home neighborhood).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="GovernmentAgencyAppraisalBase">
		<xsd:annotation>
			<xsd:documentation>Term: Government Agency Appraisal Type Definition: A value from a MISMO prescribed list that represents the federal agency for which the appraisal has been prepared.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="FHA">
				<xsd:annotation>
					<xsd:documentation>An appraisal conducted in accordance with the guidelines of HUD's Federal Housing Administration, a federal agency that provides mortgage insurance for loans made by FHA-approved lenders.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="USDA">
				<xsd:annotation>
					<xsd:documentation>An appraisal conducted in accordance with the guidelines of the United States Department of Agriculture, which provides funding for mortgages in rural communities.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="VA">
				<xsd:annotation>
					<xsd:documentation>An appraisal conducted in accordance with the guidelines of the Department of Veterans Affairs, which guarantees loans made by private lenders to eligible veterans.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="GradeLevelBase">
		<xsd:annotation>
			<xsd:documentation>Term: Grade Level Type Definition: A value from a MISMO prescribed list that represents the unit's or level's grade as it relates to ground level.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="AboveGrade">
				<xsd:annotation>
					<xsd:documentation>At or above ground level with the walls having minimal or no earth contact.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FullyBelowGrade">
				<xsd:annotation>
					<xsd:documentation>Below ground level with each wall having earth contact and not having the potential for ingress or egress at ground level without the use of stairs.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PartiallyBelowGrade">
				<xsd:annotation>
					<xsd:documentation>Partly below ground level with two or more walls having earth contact, but at least one wall has existing or potential ingress or egress at ground level (e.g. walk out basement).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="HazardZoneBase">
		<xsd:annotation>
			<xsd:documentation>Term: Hazard Zone Type Definition: A value from a MISMO prescribed list that represents the geographic area, as specified by a government entity, documenting a potential risk to the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="FEMASpecialFloodHazardArea">
				<xsd:annotation>
					<xsd:documentation>Areas identified on the FEMA Flood Map as a special hazard area.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="None">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="USGSLavaFlowZone">
				<xsd:annotation>
					<xsd:documentation>Areas identified on the United States Geological Survey Lava Flow Zone Map as a special hazard area.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="HeatingFuelBase">
		<xsd:annotation>
			<xsd:documentation>Term: Heating Fuel Type Definition: Indicates the type of fuel used by the heating system.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Coal">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Electric">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Geothermal">
				<xsd:annotation>
					<xsd:documentation>Energy generated and stored in the Earth.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NaturalGas">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Oil">
				<xsd:annotation>
					<xsd:documentation>A liquid product derived from petroleum (e.g. kerosene, # 2 heating oil).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Propane">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Solar">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Wood">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="HeatingSystemBase">
		<xsd:annotation>
			<xsd:documentation>Term: Heating System Type Definition: A value from a MISMO prescribed list that specifies the type of heating.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Baseboard">
				<xsd:annotation>
					<xsd:documentation>A system of perimeter heating located at the base of the wall.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Fireplace">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ForcedWarmAir">
				<xsd:annotation>
					<xsd:documentation>A system that propels air over a heat source that is distributed via ducts and vents throughout the structure.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GravityAir">
				<xsd:annotation>
					<xsd:documentation>A system that employs gravity to move warm air throughout the structure.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="MiniSplit">
				<xsd:annotation>
					<xsd:documentation>A ductless system designed to heat certain spaces or rooms within the structure.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="None">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PassiveSolar">
				<xsd:annotation>
					<xsd:documentation>A system which uses solar energy to heat a fluid, either liquid or air, and then transfer the solar heat directly to an interior area or to a storage system for later use.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Radiant">
				<xsd:annotation>
					<xsd:documentation>A system which supplies heat directly to the floor or to panels in the wall or ceiling of a house.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Radiators">
				<xsd:annotation>
					<xsd:documentation>A system that boils water in a central unit and moves steam to a radiator in an individual room or space.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Stove">
				<xsd:annotation>
					<xsd:documentation>A fuel burning unit that provides radiant heat.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ImageCategoryBase">
		<xsd:annotation>
			<xsd:documentation>Term: Image Category Type Definition: A value from a MISMO prescribed list that categorizes the image.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="AbsorptionRateGraph">
				<xsd:annotation>
					<xsd:documentation>An image of the graph representing the number of homes sold in a specific market during a given time frame.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="AssignmentExhibit">
				<xsd:annotation>
					<xsd:documentation>An image supporting the assignment section of the valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CompletedConstruction">
				<xsd:annotation>
					<xsd:documentation>An image of the completed elements of construction associated with the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CostApproachExhibit">
				<xsd:annotation>
					<xsd:documentation>An image supporting the cost approach section of the valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DisasterMitigationExhibit">
				<xsd:annotation>
					<xsd:documentation>An image showing or supporting the disaster mitigation feature.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DwellingExteriorExhibit">
				<xsd:annotation>
					<xsd:documentation>An image showing the exterior features of the dwelling located on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DwellingFront">
				<xsd:annotation>
					<xsd:documentation>An image featuring the front of the dwelling.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DwellingRear">
				<xsd:annotation>
					<xsd:documentation>An image featuring the rear of the dwelling.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Encroachment">
				<xsd:annotation>
					<xsd:documentation>An image of the encroachment.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="EnergyEfficientAndGreenFeaturesExhibit">
				<xsd:annotation>
					<xsd:documentation>An image showing or supporting one or more energy efficient and green features.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FloorPlan">
				<xsd:annotation>
					<xsd:documentation>An image of a floor plan of the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FunctionalObsolescenceExhibit">
				<xsd:annotation>
					<xsd:documentation>An image showing or supporting the functionally obsolete feature.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GrossRentMultiplierComparableMap">
				<xsd:annotation>
					<xsd:documentation>An image of a map of the gross rent multiplier comparable properties reflecting the market boundaries.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="HighestAndBestUseExhibit">
				<xsd:annotation>
					<xsd:documentation>An image showing or supporting the highest and best use analysis on the valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="IncomeApproachExhibit">
				<xsd:annotation>
					<xsd:documentation>An image supporting the income approach analysis on the valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LandComparableMap">
				<xsd:annotation>
					<xsd:documentation>An image of a map of the land comparable properties reflecting the market boundaries.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LegalDescription">
				<xsd:annotation>
					<xsd:documentation>An image of the legal description of one or more parcels of real property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ManufacturedHomeExhibit">
				<xsd:annotation>
					<xsd:documentation>An image showing or supporting the characteristics specific to the manufactured home.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ManufacturedHomeFinancingProgramEligibilityCertification">
				<xsd:annotation>
					<xsd:documentation>An image of the financing program certificate for which the manufactured home is designed to be eligible.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ManufacturedHomeHUDCertificationLabel">
				<xsd:annotation>
					<xsd:documentation>An image of the manufactured home HUD certification label.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ManufacturedHomeHUDDataPlate">
				<xsd:annotation>
					<xsd:documentation>An image of the manufactured home HUD data plate.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="MarketAnalysisExhibit">
				<xsd:annotation>
					<xsd:documentation>An image supporting the market analysis on the valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="MedianDaysOnMarketGraph">
				<xsd:annotation>
					<xsd:documentation>An image of the graph representing the median number of days properties are listed on the market.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NoncontinuousArea">
				<xsd:annotation>
					<xsd:documentation>An image showing the finished area attached to the dwelling that is separate and not accessible from any unit(s).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NonResidentialUse">
				<xsd:annotation>
					<xsd:documentation>An image showing or supporting one or more nonresidential uses of the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OutbuildingExhibit">
				<xsd:annotation>
					<xsd:documentation>An image showing or supporting the outbuilding located on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PercentOfDistressedSalesGraph">
				<xsd:annotation>
					<xsd:documentation>An image of the graph representing the ratio of distressed sales (e.g., foreclosure, REO, short sale) to total sales in a specific market during a given time frame.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PermanentWaterfrontFeature">
				<xsd:annotation>
					<xsd:documentation>An image showing or supporting one or more permanent waterfront features associated with the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PriceTrendGraph">
				<xsd:annotation>
					<xsd:documentation>An image of the graph using the appraiser’s lookback period in the identified market representing the trend of either listing prices or sale prices, or a combination of both.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PriorSaleAndTransferHistoryExhibit">
				<xsd:annotation>
					<xsd:documentation>An image supporting the prior sale and transfer history analysis on the valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ProjectAmenity">
				<xsd:annotation>
					<xsd:documentation>An image of one or more amenities associated with the project.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ProjectDeficiency">
				<xsd:annotation>
					<xsd:documentation>An image supporting one or more defects, damaged areas or deficiencies identified in the project.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ProjectExhibit">
				<xsd:annotation>
					<xsd:documentation>An image supporting the project information section of the valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PropertyAccess">
				<xsd:annotation>
					<xsd:documentation>An image showing the primary means of accessing the property site.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PropertyBoundaries">
				<xsd:annotation>
					<xsd:documentation>An image showing the boundaries of the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PropertyPhoto">
				<xsd:annotation>
					<xsd:documentation>An image depicting the entire property being referenced.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ReconciliationExhibit">
				<xsd:annotation>
					<xsd:documentation>An image supporting the reconciliation of approaches to value and final opinion of market value on the valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="RentalComparableMap">
				<xsd:annotation>
					<xsd:documentation>An image of a map of the rental comparable properties reflecting the market boundaries.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="RentalInformationExhibit">
				<xsd:annotation>
					<xsd:documentation>An image supporting the rent schedule, and/or comparable rental analysis on the valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SalesComparableMap">
				<xsd:annotation>
					<xsd:documentation>An image of a map reflecting the market boundaries of the subject and sales comparable properties.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SalesComparisonApproachExhibit">
				<xsd:annotation>
					<xsd:documentation>An image supporting the sales comparison approach on the valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SalesContractExhibit">
				<xsd:annotation>
					<xsd:documentation>An image supporting the sales contract analysis on the valuation report. </xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SiteCharacteristic">
				<xsd:annotation>
					<xsd:documentation>An image of a site characteristic (e.g., topography, drainage). </xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SiteExhibit">
				<xsd:annotation>
					<xsd:documentation>An image showing or supporting the features of the site where subject property is located.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SiteInfluence">
				<xsd:annotation>
					<xsd:documentation>An image of a site influence (e.g., busy road, industrial area).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SubjectListingExhibit">
				<xsd:annotation>
					<xsd:documentation>An image showing or supporting the listings associated with the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SubjectPropertyAmenitiesExhibit">
				<xsd:annotation>
					<xsd:documentation>An image showing or supporting one or more amenities associated with the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SubjectPropertyExhibit">
				<xsd:annotation>
					<xsd:documentation>An image showing or supporting the identification (e.g., address, legal description) and/or features of the property being appraised.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SubjectPropertyImprovementSketch">
				<xsd:annotation>
					<xsd:documentation>An image of a footprint sketch of the subject property improvement.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SupplementalExhibit">
				<xsd:annotation>
					<xsd:documentation>An image included in the appraisal that did not relate to any specific section of the valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="UnitInteriorExhibit">
				<xsd:annotation>
					<xsd:documentation>An image showing one or more interior features of a living unit. </xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ValuationCompletionExhibit">
				<xsd:annotation>
					<xsd:documentation>An image supporting the Valuation Completion report.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ValuationUpdateExhibit">
				<xsd:annotation>
					<xsd:documentation>An image supporting the Appraisal Update report.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="VehicleStorageExhibit">
				<xsd:annotation>
					<xsd:documentation>An image showing or supporting one or more types of vehicle storage associated with the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="View">
				<xsd:annotation>
					<xsd:documentation>An image of the view from the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="WaterFrontage">

				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="StandardFinishedAreaAboveGrade">
				<xsd:annotation>
					<xsd:documentation>Refers to any above grade area of the structure that has been finished and is considered as living area (commonly referred to as GLA or finished square footage), per the applicable standard and/or policy.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="StandardFinishedAreaBelowGrade">
				<xsd:annotation>
					<xsd:documentation>Refers to any below grade area of the structure that has been finished and is considered as living area, per the applicable standard and/or policy.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>

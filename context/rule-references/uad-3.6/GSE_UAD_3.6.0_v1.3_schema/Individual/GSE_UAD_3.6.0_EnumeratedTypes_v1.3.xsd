			</xsd:enumeration>
			<xsd:enumeration value="NonStandardFinishedAreaBelowGrade">
				<xsd:annotation>
					<xsd:documentation>Refers to any below grade area of the structure that has been finished but cannot be considered as living area, per the applicable standard and/or policy.</xsd:documentation>

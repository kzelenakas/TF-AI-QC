	<xsd:simpleType name="LavaFlowZoneBase">
		<xsd:annotation>
			<xsd:documentation>Term: Lava Flow Zone Code Definition: An enumerated or coded value defined by the United States Geological Survey used to identify the most dangerous lava flow zone that the property is located in.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Zone1">
				<xsd:annotation>
					<xsd:documentation>An area designated by the United States Geological Survey for the Island of Hawai'i - Includes summits and rift zones of Kilauea and Mauna Loa volcanoes, where vents have been repeatedly active in historical time.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Zone2">
				<xsd:annotation>
					<xsd:documentation>An area designated by the United States Geological Survey for the Island of Hawai'i - Areas adjacent to and downslope of zone 1. 15-25% of zone 2 has been covered by lava since 1800, and 25-75% has been covered within the past 750 years. Relative hazard within zone 2 decreases gradually as one moves away from Zone 1.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Zone3">
				<xsd:annotation>
					<xsd:documentation>An area designated by the United States Geological Survey for the Island of Hawai'i - Areas less hazardous than zone 2 because of greater distance from recently active vents and/or because of topography. 1-5% of zone 3 has been covered since 1800, and 15-75% has been covered within the past 750 years.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Zone4">
				<xsd:annotation>
					<xsd:documentation>An area designated by the United States Geological Survey for the Island of Hawai'i - Includes all of Hualalai, where the frequency of eruptions is lower than that for Kilauea or Mauna Loa. Lava coverage is proportionally smaller, about 5% since 1800, and less than 15% within the past 750 years.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Zone5">
				<xsd:annotation>
					<xsd:documentation>An area designated by the United States Geological Survey for the Island of Hawai'i - Area on Kilauea currently protected by topography.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Zone6">
				<xsd:annotation>
					<xsd:documentation>An area designated by the United States Geological Survey for the Island of Hawai'i - Two areas on Mauna Loa, both protected by geography.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Zone7">
				<xsd:annotation>
					<xsd:documentation>An area designated by the United States Geological Survey for the Island of Hawai'i - Younger part of Mauna Kea volcano - 20% of this area was covered by lava in the past 10,000 years.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Zone8">
				<xsd:annotation>
					<xsd:documentation>An area designated by the United States Geological Survey for the Island of Hawai'i - covers the remaining part of Mauna Kea, only a few percent of this area has been covered by lava in the past 10,000 years.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Zone9">
				<xsd:annotation>
					<xsd:documentation>An area designated by the United States Geological Survey for the Island of Hawai'i - Kohala Volcano, which last erupted over 60,000 years ago.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>

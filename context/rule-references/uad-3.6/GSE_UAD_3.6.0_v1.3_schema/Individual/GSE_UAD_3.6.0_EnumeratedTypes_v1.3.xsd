					<xsd:documentation>A body of water located on or coming from a site that is not the subject site nor directly abuts the subject site.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Onsite">
				<xsd:annotation>
					<xsd:documentation>A body of water located on or coming directly from the subject site.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="CarStorageAttachmentBase">
		<xsd:annotation>
			<xsd:documentation>Term: Car Storage Attachment Type Definition: A value from a MISMO prescribed list that specifies how the vehicle storage is connected to a dwelling.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Attached">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="BuiltIn">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Detached">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="CarStorageBase">
		<xsd:annotation>
			<xsd:documentation>Term: Car Storage Type Definition: A value from a MISMO prescribed list that specifies the type of vehicle storage.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Carport">
				<xsd:annotation>
					<xsd:documentation>A covered structure which offers limited vehicular protection with two or fewer walls. It may be free standing or attached to a structure and is available for use only by the property owner (i.e. single family, 2-4 unit).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CommonCarport">
				<xsd:annotation>
					<xsd:documentation>A covered structure which offers limited vehicular protection with two or fewer walls. It may be free standing or attached to a structure and is available for use by all residents of the project or PUD.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Driveway">
				<xsd:annotation>
					<xsd:documentation>An improved surface providing vehicular access and off-street parking.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Garage">
				<xsd:annotation>
					<xsd:documentation>An enclosed structure for storing vehicles that is available for use only by the property owner (i.e. single family, 2-4 unit).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="None">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OpenLot">
				<xsd:annotation>
					<xsd:documentation>An open and improved surface area which is specifically designed for vehicle storage.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ParkingGarage">
				<xsd:annotation>
					<xsd:documentation>An enclosed area for storing vehicles that is intended to support multiple units and is available for use by all residents of the project or PUD.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SharedDriveway">
				<xsd:annotation>
					<xsd:documentation>An improved surface providing vehicular access and off-street parking, jointly owned by the owners of the properties that it gives access to.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="CarStoragesComparisonBase">
		<xsd:annotation>
			<xsd:documentation>Term: Car Storages Comparison Type Definition: A value from a MISMO prescribed list which represents the overall rating of the differences between the comparable and the subject for all types of vehicle storage included in the rental agreement.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Inferior">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Similar">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Superior">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="CeilingStyleBase">
		<xsd:annotation>
			<xsd:documentation>Term: Ceiling Style Type Definition: A value from a MISMO prescribed list that represents the style of the ceiling.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Barrel">
				<xsd:annotation>
					<xsd:documentation>A ceiling that is semicircular in cross section and resembles a segment of a barrel.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Beams">
				<xsd:annotation>
					<xsd:documentation>A ceiling that features exposed joists and/or beams.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Cathedral">
				<xsd:annotation>
					<xsd:documentation>A ceiling that features two equally sloping sides that meet in the middle and often conforms to the shape of the roof.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Coffered">
				<xsd:annotation>
					<xsd:documentation>A ceiling that features a series of rectangular, square or octagonal grids with sunken or recessed panels.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Drop">
				<xsd:annotation>
					<xsd:documentation>A secondary ceiling hung below the main ceiling or joists.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Flat">
				<xsd:annotation>
					<xsd:documentation>A ceiling with no pitch or change in height.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Tray">
				<xsd:annotation>
					<xsd:documentation>An inverted or recessed ceiling that features a center section that is several inches higher than the rest of the ceiling.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Vaulted">
				<xsd:annotation>
					<xsd:documentation>A ceiling that features higher than typical open areas with sloping sides that does not conform to the shape of the roof.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ComparableAdjustmentBase">
		<xsd:annotation>
			<xsd:documentation>Term: Comparable Adjustment Type Definition: A value from a MISMO prescribed list that specifies the type of adjustment made for comparison purposes within the Sales Comparison Approach.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="AccessoryDwellingUnitLocation">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the type of building in which the accessory dwelling unit is located (e.g., dwelling, outbuilding).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ApparentEnvironmentalCondition">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the apparent environmental conditions.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="AttachedOrDetached">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to attachment type.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ConstructionMethod">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the method of construction.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ContractDate">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the contract date.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CoolingSystem">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the cooling system(s).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CornerUnit">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the property being a corner unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DisasterMitigationFeatures">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the disaster mitigation features.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DwellingStyle">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the style of the dwelling.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Easement">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the easement(s).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="EnergyEfficientAndGreenFeatures">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the energy efficient and green feature(s) present on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FinancingMethod">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the financing or payment method.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FunctionalIssues">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the functional obsolescence.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GrossBuildingFinishedArea">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the gross building finished area.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GrossRentMultiplierAdditionalNonAdjustableComparisonItem">
				<xsd:annotation>
					<xsd:documentation>An additional appraiser defined item which cannot be used to adjust the value for a market-derived difference between the subject property and the gross rent multiplier comparable.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="HazardZone">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the hazard zone(s).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="HeatingSystem">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the heating system(s).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LandOwnedInCommon">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the land owned in common.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LivingUnitBathroomCount">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the number of full bathrooms and half bathrooms in the living unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LivingUnitBedroomCount">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the bedroom count in the living unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LivingUnitFeaturesForIndividualsWithDisabilities">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the features for individuals with disabilities.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LivingUnitFloorNumber">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the floor on which the unit is located.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LivingUnitLevelCount">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the number of levels in the living unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LivingUnitNonStandardFinishedAreaAboveGrade">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the above grade area that has been finished but cannot be considered as living area, per the applicable standard and/or policy.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LivingUnitNonStandardFinishedAreaBelowGrade">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the below grade area that has been finished but cannot be considered as living area, per the applicable standard and/or policy.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LivingUnitStandardFinishedAreaAboveGrade">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the above grade area that has been finished and is considered as living area, per the applicable standard and/or policy. This is commonly referred to as GLA or finished square footage.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LivingUnitStandardFinishedAreaBelowGrade">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the below grade area that has been finished and is considered as living area, per the applicable standard and/or policy.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LivingUnitUnfinishedAreaAboveGrade">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the unfinished area above grade in the living unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LivingUnitUnfinishedAreaBelowGrade">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the unfinished area below grade in the living unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ManufacturedHomeWidth">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the width of the manufactured home.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="MiscellaneousAmenity">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to any miscellaneous amenities (e.g. club membership, shared laundry facilities and appraiser defined additional amenities).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NativeAmericanLands">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the property being located on Native American Lands.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NeighborhoodName">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the name of the neighborhood in which the property resides.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NonContinuousFinishedArea">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to any non-continuous finished area located on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Outbuilding">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the type of outbuilding on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OutdoorAccessoryAmenity">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to any outdoor accessory amenities (e.g. fence, irrigation system, outdoor fireplace, sports court).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OutdoorLivingAmenity">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to any outdoor living amenities (e.g. patio, deck, porch).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OverallConditionRating">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the overall condition rating of the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OverallQualityRating">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the overall quality rating of the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OwnershipRightsConveyed">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the ownership rights conveyed (e.g. mineral rights, timber rights).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ProjectInformation">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the overall project characteristics (e.g. monthly fees, common amenities and services).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PropertyOwnershipTransferTerms">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the property ownership transfer terms.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PropertyPrimaryAccess">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the primary ingress and/or egress method for the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PropertyRestriction">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the property restriction(s).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PropertyRightsAppraised">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the property rights appraised (e.g. fee simple, leasehold).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PropertyStreetAccessAndSurface">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the property street access and street surface material.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="RowhouseTownhouseBackToBack">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the rowhouse/townhouse being back to back with another property. </xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="RowhouseTownhouseEndUnit">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the rowhouse/townhouse being an end unit. </xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="RowhouseTownhouseLocation">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the rowhouse/townhouse location when there are other properties above or below.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SaleDate">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the sale date.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SalesComparableAdditionalAdjustableComparisonItem">
				<xsd:annotation>
					<xsd:documentation>An additional appraiser defined item which can be used to adjust the value for a market-derived difference between the subject property and the sales comparable.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SalesComparableAdditionalNonAdjustableComparisonItem">
				<xsd:annotation>
					<xsd:documentation>An additional appraiser defined item which cannot be used to adjust the value for a market-derived difference between the subject property and the sales comparable.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SalesConcessions">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to any sales concessions included in the sales contract.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SaleToListPriceRatio">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the sale to list price ratio.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SiteCharacteristic">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the characteristics of the site (e.g. shape, land scaping, wetlands).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SiteDrainage">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the site drainage.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SiteInfluence">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to any influences impacting the site (e.g. busy roadway, industrial area, airport).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SiteSize">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the size of the site.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="StructureDesign">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the design of the structure (high-rise, low-rise, rowhouse/townhouse).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Topography">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the site topography.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="TotalDwellingVolume">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the volume measurement of all dwellings on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="VehicleStorage">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to any vehicle storage on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="View">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the property's view and/or the range of that view (e.g. full view of the woods, partial view of a lake).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="WaterFeaturesAmenity">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to any amenities with water features (e.g. sauna, inground pool, inground spa).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="WaterFrontage">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to any water frontage adjacent to or facing the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="WholeHomeAmenity">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to any amenities designed to supplement the standard elements within the dwelling (e.g. fire suppression, smart home system, elevator).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="WindowSurfaceArea">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to the surface area measurement of all windows across all dwellings on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="YearBuilt">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to all of the dwellings year built.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ZoningCompliance">
				<xsd:annotation>
					<xsd:documentation>Represents an element of comparison between the subject property and comparable which is directly attributable to zoning compliance of the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ComparableToSubjectDirectionBase">
		<xsd:annotation>
			<xsd:documentation>Term: Comparable To Subject Direction Type Definition: A value from a MISMO prescribed list which represents the compass direction the comparable property is located when compared to the subject property location.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="East">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="North">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NorthEast">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NorthWest">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="South">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SouthEast">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SouthWest">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="West">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ComparableWeightBase">
		<xsd:annotation>
			<xsd:documentation>Term: Comparable Weight Type Definition: A value from a MISMO prescribed list that represents the emphasis given to the comparable.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Less">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Most">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NoWeight">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ConstructionMethodBase">
		<xsd:annotation>
			<xsd:documentation>Term: Construction Method Type Definition: A value from a MISMO prescribed list that represents the manner in which the structure was constructed.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Container">
				<xsd:annotation>
					<xsd:documentation>A structure which was built by using repurposed containers as the core construction method (e.g. metal shipping container).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Manufactured">
				<xsd:annotation>
					<xsd:documentation>A factory built structure built in compliance with the Federal Manufactured Home Construction and Safety Standards in effect at the time the home was manufactured as evidenced by the HUD label. (HUD Code Home)</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Modular">
				<xsd:annotation>
					<xsd:documentation>A factory built structure, not on a permanent chassis, built to state or local guidelines and does not have a HUD label.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OnFrameModular">
				<xsd:annotation>
					<xsd:documentation>A factory built structure, on a steel permanent chassis, built to state or local guidelines and does not have a HUD label.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SiteBuilt">
				<xsd:annotation>
					<xsd:documentation>Describes construction process, indicating that most elements are created at the homes permanent site. May include some prefabricated components.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ThreeDimensionalPrintingTechnology">
				<xsd:annotation>
					<xsd:documentation>A structure that was built using three dimensional printing technologies as a core method in the fabrication process.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ConstructionStatusBase">
		<xsd:annotation>
			<xsd:documentation>Term: Construction Status Type Definition: A value from a MISMO prescribed list that represents stage of construction at the time of the inspection.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Complete">
				<xsd:annotation>
					<xsd:documentation>Construction is 100% complete.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Proposed">
				<xsd:annotation>
					<xsd:documentation>Construction has not started and the description of the work to be completed is based on plans and specifications and/or similar documentation.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="UnderConstruction">
				<xsd:annotation>
					<xsd:documentation>Construction has begun and is in progress, but is not 100% complete.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ConvertedAreaFinishComparisonBase">
		<xsd:annotation>
			<xsd:documentation>Term: Converted Area Finish Comparison Type Definition: A value from a MISMO prescribed list that represents the converted area's quality of finish compared to the rest of the living area.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Inferior">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Similar">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Superior">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ConvertedAreaOriginalUseBase">
		<xsd:annotation>
			<xsd:documentation>Term: Converted Area Original Use Type Definition: A value from a MISMO prescribed list that identifies the original purpose of an area, which has been improved from its original use to livable standards.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Garage">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Patio">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Porch">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="CoolingSystemBase">
		<xsd:annotation>
			<xsd:documentation>Term: Cooling System Type Definition: Specifies the type of cooling system.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Centralized">
				<xsd:annotation>
					<xsd:documentation>A system in which air is cooled at a central location and distributed to and from rooms by one or more fans and ductwork (e.g. forced air, mini-split).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Individual">
				<xsd:annotation>
					<xsd:documentation>A self-contained cooling system, mounted on a wall or in a window, designed to cool an individual room or small area (e.g. window unit).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="CostAnalysisBase">
		<xsd:annotation>
			<xsd:documentation>Term: Cost Analysis Type Definition: A value from a MISMO prescribed list that represents the manner in which the building would be reconstructed.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Replacement">
				<xsd:annotation>
					<xsd:documentation>The estimated cost to construct, at current prices as of the effective date of the appraisal, a building with utility equivalent to the building being appraised, using modern materials, current standards, design, and layout.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Reproduction">
				<xsd:annotation>
					<xsd:documentation>The estimated cost to construct, at current prices, as of the effective date of the appraisal, an exact duplicate or replica of the building being appraised, using the same materials, construction standards, design, layout, and quality of workmanship, and embodying all of the deficiencies, superadequacies, and obsolescence of the subject building.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="CostMethodBase">
		<xsd:annotation>
			<xsd:documentation>Term: Cost Method Type Definition: A value from a MISMO prescribed list that represents the methodology used to arrive at a replacement or reproduction building cost.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="ComparativeUnit">
				<xsd:annotation>
					<xsd:documentation>A method used to derive a cost estimate in terms of dollars per unit of area, or volume, based on known cost of similar structures that are adjusted for time, and physical differences. The cost estimate is then applied to the total building area. Also known as Square Foot Method or Market Extraction Method.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="QuantitySurvey">
				<xsd:annotation>
					<xsd:documentation>A cost-estimating method used to derive the total cost of labor and materials for each individual item used in the construction of the improvements (e.g. nails, drywall, bricks, mortar).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="UnitInPlace">
				<xsd:annotation>
					<xsd:documentation>A cost-estimating method in which total building cost is estimated by adding together the unit cost for various building components as installed. Also known as Segregated Cost Method.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="CostToRepairBase">
		<xsd:annotation>
			<xsd:documentation>Term: Cost To Repair Type Definition: A value from a MISMO prescribed list that represents how the cost to repair amount will be provided for the defects, damages or deficiencies that have been identified for the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Itemized">
				<xsd:annotation>
					<xsd:documentation>The individual cost to repair amount will be provided for each defect, damage or deficiency.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="None">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="TotalCost">
				<xsd:annotation>
					<xsd:documentation>An aggregate cost to repair amount will be provided for all defects, damages or deficiencies.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="DataNotSuppliedReasonBase">
		<xsd:annotation>
			<xsd:documentation/>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="NotCollected">
				<xsd:annotation>
					<xsd:documentation>The creator of the MISMO message does not collect the data point.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NotReceived">
				<xsd:annotation>
					<xsd:documentation>The creator of the MISMO message can collect the data point, but has not received a value as of the time the file was created.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NotRelevant">
				<xsd:annotation>
					<xsd:documentation>The creator of the MISMO message can collect the data point, but did not ask for it because it is not germane to the context at hand. (One example is “cash out purpose type” for a purchase loan.)</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Omitted">
				<xsd:annotation>
					<xsd:documentation>The creator of the MISMO message has a value for the data point. However, they have a pertinent reason (such as confidentiality) for not including it in the message.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="DataSourceBase">
		<xsd:annotation>
			<xsd:documentation>Term: Data Source Type Definition: A value from a MISMO prescribed list that identifies the sources of data.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="AssessorRecord">
				<xsd:annotation>
					<xsd:documentation>Publicly available property data provided by a local jurisdictional authority.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="BuilderOrDeveloper">
				<xsd:annotation>
					<xsd:documentation>The party who constructed the property improvements serving as collateral for the mortgage loan.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CondominiumQuestionnaire">
				<xsd:annotation>
					<xsd:documentation>A questionnaire generally created by the lender sent to the condominium board or management agent to obtain relevant project details.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CooperativeBoard">
				<xsd:annotation>
					<xsd:documentation>A collection of individuals responsible for the management and operations of the cooperative.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CooperativeQuestionnaire">
				<xsd:annotation>
					<xsd:documentation>A questionnaire generally created by the lender sent to the cooperative board or management agent to obtain relevant project details.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CostService">
				<xsd:annotation>
					<xsd:documentation>A service provider that publishes a guide for developing replacement cost, depreciated values, and insurable values of building and other improvements.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CostSurvey">
				<xsd:annotation>
					<xsd:documentation>Data prepared by the appraiser using local building sources to compile costs of all materials and labor required to estimate a per-unit cost.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DataAggregator">
				<xsd:annotation>
					<xsd:documentation>A proprietary database populated with property information obtained from reputable external sources.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Deed">
				<xsd:annotation>
					<xsd:documentation>A legal document used to identify or transfer ownership of real property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ExteriorInspection">
				<xsd:annotation>
					<xsd:documentation>An inspection limited to the exterior of the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="HomeownersAssociation">
				<xsd:annotation>
					<xsd:documentation>A legal entity that is responsible for managing residential properties bound by neighborhood covenants and restrictions, planned unit developments, cooperatives or condominium communities.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="InteriorInspection">
				<xsd:annotation>
					<xsd:documentation>An inspection of the interior of the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LandSurvey">
				<xsd:annotation>
					<xsd:documentation>A document prepared by a professional surveyor which includes details such as the legal boundaries of the parcel or plat.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Lender">
				<xsd:annotation>
					<xsd:documentation>An organization or individual, associated with the transaction, who lends money.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="MLS">
				<xsd:annotation>
					<xsd:documentation>A database established by cooperating real estate brokers to provide property characteristics and transaction information.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PhysicalMeasurement">
				<xsd:annotation>
					<xsd:documentation>An onsite measurement of the living unit completed by an individual.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PlansAndSpecifications">
				<xsd:annotation>
					<xsd:documentation>A technical and graphical representation, to scale, of a structure's construction also known as blueprints.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PlatMap">
				<xsd:annotation>
					<xsd:documentation>A document created by a licensed surveyor showing the division(s) of a tract of land.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PreviousAppraisalFile">
				<xsd:annotation>
					<xsd:documentation>Data and/or analysis from the previous appraisal file for the property prepared or made available to the appraiser.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PropertyDataReport">
				<xsd:annotation>
					<xsd:documentation>A report completed by an individual performing the property inspection, other than the appraiser, which describes the characteristics of the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PropertyManagementCompany">
				<xsd:annotation>
					<xsd:documentation>An organization that manages properties and acts as an independent liaison between two or more parties.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PropertyOwner">
				<xsd:annotation>
					<xsd:documentation>Individual or entity with legal title to real property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PropertyTenant">
				<xsd:annotation>
					<xsd:documentation>An individual or entity with legal rights to occupy the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="RealEstateAgent">
				<xsd:annotation>
					<xsd:documentation>An individual that represents a buyer or seller in the sale or a client in the lease of real estate.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ThreeDimensionalScan">
				<xsd:annotation>
					<xsd:documentation>A visual representation created from a technology solution which electronically collects measurements.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Zoning">
				<xsd:annotation>
					<xsd:documentation>Publicly available zoning data provided by a local jurisdictional authority.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="DefectComponentLabelBase">
		<xsd:annotation>
			<xsd:documentation>Term: Defect Component Label Type Definition: A value from a MISMO prescribed list that identifies a specific component on the property where the defect, damage or deficiency has been observed.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="ExteriorWallsAndTrim">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Flooring">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Foundation">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="MechanicalSystem">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Roof">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="WallsAndCeiling">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Windows">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="DefectItemLocationBase">
		<xsd:annotation>
			<xsd:documentation>Term: Defect Item Location Type Definition: A value from a MISMO prescribed list that identifies the explicit location of the defect, damage or deficiency.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="FullBathroom">
				<xsd:annotation>
					<xsd:documentation>A bathroom that contains a sink, toilet and any combination of bathtub or shower.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="HalfBathroom">
				<xsd:annotation>
					<xsd:documentation>A bathroom that contains a sink and toilet, but no bathtub or shower.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Kitchen">
				<xsd:annotation>
					<xsd:documentation>An area designed and equipped to be used for the preparation and cooking of food.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="DefectItemRecommendedActionBase">
		<xsd:annotation>
			<xsd:documentation>Term: Defect Item Recommended Action Type Definition: A value from a MISMO prescribed list that represents the recommended action for the identified defect, damage or deficiency.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Completion">
				<xsd:annotation>
					<xsd:documentation>The recommended action is that the work related to the deficiency noted for the remodel, renovation, rehabilitation and/or construction that was initiated but incomplete, at the time of the original appraisal, be completed.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Inspection">
				<xsd:annotation>
					<xsd:documentation>The recommended action is that a follow-up inspection be completed by an individual with expertise relating to the apparent defect, damage or deficiency.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="None">
				<xsd:annotation>
					<xsd:documentation>The recommendation is that no further action is needed for the apparent defect, damage or deficiency.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Repair">
				<xsd:annotation>
					<xsd:documentation>The recommended action is that the apparent defect, damage or deficiency be repaired.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="DepreciationMethodBase">
		<xsd:annotation>
			<xsd:documentation>Term: Depreciation Method Type Definition: A value from a MISMO prescribed list that represents the method used to derive depreciated building value.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Breakdown">
				<xsd:annotation>
					<xsd:documentation>A method of estimating depreciation in which the total loss in the value of the property is estimated by analyzing and measuring each cause of depreciation (physical, functional and external) separately.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="EconomicAgeLife">
				<xsd:annotation>
					<xsd:documentation>A method of estimating accrued depreciation in which the ratio between the effective age of the building and its total economic life is applied to its current cost of improvements to obtain a lump-sum deduction. Also known as Age-Life.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ModifiedEconomicAgeLife">
				<xsd:annotation>
					<xsd:documentation>A method of estimating depreciation, in which accrued curable physical and functional depreciation are deducted from the cost of improvements before Economic Age-Life ratios are applied. Total depreciation is the sum of the accumulated curable elements and the Economic Age-Life lump sum.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="DisasterMitigationFeatureBase">
		<xsd:annotation>
			<xsd:documentation>Term: Disaster Mitigation Feature Type Definition: A value from a MISMO prescribed list that represents a feature added to or a modification made to the property which is designed to prevent or reduce the impacts and risks of hazards caused by natural disasters.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="EnclosedSoffits">
				<xsd:annotation>
					<xsd:documentation>A soffit designed to prevent embers from making contact with the interior joints, rafters, or trusses.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FireResistantDecking">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FireResistantExteriorWalls">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FloodVents">
				<xsd:annotation>
					<xsd:documentation>An opening in an enclosed structure intended to allow the free passage of water between the interior and exterior.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FortifiedRoof">
				<xsd:annotation>
					<xsd:documentation>A roof designed or modified to give increased strength and protection from severe weather.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FramingAnchorageOrBracing">
				<xsd:annotation>
					<xsd:documentation>A structural system designed to resist wind and earthquake forces in which frames are secured and are designed to not sway laterally.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ImpactResistantGlass">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ImpactResistantShingles">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NoncombustiblePerimeter">
				<xsd:annotation>
					<xsd:documentation>Entire outer edge of the property boundary has been designed to mitigate or stop fire from spreading.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="None">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="StormShelter">
				<xsd:annotation>
					<xsd:documentation>A structure designed to protect the occupants from severe weather.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="StormShutters">
				<xsd:annotation>
					<xsd:documentation>Permanently attached material used to protect windows or doors that can be stored when not in use (e.g. hurricane shutters).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="WaterHeaterStrapping">
				<xsd:annotation>
					<xsd:documentation>System designed to secure the water heater in place in the event of an earthquake.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="DocumentBase">
		<xsd:annotation>
			<xsd:documentation>Term: Document Type Definition: A value from a MISMO prescribed list that represents either a category of document or a category and sublevel of a document combined into a single enumeration.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="AppraisalReport">
				<xsd:annotation>
					<xsd:documentation>A report produced by an appropriately qualified, competent and independent appraiser in accordance with USPAP and in which the scope of work includes the development of a value conclusion.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ValuationCompletion">
				<xsd:annotation>
					<xsd:documentation>Used to confirm that the conditions stated in the original appraisal have been met.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ValuationUpdate">
				<xsd:annotation>
					<xsd:documentation>Used to confirm that the subject property value has or has not declined since the effective date of the original appraisal.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="DocumentFormIssuingEntityNameBase">
		<xsd:annotation>
			<xsd:documentation>Term: Document Form Issuing Entity Name Type Definition: Identifies the organization that defined the document form/template.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="FNM_FRE">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="EasementBase">
		<xsd:annotation>
			<xsd:documentation>Term: Easement Type Definition: A value from a MISMO prescribed list that represents a nonpossessory right to cross or otherwise use a portion of another property for a specified purpose (e.g. utility, driveway).</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Conservation">
				<xsd:annotation>
					<xsd:documentation>An easement established by a legal authority that protects or preserves resources (e.g. cultural, environmental, historical).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Drainage">
				<xsd:annotation>
					<xsd:documentation>An easement that allows the movement of water away from the site.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="IngressOrEgress">
				<xsd:annotation>
					<xsd:documentation>An easement that has been established as a means to enter or exit the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Utility">
				<xsd:annotation>
					<xsd:documentation>An easement that allows utility companies access to the property for the purpose of installing, repairing and maintaining utility lines.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ElectricitySourceBase">
		<xsd:annotation>
			<xsd:documentation>Term: Electricity Source Type Definition: A value from a MISMO prescribed list that represents the delivery method of electricity to the property. Also used in conjunction with a type of utility ownership.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="BatteryStorage">
				<xsd:annotation>
					<xsd:documentation>Permanent system designed to store energy that can be operated independently from the primary source of the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PermanentGenerator">
				<xsd:annotation>
					<xsd:documentation>A backup electrical system that operates automatically in the event of a power interruption.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Solar">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Wind">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="EncroachmentBase">
		<xsd:annotation>
			<xsd:documentation>Term: Encroachment Type Definition: A value from a MISMO prescribed list that represents the type of intrusion existing on a property when a stationary object crosses a neighboring property line (e.g. fence, shed, garage, tree).</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Building">
				<xsd:annotation>
					<xsd:documentation>Occurs when a building or structure extends on to a property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Driveway">
				<xsd:annotation>
					<xsd:documentation>Occurs when a driveway extends on to a property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Fence">
				<xsd:annotation>
					<xsd:documentation>Occurs when a fence extends on to a property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Overhang">
				<xsd:annotation>
					<xsd:documentation>Occurs when an overhang extends on to a neighboring property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="EncroachmentDirectionBase">
		<xsd:annotation>
			<xsd:documentation>Term: Encroachment Direction Type Definition: A value from a MISMO prescribed list that represents the relation of the encroachment to an adjoining property.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="BorderingPropertyEncroachingOnSubjectProperty">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SubjectPropertyEncroachingOnBorderingProperty">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="EncumbranceBase">
		<xsd:annotation>
			<xsd:documentation>Term: Encumbrance Type Definition: Identifies a right to or interest in the property that may affect value. Certain restrictions require the appraiser to indicate with additional addendum text such as Deed Restrictions on Community Land Trust properties.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="ConditionsCovenantsRestrictions">
				<xsd:annotation>
					<xsd:documentation>A set of rules established that govern the use of certain properties (e.g. condominium, cooperatives).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Easement">
				<xsd:annotation>
					<xsd:documentation>A nonpossessory right to cross or otherwise use a portion of another property for a specified purpose (e.g. utility, driveway).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Encroachment">
				<xsd:annotation>
					<xsd:documentation>An intrusion existing on a property when a stationary object crosses a neighboring property line (e.g. fence, shed, garage, tree).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="EnvironmentalConditionBase">
		<xsd:annotation>
			<xsd:documentation>Term: Environmental Condition Type Definition: A type of environmental condition identified during the analysis of a lot or structure.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="HazardousAboveGroundStorageTank">
				<xsd:annotation>
					<xsd:documentation>Stationary storage tank above the surface grade with capacity of 1000 gallons or more of flammable or explosive material.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="HazardousSubstances">
				<xsd:annotation>
					<xsd:documentation>Any material which may be harmful to humans, the property, and/or the environment (e.g. batteries, pesticides, solvent based paints, motor oils).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Landfill">
				<xsd:annotation>
					<xsd:documentation>An area of land that is built up from deposits of solid refuse in layers covered by soil.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="None">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Radon">
				<xsd:annotation>
					<xsd:documentation>A heavy radioactive gaseous element formed by the decay of radium.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SlushPit">
				<xsd:annotation>
					<xsd:documentation>Earthen pit or basin excavated next to drilling rigs which are used for the collection and disposal of drilling muds and well cuttings.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SoilContamination">
				<xsd:annotation>
					<xsd:documentation>The presence of manmade chemicals or other alterations to the natural soil environment.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SuperfundSite">
				<xsd:annotation>
					<xsd:documentation>A site established by the Federal Comprehensive Environmental Response, Compensation, and Liability Act of 1980 and administered by the Environmental Protection Agency enabling them to investigate and clean up sites contaminated with hazardous substances.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="UndergroundStorageTank">
				<xsd:annotation>
					<xsd:documentation>A storage tank that is below the surface grade.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="WaterContamination">
				<xsd:annotation>
					<xsd:documentation>Water which contains any foreign substance that can be harmful to humans, the property and/or the environment (e.g. lead, arsenic, radon).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="EnvironmentalConditionProximityBase">
		<xsd:annotation>
			<xsd:documentation>Term: Environmental Condition Proximity Type Definition: A value from a MISMO prescribed list that represents proximity of the environmental condition to the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Bordering">
				<xsd:annotation>
					<xsd:documentation>An environmental condition located on or coming from a site which directly abuts the subject site.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Offsite">
				<xsd:annotation>
					<xsd:documentation>An environmental condition located on or coming from a site that is not the subject site nor directly abuts the subject site.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Onsite">
				<xsd:annotation>
					<xsd:documentation>An environmental condition located on or coming directly from the subject site.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>

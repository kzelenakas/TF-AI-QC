					<xsd:documentation>Safety devices designed to enable a person to maintain balance while walking. Typically found in stairways and hallways.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Hardware">
				<xsd:annotation>
					<xsd:documentation>Individual components installed or modified to assist individuals with accessibility (e.g. window latches, locks, door knobs, cabinet pulls).</xsd:documentation>

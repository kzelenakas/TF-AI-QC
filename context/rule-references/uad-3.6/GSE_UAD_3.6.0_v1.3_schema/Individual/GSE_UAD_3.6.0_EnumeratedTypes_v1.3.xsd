	<xsd:simpleType name="FoundationBase">
		<xsd:annotation>
			<xsd:documentation>Term: Foundation Type Definition: Describes the construction style of the foundation of the structure.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Basement">
				<xsd:annotation>
					<xsd:documentation>Partially below grade or below grade structural foundation style consisting of walls that bear weight on foundation footings running along the perimeter of the structure.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CrawlSpace">
				<xsd:annotation>
					<xsd:documentation>A foundation style consisting of unfinished, typically narrow space between the building and the ground or the improved surface.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PostAndPier">
				<xsd:annotation>
					<xsd:documentation>A foundation style that consists of a series of posts connected to a frame which supports the structure above ground level.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Runner">
				<xsd:annotation>
					<xsd:documentation>A foundation style that consists of rows of concrete footings poured into the ground intended to support the structure.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Slab">
				<xsd:annotation>
					<xsd:documentation>A foundation style that consists of a slab of concrete which sits directly on grade supporting the structure.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="FoundationMaterialBase">

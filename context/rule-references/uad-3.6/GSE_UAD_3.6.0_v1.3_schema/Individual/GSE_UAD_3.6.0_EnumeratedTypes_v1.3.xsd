	</xsd:simpleType>
	<xsd:simpleType name="AdditionalRentalIncomeBase">
		<xsd:annotation>
			<xsd:documentation>Term: Additional Rental Income Type Definition: A value from a MISMO prescribed list that represents supplemental rental income for a rental property.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="None">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Parking">
				<xsd:annotation>
					<xsd:documentation>Income derived by charging for the use of an area set aside for the storage of personal use vehicles.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Storage">
				<xsd:annotation>
					<xsd:documentation>Income derived by charging for the use of an area set aside for storage.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="AdditionalValuationIdentifierBase">
		<xsd:annotation>
			<xsd:documentation>Term: Additional Valuation Identifier Type Definition: A value from a MISMO prescribed list that represents the individual or organization which assigned the valuation identifier.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Client">
				<xsd:annotation>
					<xsd:documentation>Represents the report identifier assigned by the party acting as the client to the transaction.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GovernmentAgency">
				<xsd:annotation>
					<xsd:documentation>Represents the report identifier assigned by the government agency (e.g. VA, FHA).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ManagementCompany">
				<xsd:annotation>
					<xsd:documentation>Represents report identifier assigned by an organization that acts as an independent liaison between two or more parties.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ValuationSoftwareVendor">
				<xsd:annotation>
					<xsd:documentation>A provider of valuation software.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="AddressUnitDesignatorBase">
		<xsd:annotation>
			<xsd:documentation>Term: Address Unit Designator Type Definition: A value from a MISMO prescribed list that specifies a further level of detail for a street address, for example, Suite or Unit. This list is based on the USPS Publication 28 on Postal Addressing Standards.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Unit">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="AgencyAppraiserIdentifierBase">
		<xsd:annotation>
			<xsd:documentation>Term: Agency Appraiser Identifier Type Definition: A value from a MISMO prescribed list which represents the governmental agency for which the appraiser has been approved to conduct the appraisal.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="FHA">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="VA">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="AmenitiesComparisonBase">
		<xsd:annotation>
			<xsd:documentation>Term: Amenities Comparison Type Definition: A value from a MISMO prescribed list which represents the overall rating of the differences between the comparable and the subject for all types of amenities included in the rental agreement.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Inferior">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Similar">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Superior">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="AmenityBase">
		<xsd:annotation>
			<xsd:documentation>Term: Amenity Type Definition: A value from a MISMO prescribed list that represents a particular service, feature or facility available to residents and/or guests of a project or property.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Airstrip">
				<xsd:annotation>
					<xsd:documentation>Typically, a single runway with very basic or no aircraft support facilities which is designed for the take-off and landing of smaller personal aircraft.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Balcony">
				<xsd:annotation>
					<xsd:documentation>An elevated, often covered, platform surrounded by walls and/or railing systems projecting from the outside of the building with access from within the structure.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Beach">
				<xsd:annotation>
					<xsd:documentation>A strip of land separating a body of water from inland areas, typically used for recreation or leisure purposes.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="BoatRamp">
				<xsd:annotation>
					<xsd:documentation>A form of access point, leading to a body of water, for boats or other watercraft.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="BoatSlip">
				<xsd:annotation>
					<xsd:documentation>A docking point for boats or other watercraft.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="BuildingMaintenance">
				<xsd:annotation>
					<xsd:documentation>Upkeep and/or repair for all dwellings and structures (e.g. roof, siding, windows, doors, interior common areas).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="BuiltInPool">
				<xsd:annotation>
					<xsd:documentation>A self-contained and manufactured area built into a structure and designed to be filled with water designated for swimming and other aquatic uses.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="BusinessCenter">
				<xsd:annotation>
					<xsd:documentation>A room or location providing office facilities and services.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CaregiverServices">
				<xsd:annotation>
					<xsd:documentation>Service offered to provide support and assistance to individuals in performing tasks of personal or household care.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Clubhouse">
				<xsd:annotation>
					<xsd:documentation>A building or area used for social or recreational activities by occupants of the project.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ClubMembership">
				<xsd:annotation>
					<xsd:documentation>A membership that is defined within the deed and conveyed as part of the real estate (e.g. golf club, fitness club).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CommunityPier">
				<xsd:annotation>
					<xsd:documentation>A private pier owned or controlled by the project which gives members access to the waterfront.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ConciergeServiceCoordination">
				<xsd:annotation>
					<xsd:documentation>Assistance with organizing a variety of personal services.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Cooling">
				<xsd:annotation>
					<xsd:documentation>Indicates that cooling is provided in common and included in the mandatory fees.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Deck">
				<xsd:annotation>
					<xsd:documentation>A platform which is located next to or attached to the structure and is accessible from the dwelling.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DoorAttendant">
				<xsd:annotation>
					<xsd:documentation>An individual providing courtesy and/or security services in a residential building.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ElectricVehicleChargingStation">
				<xsd:annotation>
					<xsd:documentation>A system designed to provide on demand charging for compatible electric vehicles.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Elevator">
				<xsd:annotation>
					<xsd:documentation>A mechanized platform used for raising and lowering people or things from one level to another.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Fence">
				<xsd:annotation>
					<xsd:documentation>A structure or barrier designed to enclose an area of the site.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FireSuppressionSystem">
				<xsd:annotation>
					<xsd:documentation>A system designed to extinguish fires.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FitnessArea">
				<xsd:annotation>
					<xsd:documentation>A room, area or structure specifically designed for exercise or other physical wellness activities.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GatedCommunity">
				<xsd:annotation>
					<xsd:documentation>A community which controls access either through an automated gate or staffed security point.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Gazebo">
				<xsd:annotation>
					<xsd:documentation>A roofed structure which is typically open on all sides.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GroundsMaintenance">
				<xsd:annotation>
					<xsd:documentation>Upkeep and/or repair of all outdoor areas not associated with a structure or dwelling (e.g. lawn mowing, landscaping, fencing, gates, irrigation systems, exterior amenities).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Heating">
				<xsd:annotation>
					<xsd:documentation>Indicates that heating is provided in common and included in the mandatory fees.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="IndoorFireplace">
				<xsd:annotation>
					<xsd:documentation>A self-contained unit or framed opening located inside of a structure which is used for containing fire.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="IngroundPool">
				<xsd:annotation>
					<xsd:documentation>A self-contained and manufactured area built into the ground and designed to be filled with water, designated for swimming and other aquatic uses.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="IngroundSpa">
				<xsd:annotation>
					<xsd:documentation>A tub type structure built into the ground which typically contains hot aerated water used for recreational and wellness activities.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="IrrigationSystem">
				<xsd:annotation>
					<xsd:documentation>A water system designed to hydrate the lawn and/or other outdoor plants.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Lobby">
				<xsd:annotation>
					<xsd:documentation>A common room near the main entrance of a building.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="MultipleZoneHeatingVentilationAndAirConditioning">
				<xsd:annotation>
					<xsd:documentation>A system which allows independent control of the temperature for various areas of the dwelling.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="None">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OngoingCleaningServices">
				<xsd:annotation>
					<xsd:documentation>Cleaning services offered for the upkeep of the unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OutdoorFireplace">
				<xsd:annotation>
					<xsd:documentation>A self-contained location outside of a structure which is used to accommodate a fire.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OutdoorKitchen">
				<xsd:annotation>
					<xsd:documentation>A permanent outdoor area designed and equipped to be used for the preparation and cooking of food.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OutdoorRidingRing">
				<xsd:annotation>
					<xsd:documentation>An area open to the elements, typically surrounded with fencing, which is specifically designed for horse riding.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OutdoorShower">
				<xsd:annotation>
					<xsd:documentation>An area open to the elements designed to be used for personal cleaning through the use of flowing water and appropriate drainage.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Patio">
				<xsd:annotation>
					<xsd:documentation>A solid surface outdoor area located on the site.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Playground">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Porch">
				<xsd:annotation>
					<xsd:documentation>A covered area surrounded by walls and/or railings projecting from the structure with roof lines attached to or similar to the structure.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Portico">
				<xsd:annotation>
					<xsd:documentation>A structural element leading to the entrance of a structure with a roof supported by columns or enclosed walls.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="RecreationArea">
				<xsd:annotation>
					<xsd:documentation>A room or area designated to be used for recreation and entertainment.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="RegistrationServices">
				<xsd:annotation>
					<xsd:documentation>A service offered to short term renters to facilitate their entry into the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Sauna">
				<xsd:annotation>
					<xsd:documentation>A room that is designed to be heated to high temperatures, typically with steam.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SharedLaundryFacilities">
				<xsd:annotation>
					<xsd:documentation>An area of a structure containing washing machines and/or dryers which are designated for the cleaning and care of clothing and linens.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ShortTermRentalServices">
				<xsd:annotation>
					<xsd:documentation>Service offered to owners to market and rent their units on a short term basis.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SmartHomeSystem">
				<xsd:annotation>
					<xsd:documentation>A system which allows control of household systems through the use of a remote device.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SportsCourt">
				<xsd:annotation>
					<xsd:documentation>An area, either open or covered, specifically designed for multiple recreational and athletic activities.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="TelevisionOrInternetServices">
				<xsd:annotation>
					<xsd:documentation>Access to television and/or internet services (e.g. cable, satellite).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="TrashRemoval">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="UnitStorage">
				<xsd:annotation>
					<xsd:documentation>A room or area within a project, outside of the unit designed to secure personal belongings.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="WaterAccess">
				<xsd:annotation>
					<xsd:documentation>Access rights for project residents and their guests to waterways or bodies of water.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="WaterFrontage">
				<xsd:annotation>
					<xsd:documentation>The space or land within the project that is adjacent to or facing a body of water.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="WholeHouseVentilation">
				<xsd:annotation>
					<xsd:documentation>A system designed to provide continuous exchange of air within the dwelling (e.g. air exchanger).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="WoodStove">
				<xsd:annotation>
					<xsd:documentation>A heating mechanism fueled by wood.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="AmenityCategoryBase">
		<xsd:annotation>
			<xsd:documentation>Term: Amenity Category Type Definition: A value from a MISMO prescribed list that represents a high-level category in which the identified amenity is grouped.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Miscellaneous">
				<xsd:annotation>
					<xsd:documentation>Miscellaneous features and/or improvements that do not fall into one of the other categories (e.g. club membership).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OutdoorAccessories">
				<xsd:annotation>
					<xsd:documentation>An external improvement on the property (e.g. fence, outdoor fireplace, sports court).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OutdoorLiving">
				<xsd:annotation>
					<xsd:documentation>An external improvement on the property that is designed to enhance the outdoor experience and/or extend the living space (e.g. deck, patio).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="WaterFeatures">
				<xsd:annotation>
					<xsd:documentation>An improvement on the property that is designed to provide an aquatic experience (e.g. pool, spa).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="WholeHome">
				<xsd:annotation>
					<xsd:documentation>Features which are designed to supplement the standard elements within the dwelling (e.g. electric car charger, elevator).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>

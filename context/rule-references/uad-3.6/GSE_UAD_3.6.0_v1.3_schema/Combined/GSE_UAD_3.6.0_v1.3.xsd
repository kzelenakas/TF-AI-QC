	<xsd:simpleType name="FlooringBase">
		<xsd:annotation>
			<xsd:documentation>Term: Flooring Type Definition: A value from a MISMO prescribed list that represents the flooring material.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Carpet">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CeramicTile">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="EngineeredWood">
				<xsd:annotation>
					<xsd:documentation>A wood product made by binding or fixing strands or fibers of natural wood together with adhesives (e.g. particle board, plywood, T-1 11).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FinishedConcrete">
				<xsd:annotation>
					<xsd:documentation>Concrete that has been treated to enhance its look and livability (e.g. staining, polishing).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Hardwood">
				<xsd:annotation>
					<xsd:documentation>A solid wood material not manufactured with any adhesives and/or bonding agents.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Laminate">
				<xsd:annotation>
					<xsd:documentation>A multi-layer synthetic flooring product.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Marble">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SubflooringOnly">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Vinyl">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>

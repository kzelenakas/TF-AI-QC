			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_ACCESS">
		<xsd:annotation>
			<xsd:documentation>Contains information about the methods used to access the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ACCESS_STREETS" type="ACCESS_STREETS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains information about any streets leading to the property. Contains all instances of ACCESS_STREET.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROPERTY_ACCESS_DETAIL" type="PROPERTY_ACCESS_DETAIL" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains detailed information about the methods used to access the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_ACCESS_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_ACCESS_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Contains detailed information about the methods used to access the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PrivateStreetMaintenanceAgreementExistIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that there is a maintenance agreement for a private street used to access the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyAccessDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field describing access to the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyAccessTypicalToMarketIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the property access is common for the identified market.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyPrimaryEntryExitMethodType" type="PropertyPrimaryEntryExitMethodEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the primary ingress and/or egress method for the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyPrimaryEntryExitMethodTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Property Primary Entry Exit Method Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_ACCESS_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_AMENITY">
		<xsd:annotation>
			<xsd:documentation>Contains information about one or more amenities located on the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AMENITY_CATEGORIES" type="AMENITY_CATEGORIES">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more AMENITY_CATEGORY. Contains all instances of AMENITY_CATEGORY.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_AMENITY_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_DATA_COLLECTOR">
		<xsd:annotation>
			<xsd:documentation>Information about the party acting as property data collector.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PrimaryOccupationType" type="PrimaryOccupationEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the primary occupation of the identified party role.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PrimaryOccupationTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Primary Occupation Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_DATA_COLLECTOR_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_DEFECT">
		<xsd:annotation>
			<xsd:documentation>Contains information about one or more defect, damage and/or deficiency that has been observed on the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="DEFECTS" type="DEFECTS">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more DEFECT. Contains all instances of DEFECT.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROPERTY_DEFECT_SUMMARY" type="PROPERTY_DEFECT_SUMMARY" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains aggregate information about defects, damages, deficiencies and associated costs that have been observed on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_DEFECT_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_DEFECT_SUMMARY">
		<xsd:annotation>
			<xsd:documentation>Contains aggregate information about defects, damages, deficiencies and associated costs that have been observed on the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="CostToRepairType" type="CostToRepairEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents how the cost to repair amount will be provided for the defects, damages or deficiencies that have been identified for the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DefectCostToRepairTotalAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The estimated total cost of the repairs to be performed on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_DEFECT_SUMMARY_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Information about the subject property or other owned property that includes construction information, restrictions, property usage and other details about the real property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AccessoryDwellingUnitTotalCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total number of accessory dwelling units in the subject property. Possible examples may include in-law quarters, apartment over a garage, etc.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AttachmentType" type="AttachmentEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that specifies the type of physical attachment, if any, between the dwelling and adjacent dwellings.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CommunityLandTrustIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Indicates that the property is located in a community land trust.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ConstructionStatusType" type="ConstructionStatusEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents stage of construction at the time of the inspection.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CooperativeProprietaryLeaseExpirationDate" type="MISMODate" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The expiration date of the lease agreement that gives a shareholder the right to occupy a particular dwelling unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DwellingCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total number of structures on the property, excluding outbuildings, that contains a living unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FunctionalIssueDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field describing all apparent functional issues associated with the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="HomeownerResponsibleForExteriorMaintenanceIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the homeowner is responsible for maintaining the exterior of the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LivingUnitExcludingADUCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The number of separate living units in the subject property, excluding any accessory dwelling units.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MineralRightsLeasedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that mineral rights for the subject property is subject to a lease agreement.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NativeAmericanLandsIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the property is located on Native American lands.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NativeAmericanLandsType" type="NativeAmericanLandsEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that categorizes the legal means by which Native American land may be owned.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NativeAmericanLandsTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field used to collect additional information when Other is selected for Native American Lands Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NewConstructionIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that all dwellings on the property have been completed in the last 12 months, have a 100% new foundation, and have never been occupied.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OverallConditionRatingCode" type="OverallConditionRatingEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An enumerated or coded value that represents the condition rating of all dwellings on the property utilized in the development of the opinion of value.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OverallQualityRatingCode" type="OverallQualityRatingEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An enumerated or coded value that represents the quality rating of all dwellings on the property utilized in the development of the opinion of value.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PriorSalesOrTransfersIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the property has a prior sale or transfer history included within the reporting period.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyAmenityExistsIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the property has one or more amenities available.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyCooperativeSharesCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The number of cooperative shares attributed to the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyEstateType" type="PropertyEstateEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that specifies the ownership interest in the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyEstateTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field used to collect additional information when Other is selected for Property Estate Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyInProjectIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the property is located in a project per trading partner guidelines.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProRataSharePercent" type="MISMOPercent" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A portion of 100 that represents the blanket mortgage payments that are attributable to the subject property, as determined by dividing the number of shares attributable to the subject property by the total number of project shares.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PUDIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the property is located within a Planned Unit Development (PUD). A PUD is a project or subdivision that consists of common property and / or improvements that are owned and maintained by an owners’ association for the benefit and use of the individual unit owners.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SubjectPropertyAmenitiesDefectsExistIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that at least one of the amenities associated with the property has defect(s), damage(s) or deficienc(ies).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TotalFinishedAreaOfAllLivingUnitsIncludingADUAreaMeasure" type="MISMOAreaMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the total finished area from all accessory dwelling units, finished area of all living units, and finished area from any common area located within the dwelling(s). The applicable unit of measurement is specified by the Area Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TotalOfAllDwellingsVolumeMeasure" type="MISMOVolumeMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the total volume, including finished and unfinished areas, of all dwellings on the property, including ADUs. The applicable unit of measurement is specified by the Volume Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TotalWindowSurfaceAreaOfAllDwellingsAreaMeasure" type="MISMOAreaMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the total window surface area for all windows of all dwellings on the property. The applicable unit of measurement is specified by the Area Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="VehicleStorageDefectsExistIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that at least one of the vehicle storages associated with the property has defect(s), damage(s) or deficienc(ies).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_GROUND_RENT">
		<xsd:annotation>
			<xsd:documentation>Information about ground rent associated with the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PropertyGroundLeaseAnnualAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The annual amount of dollars agreed to be paid for the ground rent.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyGroundLeaseExpirationDate" type="MISMODate" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The final expiration date of the ground lease.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyGroundLeaseRenewableIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the ground lease is renewable.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyGroundLeaseTermYearsCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total number of years the terms of the ground lease is in effect.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyGroundRentDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field describing the ground rent and/or its impact on the value and marketability of the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_GROUND_RENT_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_NOT_USED">
		<xsd:annotation>
			<xsd:documentation>Contains information about data pertaining to properties analyzed but ultimately not used as part of the Sales Comparison Approach.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PROPERTY_NOT_USED_DETAIL" type="PROPERTY_NOT_USED_DETAIL">
				<xsd:annotation>
					<xsd:documentation>Detailed information about properties analyzed but ultimately not used in the Sales Comparison Approach.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROPERTY_NOT_USED_REASONS" type="PROPERTY_NOT_USED_REASONS">
				<xsd:annotation>
					<xsd:documentation>Contains one or more reasons that the property was considered but ultimately not used in the Sales Comparison Approach. Contains all instances of PROPERTY_NOT_USED_REASON.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_NOT_USED_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PROPERTY_NOT_USED_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Detailed information about properties analyzed but ultimately not used in the Sales Comparison Approach.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AdditionalPropertyAnalyzedNotUsedText" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field commenting on the reason the appraiser did not include the property in the Sales Comparison Approach.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ConsiderationRequestedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the client requested the appraiser to consider the additional property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PROPERTY_NOT_USED_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>

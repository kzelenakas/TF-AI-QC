					<xsd:documentation>A free-form text field describing the Improvement Component Type being referenced.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ImprovementComponentTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Improvement Component Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="WindowSurfaceAreaMeasure" type="MISMOAreaMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the combined surface area for all windows in the structure. The applicable unit of measurement is specified by the Area Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="STRUCTURE_COMPONENT_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>

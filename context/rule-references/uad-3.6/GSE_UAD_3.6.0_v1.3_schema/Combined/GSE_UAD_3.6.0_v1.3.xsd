	<xsd:complexType name="MANUFACTURED_HOME_SECTION">
		<xsd:annotation>
			<xsd:documentation>Information regarding the section type, physical dimensions and other facts about a single section making up a manufactured home.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ManufacturedHomeHUDCertificationLabelIdentifier" type="MISMOIdentifier" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An identifier made up of 3 letters followed by 6 numbers (in some cases 7 numbers). It may be found on a (red) metal label affixed to the exterior of the manufactured home. It might read something like ULI 012345. As per HUD regulations, the label identifier consists of a 3 letter designation which identifies the production inspection primary inspection agency, and which the Sectary shall assign. Each label shall be marked with a 6 digit number which the label supplier shall furnish. The labels shall be stamped with numbers sequentially.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="MANUFACTURED_HOME_SECTION_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="MANUFACTURED_HOME_SECTIONS">
		<xsd:annotation>
			<xsd:documentation>Information about one or more types of manufactured home section. Holds all occurrences of MANUFACTURED_HOME_SECTION.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="MANUFACTURED_HOME_SECTION" type="MANUFACTURED_HOME_SECTION" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>Information regarding the section type, physical dimensions and other facts about a single section making up a manufactured home.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="MANUFACTURED_HOME_SECTIONS_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="MARKET">
		<xsd:annotation>
			<xsd:documentation>Information about the inventories, trends and other facts about the market area of the property. A market is described in terms of its supply and demand characteristics for property in a given geographic location and economic condition.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="MARKET_DETAIL" type="MARKET_DETAIL">
				<xsd:annotation>
					<xsd:documentation>Contains detailed information about the inventories, trends and other facts about the market area of the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MARKET_INVENTORIES" type="MARKET_INVENTORIES">
				<xsd:annotation>
					<xsd:documentation>Information about one or more types of market inventory. Holds all occurrences of MARKET_INVENTORY.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MARKET_TREND" type="MARKET_TREND">
				<xsd:annotation>
					<xsd:documentation>Information regarding the sales activity, historic prices and other facts about the trends for a defined market area.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="MARKET_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="MARKET_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Contains detailed information about the inventories, trends and other facts about the market area of the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="MarketBoundariesDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that describes geographic boundaries of the area that is defined as the market (e.g. streets, waterways, county or state lines or other natural boundaries).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MarketInventoryLookbackMonthsCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The number of months dated back from the appraisal effective date for which market inventory results are provided.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MarketInventorySearchParameterDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field describing all of the search criteria used to identify specific properties within the market boundaries.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="MARKET_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="MARKET_INVENTORIES">
		<xsd:annotation>
			<xsd:documentation>Information about one or more types of market inventory. Holds all occurrences of MARKET_INVENTORY.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="MARKET_INVENTORY" type="MARKET_INVENTORY" minOccurs="3" maxOccurs="3">
				<xsd:annotation>
					<xsd:documentation>Information regarding the active supply of properties on the market.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="MARKET_INVENTORIES_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="MARKET_INVENTORY">
		<xsd:annotation>
			<xsd:documentation>Information regarding the active supply of properties on the market.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="MarketInventoryCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The number of properties in the real estate market inventory category.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MarketInventoryHighestPriceAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The highest dollar amount for all properties in the real estate market inventory results.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MarketInventoryLowestPriceAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The lowest dollar amount for all properties in the real estate market inventory results.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MarketInventoryMedianDaysOnMarketCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The median number of days on market for all properties listed for sale in the real estate market inventory results.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MarketInventoryMedianPriceAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The median dollar amount for all properties in the real estate market inventory results.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MarketInventoryType" type="MarketInventoryEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the category of real estate market inventory as of the appraisal report effective date.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="MARKET_INVENTORY_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>

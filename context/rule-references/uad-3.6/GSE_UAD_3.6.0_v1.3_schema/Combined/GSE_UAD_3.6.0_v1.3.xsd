	<xsd:complexType name="VALUATION_REPORT">
		<xsd:annotation>
			<xsd:documentation>An inspection and report of a property that will determine its value. The valuation report will look at the condition and location of a property to provide an estimated value.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ADDITIONAL_IDENTIFIERS" type="ADDITIONAL_IDENTIFIERS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more ADDITIONAL_IDENTIFIER. Contains all instances of ADDITIONAL_IDENTIFIER.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="APPROACH_TO_VALUE" type="APPROACH_TO_VALUE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about the three recognized methodologies for determining real property value: cost approach, sales comparison approach and income approach. The appraiser will identify which of the approaches were applicable in his opinion and applied in the assignment. The appraiser considers the scope of work, definition of value, subject property characteristics, and the quality and quantity of data available for each approach.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RECONSIDERATIONS_OF_VALUE" type="RECONSIDERATIONS_OF_VALUE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more RECONSIDERATION_OF_VALUE. Holds all occurrences of of RECONSIDERATION_OF_VALUE.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SCOPE_OF_WORK" type="SCOPE_OF_WORK">
				<xsd:annotation>
					<xsd:documentation>Contains the details pertinent to the appraisal assignment that the appraiser must accept and abide by in the fulfillment of an appraisal assignment.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="VALUATION_COMMENTARIES" type="VALUATION_COMMENTARIES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more VALUATION_COMMENTARY. Contains all instances of VALUATION_COMMENTARY.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="VALUATION_COMPLETION" type="VALUATION_COMPLETION" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about an Appraisal Completion Report.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="VALUATION_RECONCILIATION" type="VALUATION_RECONCILIATION" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information that describes the details and summary data related to the subject property that the valuation is based on.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="VALUATION_REPORT_DETAIL" type="VALUATION_REPORT_DETAIL">
				<xsd:annotation>
					<xsd:documentation>Information including the signature date, identification, and other facts about the valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="VALUATION_REVISIONS" type="VALUATION_REVISIONS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more VALUATION_REVISION. Contains all instances of VALUATION_REVISION.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="VALUATION_SOFTWARE_SYSTEMS" type="VALUATION_SOFTWARE_SYSTEMS">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more VALUATION_SOFTWARE_SYSTEM. Contains all instances of VALUATION_SOFTWARE_SYSTEM.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="VALUATION_UPDATE" type="VALUATION_UPDATE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information that describes details of the original appraisal report when there is an update and specifies if the report is a certificate of completion of improvements.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="VALUATION_REPORT_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="VALUATION_REPORT_ADDITIONAL_CERTIFICATION">
		<xsd:annotation>
			<xsd:documentation>Contains information about one or more additional certifications included in the valuation report.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ValuationAdditionalCertificationIncludedByType" type="ValuationAdditionalCertificationIncludedByEnum" nillable="true" minOccurs="0">

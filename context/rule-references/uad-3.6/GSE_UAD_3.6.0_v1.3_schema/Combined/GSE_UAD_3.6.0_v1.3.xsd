					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Parking">
				<xsd:annotation>
					<xsd:documentation>Income derived by charging for the use of an area set aside for the storage of personal use vehicles.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Storage">

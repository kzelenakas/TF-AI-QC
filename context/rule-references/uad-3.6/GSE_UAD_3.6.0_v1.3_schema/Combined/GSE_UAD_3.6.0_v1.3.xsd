	<xsd:complexType name="MISMOCount">
		<xsd:annotation>
			<xsd:documentation>A data type of Count SHOULD identify a non-negative number value that is a whole number with a maximum value of 2147483647. It SHALL NOT contain any punctuation.
EXAMPLE: A Total Bathroom Count for a dwelling unit with one full bathroom and one partial bathroom would be expressed as "2".</xsd:documentation>
		</xsd:annotation>
		<xsd:simpleContent>
			<xsd:extension base="MISMOCount_Base">

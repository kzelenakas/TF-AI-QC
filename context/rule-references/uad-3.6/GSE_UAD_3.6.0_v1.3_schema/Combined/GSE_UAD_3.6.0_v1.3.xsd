	<xsd:complexType name="SITE">
		<xsd:annotation>
			<xsd:documentation>Information that describes features or aspects of the site.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="HAZARD_ZONES" type="HAZARD_ZONES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains information about hazard zones that may exist on the site. Contains all instances of HAZARD_ZONE.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="HIGHEST_AND_BEST_USE" type="HIGHEST_AND_BEST_USE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about the highest and best use of the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PROPERTY_ACCESS" type="PROPERTY_ACCESS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains information about the methods used to access the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SITE_DETAIL" type="SITE_DETAIL" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information that describes the condition, rating, use and additional details about the site.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SITE_FEATURES" type="SITE_FEATURES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more types of features, landscaping or other information. Holds all occurrences of Site Feature.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SITE_INFLUENCES" type="SITE_INFLUENCES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more SITE_INFLUENCE. Holds all occurrences of SITE_INFLUENCE.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SITE_SIZE_LAYOUT" type="SITE_SIZE_LAYOUT" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information that describes the lot size, dimension, shape, topography and other details of the site.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SITE_UTILITIES" type="SITE_UTILITIES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more SITE_UTILITY. Holds all occurrences of SITE_UTILITY.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SITE_VIEWS" type="SITE_VIEWS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more SITE_VIEW. Holds all occurrences of SITE_VIEW.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SITE_ZONING" type="SITE_ZONING" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about the various aspects of the zoning classification, compliance and category about the property site.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="SITE_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="SITE_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Information that describes the condition, rating, use and additional details about the site.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="BroadbandInternetAvailableIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that high-speed internet access is available exclusively through a digital subscriber line, fiber-optic or cable. When false, indicates that high-speed internet access is unavailable.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LandOwnedInCommonIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates land associated with the subject property parcel is owned by an association, condominium project, or cooperative.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PublicSewerUtilityAvailableNotConnectedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that there is a public sewer system available but not connected to the subject property. When false, indicates that a public sewer system is not available.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PublicWaterUtilityAvailableNotConnectedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that there is public water available but not connected to the subject property. When false, indicates that public water is not available.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SiteDefectsExistIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the site has defect(s), damage(s) or deficienc(ies).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="SITE_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="SITE_FEATURE">
		<xsd:annotation>
			<xsd:documentation>Information regarding the type, quality, condition, description and other facts about a site feature for the property.</xsd:documentation>

					<xsd:documentation>An image supporting the cost approach section of the valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DisasterMitigationExhibit">
				<xsd:annotation>
					<xsd:documentation>An image showing or supporting the disaster mitigation feature.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DwellingExteriorExhibit">
				<xsd:annotation>
					<xsd:documentation>An image showing the exterior features of the dwelling located on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DwellingFront">
				<xsd:annotation>
					<xsd:documentation>An image featuring the front of the dwelling.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DwellingRear">
				<xsd:annotation>
					<xsd:documentation>An image featuring the rear of the dwelling.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Encroachment">

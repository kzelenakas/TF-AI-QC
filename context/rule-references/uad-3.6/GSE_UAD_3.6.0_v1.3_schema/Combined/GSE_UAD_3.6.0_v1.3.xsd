	<xsd:simpleType name="AddressUnitDesignatorBase">
		<xsd:annotation>
			<xsd:documentation>Term: Address Unit Designator Type Definition: A value from a MISMO prescribed list that specifies a further level of detail for a street address, for example, Suite or Unit. This list is based on the USPS Publication 28 on Postal Addressing Standards.</xsd:documentation>

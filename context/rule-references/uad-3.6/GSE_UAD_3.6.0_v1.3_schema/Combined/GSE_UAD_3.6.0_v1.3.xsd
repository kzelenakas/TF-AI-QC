				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RenewableEnergyComponentTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Renewable Energy Component Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="RENEWABLE_ENERGY_COMPONENT_EXTENSION" minOccurs="0"/>
		</xsd:sequence>

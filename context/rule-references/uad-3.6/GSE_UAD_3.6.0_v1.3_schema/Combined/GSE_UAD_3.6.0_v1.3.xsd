			<xsd:documentation>Contains specific information about SALES_COMPARISON_APPROACH.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="SalesComparisonCommentDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field used to describe or comment on the Sales Comparison approach in evaluating the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ValueIndicatedBySalesComparisonAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>

			<xsd:element name="BodyOfWaterDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field describing the body of water and/or its impact on the value and marketability of the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BodyOfWaterName" type="MISMOString" nillable="true" minOccurs="0">

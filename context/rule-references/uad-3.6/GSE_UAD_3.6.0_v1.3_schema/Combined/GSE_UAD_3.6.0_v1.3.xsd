	<xsd:complexType name="ROLE">
		<xsd:annotation>
			<xsd:documentation>Information about various capacities of parties involved in the transaction.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:choice minOccurs="0">
				<xsd:element name="APPRAISER" type="APPRAISER" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>A state-licensed or state-certified individual qualified to evaluate and opine on real estate matters including but not limited to an opinion of value, such as market value, quick sale value or otherwise.</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="PROPERTY_DATA_COLLECTOR" type="PROPERTY_DATA_COLLECTOR" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>Information about the party acting as property data collector.</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="SERVICE_PROVIDER" type="SERVICE_PROVIDER" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>Information about a service provider available for use in the loan transaction.</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
			</xsd:choice>
			<xsd:element name="LICENSES" type="LICENSES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more types of license. Holds all occurrences of LICENSE.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ROLE_DETAIL" type="ROLE_DETAIL" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Addition detail describing the various capacities of parties involved in the transaction.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="ROLE_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="ROLE_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Addition detail describing the various capacities of parties involved in the transaction.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PartyRoleType" type="PartyRoleEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO defined list that identifies the role that the party plays in the transaction. Parties may be either a person or legal entity. A party may play multiple roles in a transaction.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PartyRoleTypeAdditionalDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form alphanumeric string which contains a supplemental comment or remark regarding the Party Role Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PartyRoleTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field used to collect additional information when Other is selected for Party Role Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="ROLE_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="ROLES">
		<xsd:annotation>
			<xsd:documentation>Information about one or more ROLE. Holds all occurrences of ROLE.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ROLE" type="ROLE" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>Information about various capacities of parties involved in the transaction.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ManufacturedHomeAttachedToFoundationIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the manufactured home is attached to a permanent foundation.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeHitchWheelsAxlesRemovedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the towing hitch, wheels and axles have been removed from the frame of the manufactured home creating a more permanent structure.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeHUDCertificateLabelIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the HUD Certification Label is present for each section of the manufactured home.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeHUDDataPlateAttachedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Indicates that the manufactured home has a HUD data plate attached.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeInstalledDate" type="MISMOYear" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Reports the date a Certificate of Occupancy or its equivalent was issued for the development of a lot and placement of a manufactured home on a permanent foundation.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeInstalledDateEstimatedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the calendar year in which the manufactured home was installed is an estimate.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeInvoiceNotReasonableDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field describing why the invoice is not reasonable.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeInvoiceReasonableIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that based on the analysis of the manufacturer's invoice and/or retailer's invoice, the content appears to be reasonable.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeInvoiceReviewedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Indicates that the appraiser reviewed and analyzed the invoice of the manufacturer for the manufactured home.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeManufactureDate" type="MISMODate" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The date the manufactured home was built as noted on the HUD data plate.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeManufacturerName" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The name of the manufacturer (maker) of the Manufactured home.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeModificationIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that modifications, attachments or additions have been made that rely on or have altered the original structure for support.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeModificationsDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field describing any and all modifications, attachments and additions that rely on or have altered the original structure for support.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeMovedAfterOriginalInstallationIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the manufactured home has been moved to a different location than the one on which it was originally installed.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomePurchasedFromRetailerIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the manufactured home was purchased from a retailer.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeRetailerInvoiceReviewedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the appraiser reviewed and analyzed the retailer's invoice.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeRetailerName" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An unstructured name that identifies the retail seller of the manufactured home.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeSerialNumberIdentifier" type="MISMOIdentifier" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The serial number of the manufactured home identifies the manufacturer and the state in which the manufactured home is manufactured. This may be also be called a VIN (Vehicle Identification Number).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeValuationCommentText" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form alphanumeric string which contains commentary for the manufactured home appraisal.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeWidthType" type="ManufacturedHomeWidthEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Specifies the common size (width) designation of a Manufactured home.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RoofLoadZoneCode" type="RoofLoadZoneEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An enumeration or a coded value identifying the Roof Load Zone that the manufactured home was designed and constructed to conform to.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SkirtingExistsIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that a non-structural enclosure of a foundation crawl space exists.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ThermalZoneCode" type="ThermalZoneEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An enumeration or a coded value identifying the Thermal Zone that the manufactured home was designed and constructed to conform to.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="WindZoneCode" type="WindZoneEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An enumeration or a coded value identifying the Wind Zone that the manufactured home was designed and constructed to conform to.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="MANUFACTURED_HOME_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="MANUFACTURED_HOME_FINANCING_PROGRAM">
		<xsd:annotation>
			<xsd:documentation>Contains information about one or more affordable housing programs for which a manufactured home is eligible.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ManufacturedHomeFinancingProgramEligibilityIdentifier" type="MISMOIdentifier" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A unique alphanumeric string identifying this manufactured home's eligibility for the associated financing program.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeFinancingProgramEligibilityType" type="ManufacturedHomeFinancingProgramEligibilityEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the financing program for which the manufactured home is designed to be eligible.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeFinancingProgramEligibilityTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Manufactured Home Financing Program Eligibility Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="MANUFACTURED_HOME_FINANCING_PROGRAM_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">

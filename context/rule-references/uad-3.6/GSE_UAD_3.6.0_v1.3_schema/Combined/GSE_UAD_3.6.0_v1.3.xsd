			<xsd:documentation>Term: Appraiser Designation Type Definition: The designation type held by the appraiser awarded by a recognized appraisal trade organization.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="AccreditedAgriculturalConsultant">
				<xsd:annotation>
					<xsd:documentation>AAC- American Society of Farm Managers and Rural Appraisers URI urn:www:org:asfmra:AAC URL http://www.asfmra.org</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="AccreditedFarmManager">
				<xsd:annotation>
					<xsd:documentation>AFM - American Society of Farm Managers and Rural Appraisers URI urn:www:org:asfmra:AFM URL http://www.asfmra.org</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="AccreditedMember">
				<xsd:annotation>
					<xsd:documentation>AM - American Society of Appraisers URI urn:www:org:appraisers:AM URL http://www.appraisers.org</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="AccreditedRuralAppraiser">
				<xsd:annotation>
					<xsd:documentation>ARA- American Society of Farm Managers and Rural Appraisers URI urn:www:org:asfmra:ARA URL http://www.asfmra.org</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>

		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="MANUFACTURED_HOME_MODIFICATION" type="MANUFACTURED_HOME_MODIFICATION" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>Information about one or more modifications made after the initial installation of a manufactured home.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="MANUFACTURED_HOME_MODIFICATIONS_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>

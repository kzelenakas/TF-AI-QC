					<xsd:documentation>The actual identifier value of the type specified by Parcel Identifier Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ParcelIdentifierOwnerName" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An unstructured name that identifies the owner of the algorithm used to create the parcel identifier.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PARCEL_IDENTIFICATION_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">

			<xsd:documentation>Contains information about one or more REPLACEMENT_REPRODUCTION_COST. Contains all instances of REPLACEMENT_REPRODUCTION_COST.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="REPLACEMENT_REPRODUCTION_COST" type="REPLACEMENT_REPRODUCTION_COST" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>Information about the replacement or reproduction costs for the various areas of an improvement.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="REPLACEMENT_REPRODUCTION_COSTS_EXTENSION" minOccurs="0"/>

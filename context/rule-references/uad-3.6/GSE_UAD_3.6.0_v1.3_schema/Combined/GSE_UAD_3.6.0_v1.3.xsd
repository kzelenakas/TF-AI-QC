				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="MarketAnalysisExhibit">
				<xsd:annotation>
					<xsd:documentation>An image supporting the market analysis on the valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="MedianDaysOnMarketGraph">
				<xsd:annotation>
					<xsd:documentation>An image of the graph representing the median number of days properties are listed on the market.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NoncontinuousArea">
				<xsd:annotation>
					<xsd:documentation>An image showing the finished area attached to the dwelling that is separate and not accessible from any unit(s).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NonResidentialUse">
				<xsd:annotation>
					<xsd:documentation>An image showing or supporting one or more nonresidential uses of the property.</xsd:documentation>
				</xsd:annotation>

			<xsd:documentation>Contains summary level information about all parcels of land.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="NON_CONTIGUOUS_PARCEL_SEPARATORS" type="NON_CONTIGUOUS_PARCEL_SEPARATORS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more elements separating parcels of land. Holds all occurrences of NON_CONTIGUOUS_PARCEL_SEPARATOR.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PARCEL_SUMMARY_DETAIL" type="PARCEL_SUMMARY_DETAIL" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains additional information about the parcel summary.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PARCEL_SUMMARY_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="PARCEL_SUMMARY_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Contains additional information about the parcel summary.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ParcelsLegalDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An unparsed legal description for one or more parcels of real property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="PARCEL_SUMMARY_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">

			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="VALUATION_RECONCILIATION_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Information describes conditions and methods used to arrive at the final property valuation.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AdditionalClientRequestedConditionsCommentDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field describing the client requested conditions of the assignment.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AdditionalClientRequestedConditionsIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that one or more additional client requested value conditions are present in the appraisal report.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FHA_REOInsurabilityLevelCode" type="MISMOCode" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An enumerated or coded value identifying the level of insurability, or Statement of Insurability for FHA REO properties. It identifies the property compliance with FHA’s property acceptability criteria.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ValuationReconciliationSummaryCommentDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field used to describe or reconcile the different property valuation methods used to arrive at the final property valuation.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="VALUATION_RECONCILIATION_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>

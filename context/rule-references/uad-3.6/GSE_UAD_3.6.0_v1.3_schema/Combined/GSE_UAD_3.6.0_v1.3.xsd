	<xsd:complexType name="VALUATION_REPORT_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Information including the signature date, identification, and other facts about the valuation report.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AppraiserAdditionalCertificationIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that one or more additional certifications have been identified by the appraiser.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AppraiserFileIdentifier" type="MISMOIdentifier" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>This is an identifier or number used by the appraiser to identify their reports. It is generally specific to the appraiser.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AppraiserPriorServicesPerformedDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form alphanumeric string which contains commentary about any prior services for the subject property that was performed by the appraiser.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AppraiserPriorServicesPerformedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates the appraiser has performed a prior service for the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AppraiserSupervisorAdditionalCertificationIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that one or more additional certifications have been identified by the appraiser supervisor.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="InvestorRequestedIdentificationCode" type="MISMOCode" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An enumerated or coded value representing any special identification provided with the appraisal (e.g. special pilot program, disaster, pandemic).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MeasurementStandardPublisherType" type="MeasurementStandardPublisherEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the publisher of the property area measurement standard used for the appraisal.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MeasurementStandardPublisherTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Measurement Standard Publisher Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OriginalAppraisalEffectiveDate" type="MISMODate" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The effective date of the original appraisal report.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OriginalAppraisalMarketingOrExposureDaysCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total number of days the property would have been offered on the market prior to the hypothetical sale at market value as of the original appraisal report effective date.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OriginalAppraisalMarketingOrExposureHighRangeDaysCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The highest number of days the property would have been offered on the market prior to the hypothetical sale at market value as of the original appraisal report effective date.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OriginalAppraisalMarketingOrExposureLowRangeDaysCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The lowest number of days the property would have been offered on the market prior to the hypothetical sale at market value as of the original appraisal report effective date.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OriginalAppraisedValueAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The amount of the reconciled opinion of value from the original appraisal report.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OriginalAppraiserFileIdentifier" type="MISMOIdentifier" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A unique alphanumeric string identifying the original appraiser's file.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OriginalAppraiserUnparsedName" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>

			<xsd:documentation>Term: Foundation Material Type Definition: A value from a MISMO prescribed list that specifies the type of material used in the foundation.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Brick">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ConcreteBlock">
				<xsd:annotation>
					<xsd:documentation/>

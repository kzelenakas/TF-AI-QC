	<xsd:complexType name="COST_APPROACH_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Information about the type of estimated costs and other facts about the replacement or reproduction analysis.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="CostAnalysisCommentDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field used to further describe the application of the Cost Approach valuation method to the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CostAnalysisType" type="CostAnalysisEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the manner in which the building would be reconstructed.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CostMethodType" type="CostMethodEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the methodology used to arrive at a replacement or reproduction building cost.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CostMethodTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Cost Method Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepreciatedCostDwellingsTotalAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total amount of depreciated cost for all dwellings on the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepreciatedCostOutbuildingsTotalAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total amount of depreciated cost for all outbuildings on the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepreciationMethodType" type="DepreciationMethodEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the method used to derive depreciated building value.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DepreciationMethodTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Depreciation Method Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SiteEstimatedValueAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The dollar value estimated for the property site (e.g., land that is improved so that it is ready to be used for a specific purpose).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SiteEstimatedValueCommentDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field used to further describe the estimated value provided in Site Estimated Value Amount.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SiteOtherImprovementsAsIsAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The dollar value contributed by other &quot;as is&quot; improvements located on the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SiteValuationMethodType" type="SiteValuationMethodEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the method by which the site value is calculated.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SiteValuationMethodTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Site Valuation Method Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ValueIndicatedByCostApproachAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The indicated value of the subject property as determined by the Cost Approach method of property valuation.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="COST_APPROACH_DETAIL_EXTENSION" minOccurs="0"/>

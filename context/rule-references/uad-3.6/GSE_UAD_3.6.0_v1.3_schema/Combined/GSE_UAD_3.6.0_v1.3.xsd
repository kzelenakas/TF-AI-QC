					<xsd:documentation>A free-form text field describing the analysis that led to the remaining economic life conclusion.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EstimatedRemainingEconomicLifeYearsCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The estimated number of years of the structure's remaining useful life.</xsd:documentation>
				</xsd:annotation>

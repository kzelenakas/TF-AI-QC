	<xsd:complexType name="PARCEL_IDENTIFICATIONS">
		<xsd:annotation>
			<xsd:documentation>Information about one or more types of parcel identification. Holds all occurrences of PARCEL_IDENTIFICATION.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PARCEL_IDENTIFICATION" type="PARCEL_IDENTIFICATION" maxOccurs="unbounded">

	<xsd:complexType name="RENTAL_COMPARISON">
		<xsd:annotation>
			<xsd:documentation>Information about the comparable property that was used in the comparable rental analysis for determining the monthly market rent of the subject property. Details such as the comparable’s weight, comparable’s adjusted rent are captured.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ADDITIONAL_RENTAL_COMPARISON_ITEMS" type="ADDITIONAL_RENTAL_COMPARISON_ITEMS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains information about one or more ADDITIONAL_RENTAL_COMPARISON_ITEM. Holds all occurrences of ADDITIONAL_RENTAL_COMPARISON_ITEM.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RENTAL_COMPARISON_DETAIL" type="RENTAL_COMPARISON_DETAIL" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Contains specific information pertaining to RENTAL_COMPARISON.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="RENTAL_COMPARISON_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="RENTAL_COMPARISON_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Contains specific information pertaining to RENTAL_COMPARISON.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AmenitiesComparisonType" type="AmenitiesComparisonEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list which represents the overall rating of the differences between the comparable and the subject for all types of amenities included in the rental agreement.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CarStoragesComparisonType" type="CarStoragesComparisonEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list which represents the overall rating of the differences between the comparable and the subject for all types of vehicle storage included in the rental agreement.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ComparableWeightType" type="ComparableWeightEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the emphasis given to the comparable.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RentalUnitAdjustedRentAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The adjusted total amount of the rent after accounting for overall differences between the comparable and the subject.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RentalUnitToSubjectComparisonType" type="RentalUnitToSubjectComparisonEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the overall rating of the differences between the comparable and the subject.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SiteInfluencesComparisonType" type="SiteInfluencesComparisonEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list which represents the overall rating of the differences between the comparable and the subject for all types of site influences.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ViewsComparisonType" type="ViewsComparisonEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list which represents the overall rating of the differences between the comparable and the subject for all views associated with the rental unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="RENTAL_COMPARISON_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="RENTAL_INFORMATION">
		<xsd:annotation>
			<xsd:documentation>Information about features and analysis (e.g. current rent amount, lease date, rent control status) of a property that helps determine market rent for the subject property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="CAR_STORAGES" type="CAR_STORAGES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more types of car storage. Holds all occurrences of CAR_STORAGE.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RENTAL_COMPARISON" type="RENTAL_COMPARISON" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about the comparable property that was used in the comparable rental analysis for determining the monthly market rent of the subject property. Details such as the comparable’s weight, comparable’s adjusted rent are captured.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="RENTAL_INFORMATION_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="RENTAL_INFORMATION_SUMMARY">
		<xsd:annotation>
			<xsd:documentation>Contains aggregate information about the rental information for one or more property unit.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ADDITIONAL_RENTAL_INCOMES" type="ADDITIONAL_RENTAL_INCOMES" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about one or more ADDITIONAL_RENTAL_INCOME. Hold all occurrences of ADDITIONAL_RENTAL_INCOME.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RENTAL_INFORMATION_SUMMARY_DETAIL" type="RENTAL_INFORMATION_SUMMARY_DETAIL">
				<xsd:annotation>
					<xsd:documentation>Contains specific information pertaining to RENTAL_INFORMATION_SUMMARY.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="RENTAL_INFORMATION_SUMMARY_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="RENTAL_INFORMATION_SUMMARY_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Contains specific information pertaining to RENTAL_INFORMATION_SUMMARY.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PropertyRentControlStatusType" type="PropertyRentControlStatusEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the existence or likelihood of rent control on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RentControlDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Description of the existing or proposed rent controls for a property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TotalMonthlyActualAdditionalIncomeAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total monthly dollar amount of additional income received for services and amenities provided (e.g. parking lot, laundry facilities).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TotalMonthlyActualIncomeAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The dollar amount of the total monthly income received, including all rental income and additional income.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TotalMonthlyActualRentAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The combined total monthly dollar amount of the rent received for all units on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TotalMonthlyActualRentAmountEstimatedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the total monthly dollar amount of the rent received on the property is an estimate.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TotalMonthlyEstimatedAdditionalIncomeAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total monthly dollar amount that is expected to be received for services and amenities provided (e.g. parking lot, laundry facilities).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TotalMonthlyEstimatedIncomeAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The combined total monthly dollar amount expected to be received for all units and additional income.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TotalMonthlyMarketRentAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The combined total monthly dollar amount that is expected to be received as rental income at full market price for all units on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="RENTAL_INFORMATION_SUMMARY_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>

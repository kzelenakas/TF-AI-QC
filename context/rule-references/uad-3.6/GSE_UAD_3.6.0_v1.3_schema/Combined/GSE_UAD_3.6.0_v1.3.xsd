			<xsd:documentation>Information about one or more modifications made after the initial installation of a manufactured home.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ManufacturedHomeModificationType" type="ManufacturedHomeModificationEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents a modification, attachment or addition made to or that relies on the original structure for support.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ManufacturedHomeModificationTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Manufactured Home Modification Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="MANUFACTURED_HOME_MODIFICATION_EXTENSION" minOccurs="0"/>

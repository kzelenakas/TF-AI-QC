					<xsd:documentation>The annual amount granted in tax reductions or exemptions.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TaxAbatementsOrExemptionsExpirationDate" type="MISMODate" nillable="true" minOccurs="0">

	<xsd:simpleType name="AppraiserEmploymentBase">
		<xsd:annotation>
			<xsd:documentation>Term: Appraiser Employment Type Definition: A value from a MISMO prescribed list that represents the employment category for the appraiser.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="IndependentFeeAppraiser">
				<xsd:annotation>
					<xsd:documentation>The appraiser is an independent contractor; is treated for purposes of Federal income taxation as an independent contractor by both the lender/client and the appraisal management company ordering the appraisal. The appraiser is issued a 1099 and is responsible under IRS rules accordingly.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="StaffAppraiser">
				<xsd:annotation>
					<xsd:documentation>An employee for purposes of Federal income taxation by either the lender/client, firm or the appraisal management company ordering the appraisal. The appraiser is expected to be issued a W-2.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="AppraiserLicenseBase">
		<xsd:annotation>
			<xsd:documentation>Term: Appraiser License Type Definition: Used to specify the different types of appraisal licenses that can be held by an appraiser.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="CertifiedGeneral">
				<xsd:annotation>
					<xsd:documentation>May appraise all types of real property (subject to the COMPETENCY RULE) in USPAP.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CertifiedResidential">
				<xsd:annotation>
					<xsd:documentation>May appraise 1-4 family residential properties without regard to value or complexity, and all other properties with transaction values up to $250,000 (subject to the COMPETENCY RULE in USPAP and applicable state laws).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LicensedResidentialAppraiser">
				<xsd:annotation>
					<xsd:documentation>May appraise non-complex 1-4 unit residential properties with transaction values up to $1million and all other properties with transaction values up to $250,000 (subject to the COMPETENCY RULE is USPAP and applicable state laws).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="None">
				<xsd:annotation>
					<xsd:documentation>The individual does not hold an active license or certification.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="TraineeAppraiser">
				<xsd:annotation>
					<xsd:documentation>Appraisal work completed by this level of credential must be accompanied by the signature of a valid licensed and qualified supervisory appraiser.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>

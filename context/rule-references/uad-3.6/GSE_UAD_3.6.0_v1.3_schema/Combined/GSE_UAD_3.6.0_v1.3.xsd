	<xsd:simpleType name="AdditionalValuationIdentifierBase">
		<xsd:annotation>
			<xsd:documentation>Term: Additional Valuation Identifier Type Definition: A value from a MISMO prescribed list that represents the individual or organization which assigned the valuation identifier.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Client">
				<xsd:annotation>
					<xsd:documentation>Represents the report identifier assigned by the party acting as the client to the transaction.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GovernmentAgency">
				<xsd:annotation>
					<xsd:documentation>Represents the report identifier assigned by the government agency (e.g. VA, FHA).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ManagementCompany">
				<xsd:annotation>
					<xsd:documentation>Represents report identifier assigned by an organization that acts as an independent liaison between two or more parties.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ValuationSoftwareVendor">
				<xsd:annotation>
					<xsd:documentation>A provider of valuation software.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>

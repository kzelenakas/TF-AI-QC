	<xsd:complexType name="STRUCTURE_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Information that describes the size, age and various features of the structure.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AtticExistsIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Indicates that the structure has an attic.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ExteriorConditionRatingCode" type="ExteriorConditionRatingEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An enumerated or coded value that represents the exterior condition rating of the structure.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ExteriorQualityRatingCode" type="ExteriorQualityRatingEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An enumerated or coded value that represents the exterior quality rating of the structure.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FactoryBuiltCertificationExaminedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that a factory-built certification is present and has been examined for an on-frame modular or modular home.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FrontDoorApproximateElevationRangeType" type="FrontDoorApproximateElevationRangeEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the approximate elevation range from grade to the bottom of the front entrance door.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LivingUnitCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The number of separate living units in the structure, including any accessory dwelling units.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RowhouseTownhouseBackToBackIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the rowhouse/townhouse shares a rear wall with a rear wall of another property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RowhouseTownhouseEndUnitIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that a rowhouse/townhouse is located at the end of the row of attached properties.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RowhouseTownhouseLocationType" type="RowhouseTownhouseLocationEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the location of the rowhouse/townhouse when there are other properties above or below.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RowhouseTownhouseStackedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that there are other properties above and/or below the rowhouse/townhouse being referenced.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="StoriesCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total number of above grade levels in a low rise, high rise or mid rise building.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="StructureAreaMeasure" type="MISMOAreaMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the total interior area of the structure (a.k.a. gross building area (GBA)). The applicable unit of measurement is specified by the Area Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="StructureExcludingVehicleStorageAndADUFinishedAreaMeasure" type="MISMOAreaMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the finished area of the structure, excluding the finished area within the detached garage and the finished area from any accessory dwelling units present in the structure. The applicable unit of measurement is specified by the Area Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="StructureExcludingVehicleStorageAndADUUnfinishedAreaMeasure" type="MISMOAreaMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the unfinished area of the structure, excluding the unfinished area within the detached garage and the unfinished area from any accessory dwelling units present in the structure. The applicable unit of measurement is specified by the Area Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="StructureIdentifier" type="MISMOIdentifier" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An unique alphanumeric string used to identify and/or differentiate between multiple structures located on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="StructureNonContinuousFinishedAreaMeasure" type="MISMOAreaMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the total finished area(s) attached to the dwelling that is separate and not accessible from any unit(s) (e.g., a finished office above, below or behind an attached garage that cannot be accessed from within any living unit). The applicable unit of measurement is specified by the Area Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="StructureValuationCommentText" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form alphanumeric string which contains commentary for the structure.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="StructureVolumeMeasure" type="MISMOVolumeMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the total volume of the structure, including finished and unfinished areas, including ADUs. The applicable unit of measurement is specified by the Volume Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="STRUCTURE_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>

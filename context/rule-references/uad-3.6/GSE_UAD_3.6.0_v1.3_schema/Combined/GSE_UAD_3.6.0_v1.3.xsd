	<xsd:complexType name="UNIT_RENT_SCHEDULE">
		<xsd:annotation>
			<xsd:documentation>Information about the lease details and dollar amount of market rent for a living unit in a multi-unit property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ActualRentPerUnitFinishedAreaAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The dollar amount of the rent per finished area unit of measure (e.g. square feet, square meters) determined by dividing the amount of actual rent by the total finished area of the living unit.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FinancialRentalConcessionIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates a monetary concession is included within the terms of the lease.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LeaseStartDate" type="MISMODate" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The date the lease starts.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MonthToMonthLeaseIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the lease agreement is for a one-month period.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

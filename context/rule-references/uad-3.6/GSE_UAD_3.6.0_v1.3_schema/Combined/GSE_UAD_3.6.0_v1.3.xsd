			<xsd:element name="ParcelIdentificationType" type="ParcelIdentificationEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that specifies the method used by taxing authorities or others to identify a parcel of property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ParcelIdentifier" type="MISMOIdentifier" nillable="true" minOccurs="0">

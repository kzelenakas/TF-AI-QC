			<xsd:documentation>Contains specific information pertaining to VALUATION_RECONCILIATION_SUMMARY.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AppraisalReportEffectiveDate" type="MISMODate" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The effective date of the appraisal report on the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LineOfCreditProRataShareSelectionMethodType" type="LineOfCreditProRataShareSelectionMethodEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the pro rata share line of credit amount that was used in determining the final opinion of value when one or more blanket financing liens is a line of credit.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MarketingOrExposureDaysCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total number of days the property would have been offered on the market prior to a hypothetical sale at market value as of the appraisal report effective date.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MarketingOrExposureHighRangeDaysCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The highest number of days the property would have been offered on the market prior to a hypothetical sale at market value as of the appraisal report effective date.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MarketingOrExposureLowRangeDaysCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The lowest number of days the property would have been offered on the market prior to a hypothetical sale at market value as of the appraisal report effective date.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MarketingOrExposureTimeType" type="MarketingOrExposureTimeEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents either the market or exposure time supporting the appraisal amount and condition for the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OpinionOfValueAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The reconciled opinion of value in the appraisal report representing the conclusion of the approaches to value methods used by the appraiser.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyAsIsConditionRatingCode" type="PropertyAsIsConditionRatingEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An enumerated or coded value that represents the actual condition of all dwellings on the property as of the effective date of this appraisal, excluding all required repairs, alterations or inspections.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="VALUATION_RECONCILIATION_SUMMARY_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>

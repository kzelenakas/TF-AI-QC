	<xsd:complexType name="SALES_CONTRACT">
		<xsd:annotation>
			<xsd:documentation>Information about the agreement for sale between a buyer and seller by which they agree on terms of the sale.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="SALES_CONTRACT_DETAIL" type="SALES_CONTRACT_DETAIL">
				<xsd:annotation>
					<xsd:documentation>Information about the type, terms, value and other details of the sales agreement.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="SALES_CONTRACT_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="SALES_CONTRACT_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Information about the type, terms, value and other details of the sales agreement.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AllPropertyRightsAppraisedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates all ownership rights of the property are being included as part of the valuation.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ArmsLengthIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Indicates that this is an arm's length transaction. An arm's length transaction is between a willing buyer and a willing seller with no undue influence on either party and there is no relationship between the parties except that of the specific transaction.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NonArmsLengthCommentText" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form alphanumeric string which contains commentary on the non arm's length transaction.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PersonalPropertyIncludedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Indicates if there is personal property included in the contract for sale.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SalesConcessionAmountKnownIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates the total amount of sales concessions are known.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SalesConcessionIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true indicates the presence of a concession in the sales contract.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SalesConcessionsTypicalToMarketIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that sales concessions are common for the identified market.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SalesContractAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The amount of money the contract is for.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SalesContractDate" type="MISMODate" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The date the sales contract was fully executed.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SalesContractExistsIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that an active sales contract is associated with the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SalesContractReviewedIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Indicated that the appraiser reviewed and analyzed the contract for sale for the subject purchase transaction.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SaleType" type="SaleEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the type of sales transaction for the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SaleTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Sale Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TotalSalesConcessionAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The sum total dollar amount of the value of all sales concessions granted by an interested party including such items as furniture, carpeting, decorator allowances, automobiles, vacations, securities, giveaways or other sales incentives.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="SALES_CONTRACT_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>

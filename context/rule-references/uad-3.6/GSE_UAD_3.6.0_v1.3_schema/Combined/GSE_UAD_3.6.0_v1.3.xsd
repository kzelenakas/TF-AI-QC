		<xsd:sequence>
			<xsd:element name="ValuationAdditionalIntendedUserDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field describing additional intended users of the valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="VALUATION_REPORT_ADDITIONAL_INTENDED_USER_EXTENSION" minOccurs="0"/>

					<xsd:documentation>When true, indicates that a tax reduction or exemption has been granted.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SpecialTaxAssessmentsIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">

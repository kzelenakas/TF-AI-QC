					<xsd:documentation>An image of the encroachment.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="EnergyEfficientAndGreenFeaturesExhibit">
				<xsd:annotation>
					<xsd:documentation>An image showing or supporting one or more energy efficient and green features.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FloorPlan">
				<xsd:annotation>
					<xsd:documentation>An image of a floor plan of the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="FunctionalObsolescenceExhibit">
				<xsd:annotation>
					<xsd:documentation>An image showing or supporting the functionally obsolete feature.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GrossRentMultiplierComparableMap">
				<xsd:annotation>
					<xsd:documentation>An image of a map of the gross rent multiplier comparable properties reflecting the market boundaries.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="HighestAndBestUseExhibit">
				<xsd:annotation>
					<xsd:documentation>An image showing or supporting the highest and best use analysis on the valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="IncomeApproachExhibit">
				<xsd:annotation>
					<xsd:documentation>An image supporting the income approach analysis on the valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LandComparableMap">
				<xsd:annotation>
					<xsd:documentation>An image of a map of the land comparable properties reflecting the market boundaries.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LegalDescription">
				<xsd:annotation>
					<xsd:documentation>An image of the legal description of one or more parcels of real property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ManufacturedHomeExhibit">
				<xsd:annotation>
					<xsd:documentation>An image showing or supporting the characteristics specific to the manufactured home.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ManufacturedHomeFinancingProgramEligibilityCertification">

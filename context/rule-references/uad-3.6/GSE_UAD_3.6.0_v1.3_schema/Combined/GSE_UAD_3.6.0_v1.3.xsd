					<xsd:documentation>Contains information about one or more VALUATION_APPROACH_EXCLUSION_REASON. Contains all instances of VALUATION_APPROACH_EXCLUSION_REASON.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="SALES_COMPARISON_APPROACH_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">

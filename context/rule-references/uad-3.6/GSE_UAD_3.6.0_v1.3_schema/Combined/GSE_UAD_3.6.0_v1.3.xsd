	<xsd:complexType name="ADDITIONAL_IDENTIFIER">
		<xsd:annotation>
			<xsd:documentation>Contains information about an additional identifier associated with the valuation report (e.g. Agency Case, Client Reference Identifier).</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AdditionalValuationIdentifier" type="MISMOIdentifier" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A unique alphanumeric string identifying the valuation report as assigned by a party other than the appraiser (e.g. Client Reference ID, Agency Case Number).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AdditionalValuationIdentifierType" type="AdditionalValuationIdentifierEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the individual or organization which assigned the valuation identifier.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="ADDITIONAL_IDENTIFIER_EXTENSION" minOccurs="0"/>
		</xsd:sequence>

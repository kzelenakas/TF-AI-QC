	<xsd:complexType name="REPLACEMENT_REPRODUCTION_COST">
		<xsd:annotation>
			<xsd:documentation>Information about the replacement or reproduction costs for the various areas of an improvement.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PricePerAreaAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The dollar amount per unit of measure for the indicated area (e.g. price per square foot).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ReplacementOrReproductionCostAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The estimated dollar amount to reproduce or replace a given area associated with this improvement.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ReplacementOrReproductionCostAreaMeasure" type="MISMOAreaMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A measurement that specifies the area of the identified item being replaced or reproduced. The applicable unit of measurement is specified by the Area Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ReplacementOrReproductionCostAreaType" type="ReplacementOrReproductionCostAreaEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the area, associated with this improvement, whose costs to reproduce or replace are being estimated.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ReplacementOrReproductionCostAreaTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Replacement Or Reproduction Cost Area Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="REPLACEMENT_REPRODUCTION_COST_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="REPLACEMENT_REPRODUCTION_COSTS">

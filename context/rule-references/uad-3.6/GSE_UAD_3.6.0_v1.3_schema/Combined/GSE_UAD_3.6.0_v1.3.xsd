	<xsd:complexType name="COMPARABLE">
		<xsd:annotation>
			<xsd:documentation>Information regarding the research, adjustments, summary conclusions and other facts about selections used in the sales comparison approach to value and in the context of grid style reporting.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="COMPARABLE_ADJUSTMENTS" type="COMPARABLE_ADJUSTMENTS" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about adjustments made on a given comparable property in the context of a valuation report. Holds all occurrences of COMPARABLE_ADJUSTMENT.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="COMPARABLE_DETAIL" type="COMPARABLE_DETAIL" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information about the comparable property such as the description of the facts and analysis for a comparable property in the grid style of reporting under the sales comparison approach valuation method in the context of a valuation report.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="COMPARABLE_EXTENSION" minOccurs="0"/>
		</xsd:sequence>

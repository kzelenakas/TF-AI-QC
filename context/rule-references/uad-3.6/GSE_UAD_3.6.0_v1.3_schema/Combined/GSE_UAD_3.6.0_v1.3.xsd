	</xsd:simpleType>
	<xsd:simpleType name="ValuationApproachExclusionReasonBase">
		<xsd:annotation>
			<xsd:documentation>Term: Valuation Approach Exclusion Reason Type Definition: A value from a MISMO prescribed list that represents a reason why the specific valuation approach was not developed.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="DifficultyEstimatingDepreciation">
				<xsd:annotation>
					<xsd:documentation>Indicates that the age of the dwelling and/or the amount of wear and tear on the improvements makes the depreciation difficult to calculate.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="InsufficientData">
				<xsd:annotation>
					<xsd:documentation>The appraiser is unable to develop the identified approach to value due to inadequate data.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LackOfLandSales">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NotNecessaryForCredibleResults">
				<xsd:annotation>
					<xsd:documentation>Indicates that the appraiser has determined the specified approach to value would not provide additional support for the final assignment results.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ValuationAssignmentBase">
		<xsd:annotation>
			<xsd:documentation>Term: Valuation Assignment Type Definition: Specifies the business reason that motivated the order for a valuation.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Construction">
				<xsd:annotation>
					<xsd:documentation>A valuation service that occurs to provide funds to construct a dwelling.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DeedInLieu">
				<xsd:annotation>
					<xsd:documentation>A valuation service that occurs when the deed to the property is accepted in lieu of the act of foreclosure.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="HomeEquity">
				<xsd:annotation>
					<xsd:documentation>A valuation service that occurs when the borrower or current owner is using the equity of their home as collateral.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LoanModification">
				<xsd:annotation>
					<xsd:documentation>A valuation service that occurs when one or more of the borrower's loan terms are changed.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PortfolioEvaluation">
				<xsd:annotation>
					<xsd:documentation>A valuation service that occurs on a portfolio of loans. Generally, the valuation is used to identify the current value of each collateral within the portfolio.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Preforeclosure">
				<xsd:annotation>
					<xsd:documentation>A valuation service that occurs prior to foreclosure proceedings being initiated.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Purchase">
				<xsd:annotation>
					<xsd:documentation>A valuation service used for the transfer of real estate as a part of sale.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Refinance">
				<xsd:annotation>
					<xsd:documentation>A valuation service that occurs when a new loan is initiated to replace an existing loan on the same property. Or, when a new loan is initiated on a property that is owned free and clear of any debt.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="REO">
				<xsd:annotation>
					<xsd:documentation>A commonly used abbreviation for real estate owned. A valuation service that is used after a client has taken possession of the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ShortSale">
				<xsd:annotation>
					<xsd:documentation>A valuation service that occurs for loss mitigation purposes when a client is considering sale or transfer of the property for less than is owed to release the lien.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>

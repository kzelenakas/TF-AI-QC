			<xsd:enumeration value="RecreationRoom">
				<xsd:annotation>
					<xsd:documentation>A room or area designated to be used for recreation and entertainment.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Sunroom">
				<xsd:annotation>
					<xsd:documentation>A room that is built with large windows which are designed to allow in natural light (e.g. solarium).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="UtilityRoom">
				<xsd:annotation>
					<xsd:documentation>A room that houses systems or equipment that are designed to utilize, relay, or enhance the systems of the house (e.g. water heater, electrical panels, forced air, heating mechanism, furnace, sump pump).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="WalkInPantry">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Workshop">
				<xsd:annotation>
					<xsd:documentation>A room used to support different hobbies or activities (e.g. tool room, craft room, dark room).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="RoomConditionStatusBase">
		<xsd:annotation>
			<xsd:documentation>Term: Room Condition Status Type Definition: A value from a MISMO prescribed list that represents the condition of the room.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="DamagedAndFunctional">
				<xsd:annotation>
					<xsd:documentation>Indicates the referenced room remains fully functional but exhibits damage.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DamagedAndNonfunctional">
				<xsd:annotation>
					<xsd:documentation>Indicates the referenced room is damaged to the level that it is no longer functional.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NewOrLikeNew">
				<xsd:annotation>
					<xsd:documentation>Indicates the referenced room is new or like new by exhibiting no visible signs of use.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="TypicalWearAndTear">
				<xsd:annotation>
					<xsd:documentation>Indicates the referenced room is fully functional but exhibits visible signs of use.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="RoomUpdatedTimeframeBase">
		<xsd:annotation>
			<xsd:documentation>Term: Room Updated Timeframe Type Definition: A value from a MISMO prescribed list that represents the estimated range of years when the room was updated.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="FiveToTenYears">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LessThanOneYear">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OneToFiveYears">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="TenOrMoreYears">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="RoomUpdateStatusBase">
		<xsd:annotation>
			<xsd:documentation>Term: Room Update Status Type Definition: A value from a MISMO prescribed list that represents the degree to which the room has been finished.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="FullyUpdated">
				<xsd:annotation>
					<xsd:documentation>A room which has been completely modernized, renovated, refinished or remodeled to a like new condition.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NotUpdated">
				<xsd:annotation>
					<xsd:documentation>A room which has had no modernization and has not experienced any renovation, refinishing, or remodeling since the original date of construction or within a timeframe that renders the update’s impact negligible.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PartiallyUpdated">
				<xsd:annotation>
					<xsd:documentation>A room which has a level of modernization with some replaced, refinished or refurbished components but does not rise to the level of total replacement.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="RowhouseTownhouseLocationBase">
		<xsd:annotation>
			<xsd:documentation>Term: Rowhouse Townhouse Location Type Definition: A value from a MISMO prescribed list that represents the location of the rowhouse/townhouse when there are other properties above or below.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="BottomUnit">
				<xsd:annotation>
					<xsd:documentation>Indicates that there are other properties located on floors immediately above but not below the rowhouse/townhouse being referenced.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="MiddleUnit">
				<xsd:annotation>
					<xsd:documentation>Indicates that there are properties located on floors both immediately above and below the rowhouse/townhouse being referenced.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="TopUnit">
				<xsd:annotation>
					<xsd:documentation>Indicates that there are other properties located on floors immediately below but not above the rowhouse/townhouse being referenced.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="SaleBase">
		<xsd:annotation>
			<xsd:documentation>Term: Sale Type Definition: A value from a MISMO prescribed list that represents the type of sales transaction for the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="CourtOrderedNonForeclosureSale">
				<xsd:annotation>
					<xsd:documentation>A sale in which a judge has ordered the sale of the property as a dispute resolution.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="EstateSale">
				<xsd:annotation>
					<xsd:documentation>A sale as a result of disposition of assets as ordered by a court or by the direction of a will and/or trust.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ForeclosureSale">
				<xsd:annotation>
					<xsd:documentation>The process in which a forced sale of a property occurs in an attempt to recover an outstanding loan balance.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LandSale">
				<xsd:annotation>
					<xsd:documentation>The sale of undeveloped or minimally developed land.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PreSubdivisionSale">
				<xsd:annotation>
					<xsd:documentation>The sale of a parcel prior to subdivision resulting in the splitting of the property into multiple parcels.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="RelocationSale">
				<xsd:annotation>
					<xsd:documentation>A property being sold as a part of a relocation program.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="REOSale">
				<xsd:annotation>
					<xsd:documentation>The sale of a property from inventory that has been acquired through foreclosure, deed-in-lieu of foreclosure, or similar legal processes by the lien holder.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SaleBetweenRelatedParties">
				<xsd:annotation>
					<xsd:documentation>The sale of a property in which the buyer and seller are related (e.g. business partners, family members).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ShortSale">
				<xsd:annotation>
					<xsd:documentation>A sale of property in which the lien holder accepts less than the debt or obligation against the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="TypicallyMotivated">
				<xsd:annotation>
					<xsd:documentation>A sale that occurs under open and competitive market conditions where both parties are well informed and acting in their own best interest.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ServiceBase">
		<xsd:annotation>
			<xsd:documentation>Term: Service Type Definition: A value from a MISMO prescribed list that specifies the type of service being defined under the SERVICE element.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Inspection">
				<xsd:annotation>
					<xsd:documentation>A fulfillment service or product related to an inspection request and/or an inspection response.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Valuation">
				<xsd:annotation>
					<xsd:documentation>A fulfillment service or product related to a valuation request and/or a valuation response.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="SewerSystemBase">
		<xsd:annotation>
			<xsd:documentation>Term: Sewer System Type Definition: A value from a MISMO prescribed list that represents a type of sewer system. Also used in conjunction with a type of utility ownership.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Cesspool">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Septic">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="SiteDrainageReasonBase">
		<xsd:annotation>
			<xsd:documentation>Term: Site Drainage Reason Type Definition: A value from a MISMO prescribed list that represents the drainage reason that may impact the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="EvidenceOfErosion">
				<xsd:annotation>
					<xsd:documentation>Degradation of the physical site due to water runoff.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ImproperGrading">
				<xsd:annotation>
					<xsd:documentation>Incorrect grading of land such that water drains towards the foundation.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="StandingWater">
				<xsd:annotation>
					<xsd:documentation>Water pooling on the surface of the ground.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="SiteFeatureBase">
		<xsd:annotation>
			<xsd:documentation>Term: Site Feature Type Definition: A value from a MISMO prescribed list that represents a given characteristic associated with the site.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="CoastalBarrierResourcesSystem">
				<xsd:annotation>
					<xsd:documentation>Areas protected by the Coastal Barrier Resource Act (CBRA) of 1982 which encourages the conservation of Hurricane prone, biologically rich coastal barriers.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Drainage">
				<xsd:annotation>
					<xsd:documentation>The movement of water away from the site (e.g. slope, surface, subsurface).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ExcessLand">
				<xsd:annotation>
					<xsd:documentation>Land beyond what is required to support the existing improvements of the site which can be subdivided and sold.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Landlocked">
				<xsd:annotation>
					<xsd:documentation>A site without legal access to a public thoroughfare (without easements).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Landscaping">
				<xsd:annotation>
					<xsd:documentation>External portions of the site improved for functionality or aesthetic quality (e.g. lawn coverage, vegetation, shrubs, trees, gardens and paths).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="None">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="RoadFrontage">
				<xsd:annotation>
					<xsd:documentation>A road exists which transects or abuts the site to such an extent that value and/or marketability could be impacted.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Shape">
				<xsd:annotation>
					<xsd:documentation>The outline of a site per legal boundaries.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SoilSuitability">
				<xsd:annotation>
					<xsd:documentation>Physical properties of the soil suitable to support the current or proposed property development and use.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SurplusLand">
				<xsd:annotation>
					<xsd:documentation>Land beyond what is required to support the existing improvements of the site which cannot be subdivided and sold off separately.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Topography">
				<xsd:annotation>
					<xsd:documentation>The terrain or relative elevation of site surfaces (e.g. rolling, sloping, rocky, level).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Wetlands">
				<xsd:annotation>
					<xsd:documentation>Areas that are inundated or saturated by surface or ground water at a frequency and duration sufficient to support, and that under normal circumstances do support, a prevalence of vegetation typically adapted for life in saturated soil conditions. Wetlands generally include swamps, marshes, bogs, and similar areas.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ZeroLotLine">
				<xsd:annotation>
					<xsd:documentation>Residential real estate in which the primary structure comes up to, or very near to, the edge of the property line (e.g. rowhouses, garden homes, patio homes, and townhomes).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="SiteInfluenceBase">
		<xsd:annotation>
			<xsd:documentation>Term: Site Influence Type Definition: Specifies a type of condition that affects the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Agricultural">
				<xsd:annotation>
					<xsd:documentation>Crop-producing farm land.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Airport">
				<xsd:annotation>
					<xsd:documentation>A designated area where aircraft take off and land.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="BodyOfWater">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="BusyRoadway">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CommercialArea">
				<xsd:annotation>
					<xsd:documentation>An area intended to produce income (e.g. office buildings, retail buildings, hospitality).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GolfCourse">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GreenSpace">
				<xsd:annotation>
					<xsd:documentation>An area of protected or conserved land or water on which development is indefinitely set aside.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="HighDensityResidential">
				<xsd:annotation>
					<xsd:documentation>A densely populated residential area.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="HighPressureGasLine">
				<xsd:annotation>
					<xsd:documentation>A distribution system with lines in which the gas pressure in the main is higher than the pressure provided to the customer.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="HistoricDistrict">
				<xsd:annotation>
					<xsd:documentation>A district designated to be of historical significance by a recognized authority.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="IndustrialArea">
				<xsd:annotation>
					<xsd:documentation>An area intended for the production of manufactured goods (e.g. factories).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LocalDistributionLine">
				<xsd:annotation>
					<xsd:documentation>Electric lines that commonly supply power to residential housing developments, similar facilities and individual properties.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OilOrGasWell">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="OverheadElectricPowerTransmissionLine">
				<xsd:annotation>
					<xsd:documentation>Electric lines that supply power from power generation stations to Local Distribution Lines.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Park">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PublicTransportationHub">
				<xsd:annotation>
					<xsd:documentation>A location where public transportation can be accessed (e.g., bus stop, metro station).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="RailLine">
				<xsd:annotation>
					<xsd:documentation>The rail line used by commercial or commuter trains (e.g., railroad tracks, metro tracks).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Residential">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="School">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="StormwaterRetention">
				<xsd:annotation>
					<xsd:documentation>An area designed to hold or retain stormwaters on a permanent basis.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="SiteInfluenceProximityBase">
		<xsd:annotation>
			<xsd:documentation>Term: Site Influence Proximity Type Definition: A value from a MISMO prescribed list that represents proximity of the site influence to the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Bordering">
				<xsd:annotation>
					<xsd:documentation>An influence located on or coming from a site which directly abuts the subject site.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Offsite">
				<xsd:annotation>
					<xsd:documentation>An influence located on or coming from a site that is not the subject site nor directly abuts the subject site.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Onsite">
				<xsd:annotation>
					<xsd:documentation>An influence located on or coming directly from the subject site.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="SiteInfluencesComparisonBase">
		<xsd:annotation>
			<xsd:documentation>Term: Site Influences Comparison Type Definition: A value from a MISMO prescribed list which represents the overall rating of the differences between the comparable and the subject for all types of site influences.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Inferior">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Similar">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Superior">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="SiteUtilityOwnershipBase">
		<xsd:annotation>
			<xsd:documentation>Term: Site Utility Ownership Type Definition: A value from a MISMO prescribed list that specifies whether the utility is public or non-public.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="NonPublic">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Public">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="SiteValuationMethodBase">
		<xsd:annotation>
			<xsd:documentation>Term: Site Valuation Method Type Definition: A value from a MISMO prescribed list that represents the method by which the site value is calculated.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Allocation">
				<xsd:annotation>
					<xsd:documentation>An estimation of land value in which sales of improved properties are analyzed to establish a typical ratio of land value to total property value. This ratio is applied to the property being appraised to arrive at an estimated value for the land.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Extraction">
				<xsd:annotation>
					<xsd:documentation>An estimation of land value in which the depreciated cost of the improvements on the improved property is estimated and deducted from the total sale price to arrive at an estimated value for the land.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SalesComparison">
				<xsd:annotation>
					<xsd:documentation>Identifies sales of vacant land and/or sites and applies an adjustment process to the sale price to determine an indicated value or range of value for the subject site.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="SiteZoningComplianceBase">
		<xsd:annotation>
			<xsd:documentation>Term: Site Zoning Compliance Type Definition: A value from a MISMO prescribed list that represents the level of compliance of the site to zoning regulations.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Illegal">
				<xsd:annotation>
					<xsd:documentation>Current use of the land or structure does not comply with local zoning regulations.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Legal">
				<xsd:annotation>
					<xsd:documentation>Current use of the land or structure complies with local zoning regulations.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LegalNonConforming">
				<xsd:annotation>
					<xsd:documentation>A permissible exception to current zoning ordinances where the property was legally conforming when established but no longer conforms with current zoning.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NoZoning">
				<xsd:annotation>
					<xsd:documentation>No zoning regulations exist for the land or structure.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="SiteZoningComplianceIllegalReasonBase">
		<xsd:annotation>
			<xsd:documentation>Term: Site Zoning Compliance Illegal Reason Type Definition: A value from a MISMO prescribed list that represents the reason that the site does not comply with zoning regulations.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="AccessoryDwellingUnit">
				<xsd:annotation>
					<xsd:documentation>Accessory dwelling units not allowed on the site.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DevelopmentStandards">
				<xsd:annotation>
					<xsd:documentation>Site not compliant with development regulations.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ExcessiveUnits">
				<xsd:annotation>
					<xsd:documentation>The property exceeds the allowable density established by the local zoning authority.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="LotSize">
				<xsd:annotation>
					<xsd:documentation>Site size does not meet standards established by local zoning authority.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ManufacturedHome">
				<xsd:annotation>
					<xsd:documentation>Manufactured homes not allowed on the site.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="SkirtingMaterialBase">
		<xsd:annotation>
			<xsd:documentation>Term: Skirting Material Type Definition: A value from a MISMO prescribed list that represents the skirting material.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Asbestos">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Brick">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CementBoard">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ConcreteBlock">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="EngineeredWood">
				<xsd:annotation>
					<xsd:documentation>A wood product made by binding or fixing strands or fibers of natural wood together with adhesives (e.g. particle board, plywood, T-1 11).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Fiberglass">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Log">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Metal">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="PouredConcrete">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Vinyl">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Wood">
				<xsd:annotation>
					<xsd:documentation>A solid wood material not manufactured with any adhesives and/or bonding agents.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="SpecialAirportHazardZoneBase">
		<xsd:annotation>
			<xsd:documentation>Term: Special Airport Hazard Zone Type Definition: A value from a MISMO prescribed list that represents areas mapped as special airport hazard zones at the end of the runway(s) where aircraft accidents are most likely to occur.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="CivilAirportRunwayClearZone">
				<xsd:annotation>
					<xsd:documentation>Areas immediately beyond the ends of a runway for civil airports as established by Federal Aviation Administration that serves to enhance the protection of people and property on the ground in the event an aircraft lands or crashes beyond the runway end.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="MilitaryAirportAccidentPotentialZone1">
				<xsd:annotation>
					<xsd:documentation>Areas beyond the Clear Zone for military airfields established by the United States Department of Defense as a planning tool for local planning agencies. Accident Potential Zones are areas where an aircraft mishap is most likely to occur, if one occurs.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="MilitaryAirportClearZone">
				<xsd:annotation>
					<xsd:documentation>Areas immediately beyond the ends of a runway for military airfields established by the United States Department of Defense.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="None">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="StreetAccessBase">
		<xsd:annotation>
			<xsd:documentation>Term: Street Access Type Definition: A value from a MISMO prescribed list that represents the means of access and exit to and from the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Alley">
				<xsd:annotation>
					<xsd:documentation>A typically narrow passageway between buildings/residences which is designed to provide access to the property but not meant for use as local roads.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Arterial">
				<xsd:annotation>
					<xsd:documentation>A high capacity road primarily designed to provide routes from city to city. Features divided lanes and high to moderate rates of speed, limited and controlled pedestrian access (e.g. State/County highways).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Collector">
				<xsd:annotation>
					<xsd:documentation>A moderate capacity road designed to link to arterial roads and collect traffic from local roads. May feature divided lanes, moderate rates of speed, and controlled pedestrian access.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CulDeSac">
				<xsd:annotation>
					<xsd:documentation>A low capacity road, designed as a non-through street which ends in a circle typically used for vehicle turn around. Features a low rate of speed and unregulated pedestrian access.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="DeadEnd">
				<xsd:annotation>
					<xsd:documentation>A low capacity road or series of roads which end abruptly with no specified area for vehicle turn around and will have only one means of entry/exit. Features low rate of speed and unregulated pedestrian access (e.g. non-through street).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Local">
				<xsd:annotation>
					<xsd:documentation>A moderate to low capacity road which is primarily designed to provide direct access to individual residential properties. Typically features single lane, low rates of speed and unregulated pedestrian access (e.g. neighborhood/residential roads).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Rural">
				<xsd:annotation>
					<xsd:documentation>A low capacity road which is primarily designed to provide direct access to agricultural properties and larger acreage residential properties. Typically present in areas of low population density. Will have low rates of speed and unregulated pedestrian access (e.g. County roads).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="StructuralDesignBase">
		<xsd:annotation>
			<xsd:documentation>Term: Structural Design Type Definition: A value from a MISMO prescribed list that represents the type of structural design when dwellings are connected (e.g. rowhouse, townhouse).</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Highrise">
				<xsd:annotation>
					<xsd:documentation>A multi-unit property that has eight or more stories.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Lowrise">
				<xsd:annotation>
					<xsd:documentation>A multi-unit property with one to three stories.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Midrise">
				<xsd:annotation>
					<xsd:documentation>A multi-unit property with four to seven stories.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="RowhouseTownhouse">
				<xsd:annotation>
					<xsd:documentation>One dwelling in a series of more than two attached dwellings, all of which have at least one common wall with another dwelling.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SemiDetached">
				<xsd:annotation>
					<xsd:documentation>One dwelling of two separately parceled, single family dwellings sharing a common wall or otherwise attached on one side (e.g. twin home, side-by-side, duplex).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="SubjectToCompletionFeatureComparisonBase">
		<xsd:annotation>
			<xsd:documentation>Term: Subject To Completion Feature Comparison Type Definition: A value from a MISMO prescribed list that represents the comparison of the materials and workmanship to the original plans and specifications.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Inferior">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Similar">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Superior">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="SwimmingPoolFeatureBase">
		<xsd:annotation>
			<xsd:documentation>Term: Swimming Pool Feature Type Definition: A value from a MISMO prescribed list that represents a feature of the swimming pool.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Caged">
				<xsd:annotation>
					<xsd:documentation>Indicates the swimming pool area is surrounded by a caged or a screened enclosure which offers minimal protection from the elements.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Heated">
				<xsd:annotation>
					<xsd:documentation>Indicates the temperature of the swimming pool water can be warmed through a mechanical source (e.g. pool heater).</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Indoor">
				<xsd:annotation>
					<xsd:documentation>Indicates the swimming pool area is located in a completely enclosed structure which offers complete protection from the elements.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ThermalZoneBase">
		<xsd:annotation>
			<xsd:documentation>Term: Thermal Zone Code Definition: An enumeration or a coded value identifying the Thermal Zone that the manufactured home was designed and constructed to conform to.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Zone1">
				<xsd:annotation>
					<xsd:documentation>Meets requirements of U/O Value Zone Map Zone 1. This zone consists of the southeastern coastal states grouped from South Carolina to Texas and Hawaii. Comprised of 8 states.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Zone2">
				<xsd:annotation>
					<xsd:documentation>Meets requirements of U/O Value Zone Map Zone 2. This zone consists of the mid-zone of the nation and is grouped from North Carolina across to California. Comprised of 10 states.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Zone3">
				<xsd:annotation>
					<xsd:documentation>Meets requirements of U/O Value Zone Map Zone 3. This zone consists of primarily the Upper Midwest and the Northern coastal states and Alaska. Consists of 32 states.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="TopographyBase">
		<xsd:annotation>
			<xsd:documentation>Term: Topography Type Definition: A value from a MISMO prescribed list that represents shape and features of land surface.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="Flat">
				<xsd:annotation>
					<xsd:documentation>Geographical feature exhibiting little to no elevation changes.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Other">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Rocky">
				<xsd:annotation>
					<xsd:documentation>Geographical feature exhibiting uneven landmass covered in rocks.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Rolling">
				<xsd:annotation>
					<xsd:documentation>Geographical feature exhibiting, continuous change in land contour.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="Sloping">
				<xsd:annotation>
					<xsd:documentation>Geographical feature exhibiting an increasing or decreasing elevation in a single direction.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="UnitBelowGradeFinishComparisonBase">
		<xsd:annotation>
			<xsd:documentation>Term: Unit Below Grade Finish Comparison Type Definition: A value from a MISMO prescribed list that represents the quality of the finish for the below grade area(s) when compared to the above grade living area.</xsd:documentation>

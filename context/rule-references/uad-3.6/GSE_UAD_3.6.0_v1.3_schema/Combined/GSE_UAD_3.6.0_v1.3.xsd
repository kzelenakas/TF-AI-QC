	<xsd:complexType name="ADDITIONAL_REQUESTED_CONDITIONAL_VALUATION">
		<xsd:annotation>
			<xsd:documentation>Contains information about an additional opinion of value for the subject property when additional, specific client-requested conditions are considered.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AdditionalOpinionOfValueAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An additional opinion of value for the subject property for a specific client requested condition.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MarketingOrExposureDaysCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The total number of days the property would have been offered on the market prior to a hypothetical sale at market value as of the appraisal report effective date.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MarketingOrExposureHighRangeDaysCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The highest number of days the property would have been offered on the market prior to a hypothetical sale at market value as of the appraisal report effective date.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MarketingOrExposureLowRangeDaysCount" type="MISMOCount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The lowest number of days the property would have been offered on the market prior to a hypothetical sale at market value as of the appraisal report effective date.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MarketingOrExposureTimeType" type="MarketingOrExposureTimeEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents either the market or exposure time supporting the appraisal amount and condition for the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyValuationConditionalConclusionType" type="PropertyValuationConditionalConclusionEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the conclusions of the appraisal that there may be a dependency on future repairs or activities.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="ADDITIONAL_REQUESTED_CONDITIONAL_VALUATION_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>

			<xsd:enumeration value="C3">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="C4">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="C5">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="C6">
				<xsd:annotation>
					<xsd:documentation/>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="OverallFlooringUpdateStatusBase">
		<xsd:annotation>
			<xsd:documentation>Term: Overall Flooring Update Status Type Definition: A value from a MISMO prescribed list that represents the degree to which the flooring has been updated in the entire living unit.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="MISMOEnum_Base">
			<xsd:enumeration value="FullyUpdated">
				<xsd:annotation>
					<xsd:documentation>All flooring throughout the living unit has been completely modernized, renovated, refinished or remodeled and is new or in like new condition.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="ModeratelyUpdated">
				<xsd:annotation>
					<xsd:documentation>Some flooring in the living unit has minor updates and/or minimal modernization with less than a majority of the flooring appearing to have been updated.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NotUpdated">
				<xsd:annotation>
					<xsd:documentation>No modernization and no renovation, refinishing, nor remodeling to the flooring throughout the living unit; or, any updates that have been made were completed in a timeframe that renders their impact negligible.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SignificantlyUpdated">
				<xsd:annotation>
					<xsd:documentation>A majority, but not all, of the flooring throughout the living unit appears to have been updated.</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="OverallQualityRatingBase">

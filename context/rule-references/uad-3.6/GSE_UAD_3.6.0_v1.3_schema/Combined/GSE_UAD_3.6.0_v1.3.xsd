			<xsd:documentation>Information regarding the features and other information about an attic. A space found directly below the pitched roof of a house and fills the space between the ceiling of the top floor of a building and the slanted roof, they are known for being awkwardly shaped spaces with exposed rafters and difficult-to-access corners.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="ATTIC_DETAIL" type="ATTIC_DETAIL" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Information regarding the quality, condition, materials and other facts about the attic.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="ATTIC_EXTENSION" minOccurs="0"/>

	<xsd:complexType name="DATA_SOURCE">
		<xsd:annotation>
			<xsd:documentation>Information on the type, name, identification and other facts about the data source. The data source is the origin of a fact, detail or piece of information.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="DataSourceEffectiveDate" type="MISMODate" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The effective date of the source of information.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DataSourceIdentifier" type="MISMOIdentifier" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A unique alphanumeric string identifying the record as assigned by the Data Source Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DataSourceName" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The name associated with the provider or source of the data.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DataSourceQualityRatingCode" type="MISMOCode" nillable="true" minOccurs="0">
				<xsd:annotation>

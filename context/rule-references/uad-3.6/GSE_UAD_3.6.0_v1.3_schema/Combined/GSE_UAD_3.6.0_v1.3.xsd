					<xsd:documentation>A free-form text field that specifies the enumeration when the value of Other is used for Renewable Energy Component Ownership Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RenewableEnergyComponentType" type="RenewableEnergyComponentEnum" nillable="true" minOccurs="0">

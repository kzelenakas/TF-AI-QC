			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="COMPARABLE_ADJUSTMENT">
		<xsd:annotation>
			<xsd:documentation>Information detailing the type, amount and other facts about the adjustment to price made to a comparable property in the context of grid style reporting for the sales comparison approach to value.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AdditionalComparisonLineItemDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field describing the additional comparison item.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AdditionalComparisonLineItemIdentifier" type="MISMOIdentifier" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A unique alphanumeric string identifying an additional comparison item.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ComparableAdjustmentAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The dollar amount of the adjustment associated with the identified Comparable Adjustment Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ComparableAdjustmentType" type="ComparableAdjustmentEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents an element of comparison between the subject property and comparable property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UnitIdentifier" type="MISMOIdentifier" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An unique alphanumeric string used to identify and/or differentiate between multiple units located on the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="COMPARABLE_ADJUSTMENT_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attribute name="SequenceNumber" type="MISMOSequenceNumber_Base">
			<xsd:annotation>
				<xsd:documentation>An integer value used to provide an order to multi-instance sibling elements. The value must be unique for each sibling element.</xsd:documentation>
			</xsd:annotation>
		</xsd:attribute>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="COMPARABLE_ADJUSTMENTS">
		<xsd:annotation>
			<xsd:documentation>Information about adjustments made on a given comparable property in the context of a valuation report. Holds all occurrences of COMPARABLE_ADJUSTMENT.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="COMPARABLE_ADJUSTMENT" type="COMPARABLE_ADJUSTMENT" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>Information detailing the type, amount and other facts about the adjustment to price made to a comparable property in the context of grid style reporting for the sales comparison approach to value.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="COMPARABLE_ADJUSTMENTS_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="COMPARABLE_DETAIL">
		<xsd:annotation>
			<xsd:documentation>Information about the comparable property such as the description of the facts and analysis for a comparable property in the grid style of reporting under the sales comparison approach valuation method in the context of a valuation report.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AdjustedSalesPriceAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The sales price of a comparable property after it has been adjusted to reflect the differences between the comparable property and the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AdjustedSalesPricePerBedroomAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The dollar amount of a bedroom determined by dividing the adjusted sales price by the total bedrooms in all living units (including any accessory dwelling units).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AdjustedSalesPricePerUnitAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The dollar amount of a living unit determined by dividing the adjusted sales price by the number of living units (including any accessory dwelling units).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ComparableToSubjectDirectionType" type="ComparableToSubjectDirectionEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list which represents the compass direction the comparable property is located when compared to the subject property location.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ComparableWeightType" type="ComparableWeightEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that represents the emphasis given to the comparable.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ContractAmountUnknownIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the contract amount is unknown.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ContractDateUnknownIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the contract date is unknown.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="GrossMonthlyRentMultiplierNumber" type="MISMONumeric" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A numeric value that specifies the Gross Rent Multiplier for the property which is derived by dividing the sale price by the actual gross monthly rent.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MortgageType" type="MortgageEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A value from a MISMO prescribed list that specifies the private or public sector entity under whose guidelines the mortgage is originated.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MortgageTypeOtherDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field used to collect additional information or a description of the mortgage type when Other is selected.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NoFinancingTransactionIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the transaction was executed without financing (e.g., cash, gift). When false, the transaction was financed.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PricePerTotalStandardAboveGradeFinishedAreaAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The price per total standard finished area above grade (commonly referred to as GLA or finished square footage). The total standard finished area above grade includes measurements across all buildings containing living units, including any accessory dwelling units.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PricePerUnitOfMeasureTypeForTotalFinishedAreaOfAllLivingUnitsIncludingADUAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The price in terms of dollars per the Unit Of Measure Type used for the total finished area from all accessory dwelling units, finished area of all living units, and finished area from any common area located within the dwelling(s).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PropertyOrdinalNumber" type="MISMOOrdinalNumber" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A positive, whole number that identifies the position of the property in the valuation analysis.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProximityToSubjectDistanceLinearMeasure" type="MISMOLinearMeasure" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A linear measurement that specifies the linear distance the comparable property is from the subject property. The applicable unit of measurement is specified by the Linear Unit Of Measure Type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SalePriceNetTotalAdjustmentAmount" type="MISMOAmount" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The net dollar amount of the adjustments made to a comparable property price.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SaleToListPriceRatioPercent" type="MISMOPercent" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A ratio that represents the difference between the list prices and negotiated sales prices for settled sales in the subject property's market.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SameBuilderAsSubjectIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the comparable property was constructed by the same builder as the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SameProjectAsSubjectIndicator" type="MISMOIndicator" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>When true, indicates that the comparable property is in the same project as the subject property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EXTENSION" type="COMPARABLE_DETAIL_EXTENSION" minOccurs="0"/>
		</xsd:sequence>
		<xsd:attributeGroup ref="xlink:MISMOresourceLink">
			<xsd:annotation>
				<xsd:documentation>An xlink attribute group for defining the end point of a relationship.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
		<xsd:attributeGroup ref="AttributeExtension">
			<xsd:annotation>
				<xsd:documentation>An implementation of the ability to extend an instance document by using any attribute. To change from Lax to make an redefinition restriction of AttributeExtension attribute group.</xsd:documentation>
			</xsd:annotation>
		</xsd:attributeGroup>
	</xsd:complexType>
	<xsd:complexType name="CONDITION_COVENANT_RESTRICTION">
		<xsd:annotation>
			<xsd:documentation>Contains information about restrictions that could impact the value or use of the property.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="RestrictionDescription" type="MISMOString" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A free-form text field describing the restriction and/or its impact on the value and marketability of the property.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RestrictionType" type="RestrictionEnum" nillable="true" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>A type of restriction that could impact the value or use of the property.</xsd:documentation>

				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="urn:fdc:mismo.org:2009:residential/DATA_SOURCE_IsDataSourceFor_PriorSalesOrTransfersIndicator">
				<xs:annotation>
					<xs:documentation>Link DATA_SOURCE to the item that needs a source of information identified.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="urn:fdc:mismo.org:2009:residential/DATA_SOURCE_IsDataSourceFor_PROJECT">
				<xs:annotation>
					<xs:documentation>Link DATA_SOURCE to the item that needs a source of information identified.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="urn:fdc:mismo.org:2009:residential/DATA_SOURCE_IsDataSourceFor_PROPERTY">
				<xs:annotation>
					<xs:documentation>Link DATA_SOURCE to the item that needs a source of information identified.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="urn:fdc:mismo.org:2009:residential/DATA_SOURCE_IsDataSourceFor_SALES_HISTORY">

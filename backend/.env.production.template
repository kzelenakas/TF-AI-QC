# TF AI-QC Production Environment Variables
# Copy this to Railway service variables — never commit actual values.
# All values are required unless marked OPTIONAL.

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
SECRET_KEY=<generate with: python -c "import secrets; print(secrets.token_hex(32))">

# CORS — set to your True Footage Bubble app domain
CORS_ORIGINS=https://your-app.bubbleapps.io,https://truefootage.com

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
# Get from: Cloudflare Dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID=<cloudflare-account-id>
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_BUCKET_NAME=tf-ai-qc-reports

# ── Ollama (Railway internal service) ────────────────────────────────────────
# Set to Railway private networking URL for the Ollama service
OLLAMA_BASE_URL=http://ollama.railway.internal:11434/v1
OLLAMA_MODEL=glm-4.7-flash

# ── Claude API Fallback (OPTIONAL) ───────────────────────────────────────────
# Only needed if Ollama is unreachable; used as narrative scoring fallback
ANTHROPIC_API_KEY=

# ── Bubble Auth ───────────────────────────────────────────────────────────────
# Get from: Bubble app → Settings → API → API Token
BUBBLE_AUTH_SECRET=<bubble-jwt-signing-secret>
BUBBLE_DATA_API_URL=https://your-app.bubbleapps.io/api/1.1/obj
BUBBLE_DATA_API_KEY=<bubble-data-api-key>

# ── Internal Cron ─────────────────────────────────────────────────────────────
# Generate a random string — used by Railway cron jobs to authenticate
INTERNAL_CRON_SECRET=<generate with: python -c "import secrets; print(secrets.token_urlsafe(32))">

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_<your-resend-key>
# Comma-separated reviewer emails to notify on QC complete
REVIEWER_NOTIFY_EMAIL=reviewer@truefootage.com
